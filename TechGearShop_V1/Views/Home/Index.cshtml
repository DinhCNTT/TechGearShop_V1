@model TechGearShop_V1.Models.ViewModels.HomeViewModel

@{
    ViewData["Title"] = "Trang Chủ";
}

<!-- Hero Banner Section -->
<div id="heroCarousel" class="carousel slide mb-5 shadow-lg rounded-4 overflow-hidden position-relative" data-bs-ride="carousel" data-bs-interval="3000">
    <div class="carousel-indicators">
        <button type="button" data-bs-target="#heroCarousel" data-bs-slide-to="0" class="active" aria-current="true"></button>
        <button type="button" data-bs-target="#heroCarousel" data-bs-slide-to="1"></button>
        <button type="button" data-bs-target="#heroCarousel" data-bs-slide-to="2"></button>
    </div>
    
    <div class="carousel-inner" style="height: 500px;">
        <!-- Banner 1 -->
        <div class="carousel-item active h-100">
            <img src="https://images.unsplash.com/photo-1593640495253-23196b27a87f?q=80&w=2000&auto=format&fit=crop" class="d-block w-100 h-100 object-fit-cover" alt="Laptop Gaming" style="filter: brightness(40%); object-position: center;">
            <div class="carousel-caption d-flex flex-column justify-content-center h-100 text-white" style="bottom: 0;">
                <h1 class="display-3 fw-bolder mb-3 text-uppercase text-light" style="letter-spacing: 2px; text-shadow: 2px 2px 10px rgba(0,0,0,0.7);">Đại Tiệc Laptop Đồ Họa</h1>
                <p class="fs-4 mb-4 fw-light" style="text-shadow: 1px 1px 5px rgba(0,0,0,0.8);">Giảm giá cực mạnh lên tới 30% cho Sinh viên & Doanh nghiệp</p>
                <div>
                    <a href="#" class="btn btn-primary btn-lg px-5 fw-bold rounded-pill shadow">Săn Liền Tay <i class="bi bi-arrow-right ms-2"></i></a>
                </div>
            </div>
        </div>
        
        <!-- Banner 2 -->
        <div class="carousel-item h-100">
            <img src="https://images.unsplash.com/photo-1542751371-adc38448a05e?q=80&w=2000&auto=format&fit=crop" class="d-block w-100 h-100 object-fit-cover" alt="PC Build" style="filter: brightness(40%); object-position: center;">
            <div class="carousel-caption d-flex flex-column justify-content-center h-100 text-white" style="bottom: 0;">
                <h1 class="display-3 fw-bolder mb-3 text-uppercase text-light" style="letter-spacing: 2px; text-shadow: 2px 2px 10px rgba(0,0,0,0.7);">Build PC eSports</h1>
                <p class="fs-4 mb-4 fw-light" style="text-shadow: 1px 1px 5px rgba(0,0,0,0.8);">Tặng kèm chuột cơ và bàn di khi mua PC Trọn Bộ tại TechGear</p>
                <div>
                    <a href="#" class="btn btn-success btn-lg px-5 fw-bold rounded-pill shadow">Nhận Ưu Đãi Ngay <i class="bi bi-gift ms-2"></i></a>
                </div>
            </div>
        </div>
        
        <!-- Banner 3 -->
        <div class="carousel-item h-100">
            <img src="https://images.unsplash.com/photo-1542393545-10f5cde2c810?q=80&w=2000&auto=format&fit=crop" class="d-block w-100 h-100 object-fit-cover" alt="Linh Kiện" style="filter: brightness(40%); object-position: center;">
            <div class="carousel-caption d-flex flex-column justify-content-center h-100 text-white" style="bottom: 0;">
                <h1 class="display-3 fw-bolder mb-3 text-uppercase text-light" style="letter-spacing: 2px; text-shadow: 2px 2px 10px rgba(0,0,0,0.7);">Flash Sale Linh Kiện</h1>
                <p class="fs-4 mb-4 fw-light" style="text-shadow: 1px 1px 5px rgba(0,0,0,0.8);">Giảm thêm 10% khi nhập Code: <span class="fw-bold text-warning">TECHGEAR2026</span></p>
                <div>
                    <a href="#" class="btn btn-warning btn-lg px-5 fw-bold text-dark rounded-pill shadow">Lấy Voucher Nóng <i class="bi bi-ticket-perforated ms-2"></i></a>
                </div>
            </div>
        </div>
    </div>
    
    <!-- Controls (Made slightly more elegant) -->
    <button class="carousel-control-prev" type="button" data-bs-target="#heroCarousel" data-bs-slide="prev" style="width: 5%;">
        <span class="carousel-control-prev-icon p-3 bg-dark bg-opacity-50 rounded-circle" aria-hidden="true"></span>
        <span class="visually-hidden">Previous</span>
    </button>
    <button class="carousel-control-next" type="button" data-bs-target="#heroCarousel" data-bs-slide="next" style="width: 5%;">
        <span class="carousel-control-next-icon p-3 bg-dark bg-opacity-50 rounded-circle" aria-hidden="true"></span>
        <span class="visually-hidden">Next</span>
    </button>
</div>

<!-- Section: Sản phẩm nổi bật -->
<div class="container mb-5">
    <div class="d-flex justify-content-between align-items-center mb-4 border-bottom pb-2">
        <h3 class="fw-bold text-danger"><i class="bi bi-fire"></i> SẢN PHẨM NỔI BẬT</h3>
        <a href="#" class="text-decoration-none text-primary fw-bold">Xem tất cả ></a>
    </div>

    @if (!Model.FeaturedProducts.Any())
    {
        <div class="alert alert-warning text-center">Đang cập nhật sản phẩm nổi bật...</div>
    }
    else
    {
        <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-4 g-4">
            @foreach (var p in Model.FeaturedProducts)
            {
                <div class="col">
                    @await Html.PartialAsync("_ProductCard", p)
                </div>
            }
        </div>
    }
</div>

<!-- Category Banners -->
<div class="row mb-5 g-3">
    <div class="col-md-6">
        <div class="card bg-dark text-white border-0 overflow-hidden rounded-3 hover-zoom">
            <img src="https://images.unsplash.com/photo-1587202372634-32705e3bf49c?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80" class="card-img opacity-50 object-fit-cover" alt="Gear" style="height: 200px;">
            <div class="card-img-overlay d-flex flex-column justify-content-center text-center">
                <h3 class="card-title fw-bold">THẾ GIỚI KEYBOARD</h3>
                <p class="card-text">Nâng tầm trải nghiệm gõ</p>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card bg-dark text-white border-0 overflow-hidden rounded-3 hover-zoom">
            <img src="https://images.unsplash.com/photo-1593640408182-31c70c8268f5?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80" class="card-img opacity-50 object-fit-cover" alt="Mouse" style="height: 200px;">
            <div class="card-img-overlay d-flex flex-column justify-content-center text-center">
                <h3 class="card-title fw-bold">CHUỘT GAMING</h3>
                <p class="card-text">Độ trễ thấp, chiến chuẩn xác</p>
            </div>
        </div>
    </div>
</div>

<!-- Section: Sản phẩm mới về -->
<div class="container mb-5">
    <div class="d-flex justify-content-between align-items-center mb-4 border-bottom pb-2">
        <h3 class="fw-bold text-success"><i class="bi bi-box-seam"></i> SẢN PHẨM MỚI VỀ</h3>
        <a href="#" class="text-decoration-none text-success fw-bold">Xem tất cả ></a>
    </div>

    @if (!Model.NewProducts.Any())
    {
        <div class="alert alert-secondary text-center">Đang cập nhật sản phẩm mới...</div>
    }
    else
    {
        <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-4 g-4">
            @foreach (var p in Model.NewProducts)
            {
                <div class="col">
                    @await Html.PartialAsync("_ProductCard", p)
                </div>
            }
        </div>
    }
</div>
