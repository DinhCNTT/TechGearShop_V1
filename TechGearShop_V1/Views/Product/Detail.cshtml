@section Scripts {
    <script>
        // Data Array chứa danh sách các URL ảnh
        const galleryImages = [
            '@Html.Raw(Model.ImagePath)'
            @foreach(var img in Model.ProductImages.OrderBy(p => p.SortOrder)) {
                <text>,'@Html.Raw(img.ImageUrl)'</text>
            }
        ];
        
        let currentImageIndex = 0;

        function changeImageByIndex(index) {
            if (index < 0 || index >= galleryImages.length) return;
            currentImageIndex = index;
            
            // Cập nhật ảnh chính
            const mainImg = document.getElementById('mainProductImage');
            mainImg.style.opacity = '0.5';
            setTimeout(() => {
                mainImg.src = galleryImages[currentImageIndex];
                mainImg.style.opacity = '1';
            }, 150);
            
            // Cập nhật trạng thái Thumbnail
            const thumbs = document.querySelectorAll('.gallery-thumb img');
            thumbs.forEach((img, idx) => {
                if (idx === currentImageIndex) {
                    img.classList.add('border-danger', 'border-2', 'shadow-sm');
                    img.style.opacity = '1';
                } else {
                    img.classList.remove('border-danger', 'border-2', 'shadow-sm');
                    img.style.opacity = '0.6';
                }
            });

            // Nếu Lightbox đang mở, cập nhật luôn ảnh trong Lightbox
            const lightboxImg = document.getElementById('lightboxImage');
            if (lightboxImg) {
                lightboxImg.style.opacity = '0.5';
                setTimeout(() => {
                    lightboxImg.src = galleryImages[currentImageIndex];
                    lightboxImg.style.opacity = '1';
                }, 150);
            }
        }

        function openLightbox() {
            // Hiển thị Modal Bootstrap
            var myModal = new bootstrap.Modal(document.getElementById('imageLightboxModal'), {
                keyboard: true
            });
            // Set ảnh hiện tại trước khi show
            document.getElementById('lightboxImage').src = galleryImages[currentImageIndex];
            myModal.show();
        }

        function nextImage() {
            let nextIdx = currentImageIndex + 1;
            if (nextIdx >= galleryImages.length) nextIdx = 0; // Quay vòng
            changeImageByIndex(nextIdx);
        }

        function prevImage() {
            let prevIdx = currentImageIndex - 1;
            if (prevIdx < 0) prevIdx = galleryImages.length - 1; // Móc ngược
            changeImageByIndex(prevIdx);
        }

        // JS cho nút thả tim (Yêu thích)
        function toggleFavorite(btn) {
            const icon = btn.querySelector('i');
            if (icon.classList.contains('bi-heart')) {
                // Tim đỏ
                icon.classList.remove('bi-heart', 'text-secondary');
                icon.classList.add('bi-heart-fill', 'text-danger');
                icon.style.transform = 'scale(1.3)';
                setTimeout(() => icon.style.transform = 'scale(1)', 200);
            } else {
                // Hủy tim
                icon.classList.remove('bi-heart-fill', 'text-danger');
                icon.classList.add('bi-heart', 'text-secondary');
                icon.style.transform = 'scale(0.8)';
                setTimeout(() => icon.style.transform = 'scale(1)', 200);
            }
        }

        function syncQuantity() {
            var qty = document.getElementById('productQuantity').value;
            // Update hidden inputs for both forms
            var hdAdd = document.getElementById('hiddenQtyAdd');
            var hdBuy = document.getElementById('hiddenQtyBuy');
            if (hdAdd) hdAdd.value = qty;
            if (hdBuy) hdBuy.value = qty;
        }

        function increaseQuantity() {
            var input = document.getElementById('productQuantity');
            var max = parseInt(input.getAttribute('max'));
            var current = parseInt(input.value);
            
            if (current >= max) {
                Swal.fire({
                    icon: 'warning',
                    title: 'Giới hạn tồn kho!',
                    text: 'Sản phẩm này trong kho chỉ còn tối đa ' + max + ' cái.',
                    confirmButtonColor: '#dc3545',
                    confirmButtonText: 'Đã hiểu'
                });
            } else {
                input.stepUp();
                syncQuantity();
            }
        }

        function decreaseQuantity() {
            var input = document.getElementById('productQuantity');
            input.stepDown();
            syncQuantity();
        }

        function openNotifyModal(id) {
            var myModal = new bootstrap.Modal(document.getElementById('notifyRestockModal'));
            myModal.show();
        }

        async function submitNotifyRestock(e) {
            e.preventDefault();
            const btn = document.getElementById('btnSubmitNotify');
            const originalText = btn.innerHTML;
            btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>Đang xử lý...';
            btn.disabled = true;

            const productId = document.getElementById('notifyProductId').value;
            const emailElem = document.getElementById('notifyEmail');
            const email = (emailElem && emailElem.type !== 'hidden') ? emailElem.value : '';

            try {
                const formData = new FormData();
                formData.append("productId", productId);
                formData.append("email", email);

                const response = await fetch('/Product/SubscribeStockNotification', {
                    method: 'POST',
                    body: formData
                });
                
                const data = await response.json();
                
                if (data.success) {
                    Swal.fire({
                        icon: 'success',
                        title: 'Đăng ký thành công!',
                        text: data.message,
                        confirmButtonColor: '#198754'
                    });
                    var myModalEl = document.getElementById('notifyRestockModal');
                    var modal = bootstrap.Modal.getInstance(myModalEl);
                    modal.hide();
                    if(emailElem && emailElem.type !== 'hidden') emailElem.value = '';
                } else {
                    Swal.fire({
                        icon: 'error',
                        title: 'Không thể đăng ký!',
                        text: data.message,
                        confirmButtonColor: '#dc3545'
                    });
                }
            } catch (err) {
                Swal.fire('Lỗi hệ thống', 'Không thể kết nối đến máy chủ. Vui lòng thử lại sau.', 'error');
            } finally {
                btn.innerHTML = originalText;
                btn.disabled = false;
            }
        }

        // ==========================================
        // SYSTEM REVIEW: BÌNH LUẬN & ĐÁNH GIÁ (AJAX)
        // ==========================================
        let currentReviewPage = 1;
        const productId = @Model.Id;

        // Xử lý chọn Sao trên form
        const stars = document.querySelectorAll('#star-selector i');
        const ratingInput = document.getElementById('reviewRating');
        const ratingError = document.getElementById('rating-error');
        
        stars.forEach(star => {
            star.addEventListener('mouseover', function() {
                const val = parseInt(this.getAttribute('data-val'));
                fillStars(val);
            });
            star.addEventListener('mouseout', function() {
                const val = parseInt(ratingInput.value);
                fillStars(val);
            });
            star.addEventListener('click', function() {
                const val = parseInt(this.getAttribute('data-val'));
                ratingInput.value = val;
                ratingError.classList.add('d-none');
                fillStars(val);
            });
        });

        function fillStars(val) {
            stars.forEach((s, idx) => {
                if(idx < val) {
                    s.classList.remove('bi-star');
                    s.classList.add('bi-star-fill');
                } else {
                    s.classList.remove('bi-star-fill');
                    s.classList.add('bi-star');
                }
            });
        }

        // Gửi Đánh giá
        async function submitReview(e) {
            e.preventDefault();
            const rating = parseInt(ratingInput.value);
            if(rating === 0) {
                ratingError.classList.remove('d-none');
                return;
            }

            const btn = document.getElementById('btnSubmitReview');
            const originalText = btn.innerHTML;
            btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>Đang xử lý...';
            btn.disabled = true;

            const content = document.getElementById('reviewContent').value;
            const formData = new FormData();
            formData.append("productId", productId);
            formData.append("rating", rating);
            formData.append("content", content);

            try {
                const response = await fetch('/api/Review/add', {
                    method: 'POST',
                    body: formData
                });
                
                const data = await response.json();
                if(data.success) {
                    Swal.fire('Thành công', data.message, 'success');
                    document.getElementById('frmReview').reset();
                    ratingInput.value = 0;
                    fillStars(0);
                    // Tải lại danh sách từ trang 1 để thấy review mới
                    document.getElementById('reviews-list-container').innerHTML = '';
                    currentReviewPage = 1;
                    loadReviews(1);
                } else {
                    Swal.fire('Thất bại', data.message, 'error');
                }
            } catch (err) {
                Swal.fire('Lỗi', 'Không thể kết nối đến máy chủ.', 'error');
            } finally {
                btn.innerHTML = originalText;
                btn.disabled = false;
            }
        }

        // Tải danh sách Đánh giá & Render Dashboard
        async function loadReviews(page) {
            const btnMore = document.getElementById('btnLoadMoreReviews');
            if(btnMore) {
                btnMore.innerHTML = '<span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>Đang tải...';
                btnMore.disabled = true;
            }

            try {
                const res = await fetch(`/api/Review/${productId}?page=${page}&pageSize=5`);
                const json = await res.json();

                if(json.success && json.data) {
                    const data = json.data;
                    currentReviewPage = data.currentPage;
                    
                    // Render Dashboard Stats (Lần đầu tiên page 1)
                    if(page === 1) {
                        renderDashboard(data);
                        if(data.reviews.length === 0) {
                            document.getElementById('reviews-list-container').innerHTML = '<div class="text-center text-muted py-4"><i class="bi bi-chat-square-dots fs-1 d-block mb-2"></i>Chưa có đánh giá nào cho sản phẩm này. Hãy là người đầu tiên!</div>';
                        } else {
                            document.getElementById('reviews-list-container').innerHTML = ''; // Clear loading
                        }
                    }

                    // Append reviews
                    const container = document.getElementById('reviews-list-container');
                    data.reviews.forEach(r => {
                        container.insertAdjacentHTML('beforeend', buildReviewHTML(r));
                    });

                    // Xử lý nút Load More
                    const paginationDiv = document.getElementById('review-pagination');
                    if(data.currentPage < data.totalPages) {
                        paginationDiv.classList.remove('d-none');
                        if(btnMore) {
                            btnMore.innerHTML = 'Xem thêm bình luận <i class="bi bi-chevron-down ms-1"></i>';
                            btnMore.disabled = false;
                        }
                    } else {
                        paginationDiv.classList.add('d-none');
                    }
                }
            } catch(e) {
                console.error("Lỗi tải bình luận:", e);
                if(page === 1) {
                    document.getElementById('reviews-list-container').innerHTML = '<div class="text-danger text-center">Không thể tải bình luận lúc này.</div>';
                }
            }
        }

        async function loadMyReview() {
            try {
                const res = await fetch(`/api/Review/my/${productId}`);
                const json = await res.json();
                if(json.success && json.data) {
                    // Đã có bình luận, fill form
                    const r = json.data;
                    document.getElementById('reviewRating').value = r.rating;
                    fillStars(r.rating);
                    document.getElementById('reviewContent').value = r.content;
                    
                    const btn = document.getElementById('btnSubmitReview');
                    if(btn) btn.innerText = "Cập nhật đánh giá";
                    
                    const title = document.getElementById('review-form-title');
                    if(title) title.innerHTML = 'Cập nhật đánh giá của bạn <i class="bi bi-pencil-square ms-2"></i>';
                }
            } catch(e) {
                console.error("Lỗi tải bình luận của tôi:", e);
            }
        }

        function renderDashboard(data) {
            document.getElementById('avg-rating-display').innerText = data.averageRating.toFixed(1);
            document.getElementById('total-reviews-display').innerText = data.totalReviews;
            
            // Render sao trung bình
            let starsHTML = '';
            const avg = data.averageRating;
            for(let i=1; i<=5; i++) {
                if(avg >= i) starsHTML += '<i class="bi bi-star-fill"></i>';
                else if(avg >= i - 0.5) starsHTML += '<i class="bi bi-star-half"></i>';
                else starsHTML += '<i class="bi bi-star"></i>';
            }
            document.getElementById('avg-stars-display').innerHTML = starsHTML;

            // Render Progress Bars
            let barsHTML = '';
            for(let i=5; i>=1; i--) {
                const count = data.ratingDistribution[i-1] || 0;
                const percent = data.totalReviews > 0 ? (count / data.totalReviews * 100) : 0;
                barsHTML += `
                <div class="d-flex align-items-center mb-2">
                    <div class="text-warning text-nowrap" style="width: 50px;">${i} <i class="bi bi-star-fill"></i></div>
                    <div class="progress flex-grow-1 mx-3" style="height: 8px;">
                        <div class="progress-bar bg-warning" role="progressbar" style="width: ${percent}%;" aria-valuenow="${percent}" aria-valuemin="0" aria-valuemax="100"></div>
                    </div>
                    <div class="text-muted small" style="width: 30px; text-align: right;">${count}</div>
                </div>`;
            }
            document.getElementById('rating-bars-container').innerHTML = barsHTML;
        }

        function buildReviewHTML(r) {
            // Encode content to prevent XSS (cơ bản)
            const safeContent = r.content.replace(/</g, "&lt;").replace(/>/g, "&gt;");
            
            let starsHTML = '';
            for(let i=1; i<=5; i++) {
                starsHTML += i <= r.rating ? '<i class="bi bi-star-fill"></i>' : '<i class="bi bi-star"></i>';
            }

            const date = new Date(r.createdAt).toLocaleDateString('vi-VN');
            const badge = r.isVerifiedPurchase 
                ? '<span class="badge bg-success-subtle text-success ms-2 border"><i class="bi bi-check-circle-fill me-1"></i>Đã mua hàng tại TechGear</span>' 
                : '';

            return `
            <div class="d-flex mb-4 pb-4 border-bottom">
                <div class="me-3">
                    <div class="bg-primary text-white rounded-circle d-flex align-items-center justify-content-center fw-bold fs-5 shadow-sm" style="width: 50px; height: 50px;">
                        ${r.username.charAt(0).toUpperCase()}
                    </div>
                </div>
                <div class="flex-grow-1">
                    <div class="d-flex justify-content-between align-items-start mb-1">
                        <div>
                            <span class="fw-bold fs-6 text-dark">${r.username}</span>
                            ${badge}
                        </div>
                        <small class="text-muted">${date}</small>
                    </div>
                    <div class="text-warning mb-2" style="font-size: 0.9rem;">
                        ${starsHTML}
                    </div>
                    <p class="mb-0 text-dark lh-base">${safeContent}</p>
                </div>
            </div>`;
        }

        // ==========================================
        // MINI Q&A — THREADED TREE + REALTIME SIGNALR
        // ==========================================
        const QA_PRODUCT_ID = @Model.Id;
        const QA_PAGE_SIZE = 8;
        let qaSkip = 0;
        let qaTotal = 0;
        let qaConnection = null;
        let qaSpamLocked = false;
        let qaReplyingToId = null;

        // ── Format thời gian (UTC-safe) ──
        function qaFormatTime(createdAt) {
            const rawTime = createdAt.endsWith('Z') ? createdAt : createdAt + 'Z';
            const d = new Date(rawTime);
            const diffMin = Math.floor((new Date() - d) / 60000);
            if (diffMin < 1) return 'Vừa xong';
            if (diffMin < 60) return diffMin + ' phút trước';
            if (diffMin < 1440) return Math.floor(diffMin / 60) + ' giờ trước';
            return d.toLocaleDateString('vi-VN');
        }

        // ── Build HTML cho 1 câu hỏi gốc (có container replies bên trong) ──
        function buildRootHTML(dto, listPrefix = 'inline') {
            const safe = dto.content.replace(/</g, '&lt;').replace(/>/g, '&gt;');
            const timeStr = qaFormatTime(dto.createdAt);

            @if (User.IsInRole("Admin"))
            {
                <text>
            const replyBtn = `<button type="button" class="btn btn-link p-0 mt-1" style="font-size: 0.72rem; color: #44b5fe; text-decoration: none;" onclick="setQaReply(${dto.id}, '${(dto.username ?? '').replace(/'/g,'\\u0027').replace(/`/g,'\\u0060')}', '${(dto.content ?? '').substring(0,40).replace(/'/g,'\\u0027').replace(/`/g,'\\u0060')}')"><i class="bi bi-reply me-1"></i>Trả lời</button>`;
                </text>
            }
            @if (!User.IsInRole("Admin"))
            {
                <text>
            const replyBtn = '';
                </text>
            }

            // Avatar & bubble style thay đổi tuỳ Admin hay User
            const avatarHTML = dto.isAdminReply
                ? `<div class="bg-danger bg-opacity-10 rounded-circle d-flex align-items-center justify-content-center flex-shrink-0" style="width: 30px; height: 30px;"><i class="bi bi-shield-check text-danger" style="font-size: 0.8rem;"></i></div>`
                : `<div class="bg-secondary bg-opacity-10 rounded-circle d-flex align-items-center justify-content-center flex-shrink-0" style="width: 30px; height: 30px;"><i class="bi bi-person-fill text-secondary" style="font-size: 0.8rem;"></i></div>`;

            const bubbleHTML = dto.isAdminReply
                ? `<div class="bg-primary bg-opacity-10 border border-primary border-opacity-10 rounded-3 px-3 py-2" style="font-size: 0.84rem; border-top-left-radius: 0 !important;">
                        <span class="fw-semibold text-danger" style="font-size: 0.75rem;">${dto.username}</span>
                        <span class="badge bg-danger rounded-pill ms-1" style="font-size: 0.58rem; vertical-align: middle;">Admin</span>
                        <span class="text-muted ms-1" style="font-size: 0.65rem;">• ${timeStr}</span>
                        <div class="mt-1 text-dark">${safe}</div>
                   </div>`
                : `<div class="bg-light border border-light-subtle rounded-3 px-3 py-2" style="font-size: 0.84rem; border-top-left-radius: 0 !important;">
                        <span class="fw-semibold text-primary" style="font-size: 0.75rem;">${dto.username}</span>
                        <span class="text-muted ms-1" style="font-size: 0.65rem;">• ${timeStr}</span>
                        <div class="mt-1 text-dark">${safe}</div>
                   </div>`;

            return `
            <div class="qa-thread" id="qa-thread-${dto.id}" data-qa-id="${dto.id}" style="animation: fadeInUp 0.3s ease-out forwards;">
                <div class="d-flex gap-2 align-items-start">
                    ${avatarHTML}
                    <div class="flex-fill">
                        ${bubbleHTML}
                        ${replyBtn}
                    </div>
                </div>
                <div class="qa-replies ms-4 mt-1" id="${listPrefix}-qa-replies-${dto.id}" style="border-left: 2px solid #e2e8f0; padding-left: 12px;"></div>
            </div>`;
        }

        // ── Build HTML cho 1 reply của Admin ──
        function buildReplyHTML(dto) {
            const safe = dto.content.replace(/</g, '&lt;').replace(/>/g, '&gt;');
            const timeStr = qaFormatTime(dto.createdAt);
            return `
            <div class="d-flex gap-2 align-items-start mt-2" style="animation: fadeInUp 0.25s ease-out forwards;">
                <div class="bg-danger bg-opacity-10 rounded-circle d-flex align-items-center justify-content-center flex-shrink-0" style="width: 26px; height: 26px;">
                    <i class="bi bi-shield-check text-danger" style="font-size: 0.7rem;"></i>
                </div>
                <div class="flex-fill">
                    <div class="bg-primary bg-opacity-10 border border-primary border-opacity-10 rounded-3 px-3 py-2" style="font-size: 0.84rem; border-top-left-radius: 0 !important;">
                        <span class="fw-semibold text-danger" style="font-size: 0.75rem;">${dto.username}</span>
                        <span class="badge bg-danger rounded-pill ms-1" style="font-size: 0.58rem; vertical-align: middle;">Admin</span>
                        <span class="text-muted ms-1" style="font-size: 0.65rem;">• ${timeStr}</span>
                        <div class="mt-1 text-dark">${safe}</div>
                    </div>
                </div>
            </div>`;
        }

        // ── Render toàn bộ cây từ flat list ──
        function renderQaTree(messages, containerId, listPrefix, prepend = false) {
            const listEl = document.getElementById(containerId);
            if (!listEl) return;

            // Tách: câu hỏi gốc và replies
            const roots = messages.filter(m => !m.parentId);
            const replies = messages.filter(m => m.parentId);

            // Build map parentId → [replies]
            const replyMap = {};
            replies.forEach(r => {
                if (!replyMap[r.parentId]) replyMap[r.parentId] = [];
                replyMap[r.parentId].push(r);
            });

            roots.forEach(root => {
                const rootHTML = buildRootHTML(root, listPrefix);
                if (prepend) {
                    listEl.insertAdjacentHTML('afterbegin', rootHTML);
                } else {
                    listEl.insertAdjacentHTML('beforeend', rootHTML);
                }
                // Gắn replies vào đúng container
                const container = document.getElementById(`${listPrefix}-qa-replies-${root.id}`);
                if (container && replyMap[root.id]) {
                    replyMap[root.id].forEach(r => {
                        container.insertAdjacentHTML('beforeend', buildReplyHTML(r));
                    });
                    container.style.display = replyMap[root.id].length ? 'block' : 'none';
                } else if (container) {
                    container.style.display = 'none';
                }
            });

            // Replies mà câu hỏi gốc đã có sẵn trong DOM (realtime edge case)
            replies.forEach(r => {
                if (!roots.find(root => root.id === r.parentId)) {
                    const container = document.getElementById(`${listPrefix}-qa-replies-${r.parentId}`);
                    if (container) {
                        container.insertAdjacentHTML('beforeend', buildReplyHTML(r));
                        container.style.display = 'block';
                    }
                }
            });
        }

        // ── Reply state ──
        function setQaReply(id, username, contentPreview) {
            qaReplyingToId = id;
            // Cập nhật Strip ở ngoài
            const strip = document.getElementById('qa-reply-strip');
            const stripText = document.getElementById('qa-reply-strip-text');
            if (strip && stripText) {
                stripText.textContent = `${username}: ${contentPreview}${contentPreview.length >= 40 ? '...' : ''}`;
                strip.style.display = 'flex';
            }
            // Cập nhật Strip trong Modal
            const modalStrip = document.getElementById('qa-modal-reply-strip');
            const modalStripText = document.getElementById('qa-modal-reply-strip-text');
            if (modalStrip && modalStripText) {
                modalStripText.textContent = `${username}: ${contentPreview}${contentPreview.length >= 40 ? '...' : ''}`;
                modalStrip.style.display = 'flex';
            }
            
            // Focus vào input đang hiện
            const modalEl = document.getElementById('qaFullModal');
            if (modalEl && modalEl.classList.contains('show')) {
                document.getElementById('mini-qa-modal-input').focus();
            } else {
                document.getElementById('mini-qa-input').focus();
            }

            // Highlight câu hỏi đang chọn
            document.querySelectorAll('.qa-thread').forEach(el => el.style.opacity = '0.5');
            document.querySelectorAll(`[data-qa-id="${id}"]`).forEach(el => el.style.opacity = '1');
        }

        function cancelQaReply() {
            qaReplyingToId = null;
            const strip = document.getElementById('qa-reply-strip');
            if (strip) strip.style.display = 'none';
            const modalStrip = document.getElementById('qa-modal-reply-strip');
            if (modalStrip) modalStrip.style.display = 'none';
            document.querySelectorAll('.qa-thread').forEach(el => el.style.opacity = '1');
        }

        // ── Deep Link: Cuộn trang + cuộn container + highlight câu hỏi từ Thông báo Admin ──
        function scrollToHighlightQa(questionId) {
            const listEl  = document.getElementById('mini-qa-list');
            const blockEl = document.getElementById('qa-section-block');
            if (!listEl || !blockEl) return;

            const target = document.getElementById(`qa-thread-${questionId}`);
            if (!target) {
                console.warn('[DeepLink] qa-thread-' + questionId + ' not found in DOM');
                return;
            }

            // Bước 1: Cuộn trang xuống khu vực QA block mướt mà
            blockEl.scrollIntoView({ behavior: 'smooth', block: 'center' });

            // Bước 2: Sau khi trang đã scroll (700ms), cuộn trong container đến đúng item
            setTimeout(() => {
                const listRect   = listEl.getBoundingClientRect();
                const targetRect = target.getBoundingClientRect();
                const scrollDelta = targetRect.top - listRect.top - 8;
                listEl.scrollBy({ top: scrollDelta, behavior: 'smooth' });

                // Bước 3: Sau khi container scroll xong (300ms), bật glow highlight 2s
                setTimeout(() => {
                    target.classList.add('qa-deep-link-highlight');
                    setTimeout(() => target.classList.remove('qa-deep-link-highlight'), 2200);
                }, 300);
            }, 700);
        }

        // ── Load lịch sử (Khung nhỏ bên ngoài) ──
        async function loadQaHistory() {
            try {
                const res = await fetch(`/api/qa/${QA_PRODUCT_ID}?take=${QA_PAGE_SIZE}&skip=0`);
                const json = await res.json();
                const loading = document.getElementById('qa-loading');
                if (loading) loading.remove();

                qaTotal = json.total || 0;
                qaSkip = QA_PAGE_SIZE;

                if (json.data && json.data.length > 0) {
                    json.data.reverse(); // Cũ → mới
                    renderQaTree(json.data, 'mini-qa-list', 'inline');

                    // ── Deep Link: scroll + highlight câu hỏi từ thông báo Admin ──
                    const urlParams = new URLSearchParams(window.location.search);
                    const targetQaId = urlParams.get('qa');
                    if (targetQaId) {
                        // Chờ 400ms cho animation render xong rồi mới scroll
                        setTimeout(() => scrollToHighlightQa(parseInt(targetQaId, 10)), 450);
                    } else {
                        scrollQaToBottom('mini-qa-list');
                    }
                } else {
                    document.getElementById('mini-qa-list').innerHTML =
                        '<div class="text-center text-muted py-4"><i class="bi bi-chat-text fs-4 d-block mb-2 opacity-50"></i><small>Chưa có câu hỏi nào. Hãy là người đầu tiên!</small></div>';
                }
                
                const wrap = document.getElementById('qa-load-more-wrap');
                if (qaTotal > QA_PAGE_SIZE && wrap) {
                    wrap.style.display = 'block';
                } else if (wrap) { 
                    wrap.style.display = 'none'; 
                }
            } catch (err) {
                console.error('Load Q&A history failed:', err);
            }
        }

        // ── Mở Modal & Tải toàn bộ lịch sử ──
        async function openQaModal() {
            const modalEl = document.getElementById('qaFullModal');
            const modal = new bootstrap.Modal(modalEl);
            modal.show();

            const listEl = document.getElementById('qa-modal-list');
            listEl.innerHTML = `
                <div id="qa-modal-loading" class="d-flex align-items-center justify-content-center py-5">
                    <div class="spinner-border spinner-border-sm text-primary me-2" role="status"></div>
                    <small class="text-muted">Đang tải toàn bộ dữ liệu...</small>
                </div>`;

            try {
                // Lấy lượng lớn để cover hết (có thể làm infinite scroll trong modal sau nếu quá nhiều)
                const res = await fetch(`/api/qa/${QA_PRODUCT_ID}?take=500&skip=0`);
                const json = await res.json();
                listEl.innerHTML = ''; // Clear loading

                if (json.data && json.data.length > 0) {
                    json.data.reverse();
                    renderQaTree(json.data, 'qa-modal-list', 'modal');
                    scrollQaToBottom('qa-modal-list');
                } else {
                    listEl.innerHTML = '<div class="text-center text-muted py-4"><i class="bi bi-chat-text fs-4 d-block mb-2 opacity-50"></i><small>Chưa có câu hỏi nào.</small></div>';
                }
            } catch (err) { 
                console.error(err); 
                listEl.innerHTML = '<div class="text-center text-danger py-4">Có lỗi xảy ra khi tải dữ liệu!</div>';
            }
        }

        function scrollQaToBottom(containerId) {
            const el = document.getElementById(containerId);
            if (el) {
                if (containerId === 'qa-modal-list') {
                    const parent = el.closest('.modal-body');
                    if (parent) parent.scrollTop = parent.scrollHeight;
                } else {
                    el.scrollTop = el.scrollHeight;
                }
            }
        }

        function enforceInlineQaLimit() {
            const listEl = document.getElementById('mini-qa-list');
            if (!listEl) return;
            
            let threads = Array.from(listEl.querySelectorAll('.qa-thread'));
            let totalCount = 0;
            
            // Tính tổng số tin nhắn (câu hỏi + trả lời) đang hiển thị
            threads.forEach(t => {
                totalCount += 1; // 1 cho câu hỏi gốc
                const repliesContainer = t.querySelector('.qa-replies');
                if (repliesContainer) {
                    totalCount += repliesContainer.children.length; // + số lượng reply
                }
            });

            // Nếu vượt quá 8, xóa dần thread cũ nhất (trên cùng)
            while (totalCount > QA_PAGE_SIZE && threads.length > 0) {
                const oldestThread = threads[0];
                const repliesContainer = oldestThread.querySelector('.qa-replies');
                const removedCount = 1 + (repliesContainer ? repliesContainer.children.length : 0);
                
                oldestThread.remove();
                threads.shift(); // Cập nhật mảng
                totalCount -= removedCount;
                
                const wrap = document.getElementById('qa-load-more-wrap');
                if (wrap) wrap.style.display = 'block';
            }
        }

        // ── Kết nối SignalR ──
        async function initQaHub() {
            qaConnection = new signalR.HubConnectionBuilder()
                .withUrl("/qaHub")
                .withAutomaticReconnect([0, 2000, 5000, 10000, 30000])
                .build();

            qaConnection.on("ReceiveQuestion", (dto) => {
                // Update danh sách ngoài (inline)
                const inlineListEl = document.getElementById('mini-qa-list');
                const emptyMsg = inlineListEl.querySelector('.text-center.text-muted');
                if (emptyMsg) emptyMsg.remove();

                if (!dto.parentId) {
                    inlineListEl.insertAdjacentHTML('beforeend', buildRootHTML(dto, 'inline'));
                    const c = document.getElementById(`inline-qa-replies-${dto.id}`);
                    if (c) c.style.display = 'none';
                } else {
                    const container = document.getElementById(`inline-qa-replies-${dto.parentId}`);
                    if (container) {
                        container.insertAdjacentHTML('beforeend', buildReplyHTML(dto));
                        container.style.display = 'block';
                    }
                }
                
                // Kiểm tra và ép giới hạn 8 tin nhắn TỔNG CỘNG
                enforceInlineQaLimit();
                
                scrollQaToBottom('mini-qa-list');

                // Update danh sách trong Modal (nếu đang load xong)
                const modalListEl = document.getElementById('qa-modal-list');
                if (modalListEl && !modalListEl.querySelector('#qa-modal-loading')) {
                    const emptyModalMsg = modalListEl.querySelector('.text-center.text-muted');
                    if (emptyModalMsg) emptyModalMsg.remove();

                    if (!dto.parentId) {
                        modalListEl.insertAdjacentHTML('beforeend', buildRootHTML(dto, 'modal'));
                        const c = document.getElementById(`modal-qa-replies-${dto.id}`);
                        if (c) c.style.display = 'none';
                    } else {
                        const container = document.getElementById(`modal-qa-replies-${dto.parentId}`);
                        if (container) {
                            container.insertAdjacentHTML('beforeend', buildReplyHTML(dto));
                            container.style.display = 'block';
                        }
                    }
                    scrollQaToBottom('qa-modal-list');
                }

                qaTotal++;
                cancelQaReply();
            });

            qaConnection.on("QaError", (msg) => showQaToast(msg, 'warning'));
            qaConnection.on("QaSuccess", (msg) => showQaToast(msg, 'success'));

            const statusEl = document.getElementById('qa-connection-status');
            qaConnection.onreconnecting(() => {
                if (statusEl) {
                    statusEl.style.display = 'inline-block';
                    statusEl.className = 'badge bg-warning bg-opacity-10 text-warning';
                    statusEl.innerHTML = '<i class="bi bi-arrow-repeat me-1" style="font-size: 0.4rem;"></i>Đang kết nối lại...';
                }
            });
            qaConnection.onreconnected(() => {
                if (statusEl) {
                    statusEl.className = 'badge bg-success bg-opacity-10 text-success';
                    statusEl.innerHTML = '<i class="bi bi-circle-fill me-1" style="font-size: 0.4rem;"></i>Trực tuyến';
                    // Bỏ ẩn đi để luôn hiển thị trạng thái Trực tuyến
                }
                qaConnection.invoke("JoinProductRoom", QA_PRODUCT_ID.toString()).catch(() => {});
            });
            qaConnection.onclose(() => {
                if (statusEl) {
                    statusEl.style.display = 'inline-block';
                    statusEl.className = 'badge bg-danger bg-opacity-10 text-danger';
                    statusEl.innerHTML = '<i class="bi bi-exclamation-circle me-1" style="font-size: 0.4rem;"></i>Mất kết nối';
                }
            });

            try {
                await qaConnection.start();
                await qaConnection.invoke("JoinProductRoom", QA_PRODUCT_ID.toString());
                if (statusEl) { statusEl.style.display = 'inline-block'; }
            } catch (err) { console.error("QaHub connection failed:", err); }
        }

        // ── Gửi câu hỏi / trả lời ──
        function handleMiniQaSubmit(e, source = 'inline') {
            e.preventDefault();
            const inputId = source === 'modal' ? 'mini-qa-modal-input' : 'mini-qa-input';
            const input = document.getElementById(inputId);
            const content = input.value.trim();
            if (!content) return;

            @if (User.Identity == null || !User.Identity.IsAuthenticated)
            {
                <text>
            showQaToast('Vui lòng đăng nhập để đặt câu hỏi.', 'warning');
            return;
                </text>
            }

            var isAdmin = @(User.IsInRole("Admin") ? "true" : "false");
            if (!isAdmin && qaSpamLocked) { showQaToast('Vui lòng chờ 30 giây để gửi câu hỏi tiếp theo!', 'warning'); return; }
            if (!qaConnection || qaConnection.state !== signalR.HubConnectionState.Connected) {
                showQaToast('Đang kết nối lại, vui lòng thử lại sau.', 'warning'); return;
            }

            qaSpamLocked = true;
            const replyId = qaReplyingToId;
            cancelQaReply();
            qaConnection.invoke("SendQuestion", QA_PRODUCT_ID, content, replyId).catch(err => {
                showQaToast('Gửi thất bại, vui lòng thử lại.', 'error');
                console.error(err);
            });
            input.value = '';
            
            // Xóa cả input bên kia nếu có
            const otherInputId = source === 'modal' ? 'mini-qa-input' : 'mini-qa-modal-input';
            const otherInput = document.getElementById(otherInputId);
            if(otherInput) otherInput.value = '';

            setTimeout(() => { qaSpamLocked = false; }, 30000);
        }

        // ── Toast ──
        function showQaToast(msg, type) {
            if (typeof Swal !== 'undefined') {
                Swal.fire({
                    toast: true, position: 'bottom-end',
                    icon: type === 'success' ? 'success' : type === 'error' ? 'error' : 'warning',
                    title: msg, showConfirmButton: false, timer: 3000, timerProgressBar: true
                });
            }
        }

        // Tải bình luận ngay khi trang load
        document.addEventListener("DOMContentLoaded", () => {
            loadReviews(1);
            loadQaHistory();
            initQaHub();
            
            @if (User.Identity != null && User.Identity.IsAuthenticated)
            {
                <text>loadMyReview();</text>
            }
        });

    </script>
}
