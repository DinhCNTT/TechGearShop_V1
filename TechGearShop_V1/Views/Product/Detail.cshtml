@model TechGearShop_V1.Models.Entities.Product
@{
    ViewData["Title"] = Model.Name;
    Layout = "~/Views/Shared/_Layout.cshtml";
    var relatedProducts = ViewBag.RelatedProducts as List<TechGearShop_V1.Models.Entities.Product> ?? new List<TechGearShop_V1.Models.Entities.Product>();
}

<style>
    @@keyframes fadeInUp {
        from { opacity: 0; transform: translateY(10px); }
        to   { opacity: 1; transform: translateY(0); }
    }

    /* Deep-link highlight: glow xanh nhấp nháy khi Admin click từ Thông báo */
    @@keyframes qaDeepLinkGlow {
        0%   { box-shadow: 0 0 0 0 rgba(59,130,246,0);    background: transparent; }
        20%  { box-shadow: 0 0 0 6px rgba(59,130,246,0.2); background: rgba(59,130,246,0.08); }
        50%  { box-shadow: 0 0 0 4px rgba(59,130,246,0.15); background: rgba(59,130,246,0.05); }
        80%  { box-shadow: 0 0 0 6px rgba(59,130,246,0.2); background: rgba(59,130,246,0.08); }
        100% { box-shadow: 0 0 0 0 rgba(59,130,246,0);    background: transparent; }
    }
    .qa-deep-link-highlight {
        animation: qaDeepLinkGlow 2.2s ease-in-out !important;
        border-radius: 10px;
        transition: background 0.3s;
    }
</style>

<div class="bg-white rounded-4 shadow-sm p-4 p-md-5 mb-5 mt-3">
    <!-- Breadcrumb -->
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb mb-0">
            <li class="breadcrumb-item"><a href="/" class="text-decoration-none"><i class="bi bi-house-door"></i> Trang chủ</a></li>
            <li class="breadcrumb-item"><a href="/Product" class="text-decoration-none">Sản phẩm</a></li>
            <li class="breadcrumb-item"><a href="/Product?categoryId=@Model.CategoryId" class="text-decoration-none">@Model.Category?.Name</a></li>
            <li class="breadcrumb-item active" aria-current="page">@Model.Name</li>
        </ol>
    </nav>

    <div class="row gx-5">
        <!-- Ảnh Sản Phẩm -->
        <div class="col-md-6 mb-4 mb-md-0 position-relative text-center d-flex flex-column">


            <div class="main-image-container position-relative d-flex align-items-center justify-content-center bg-white rounded-4 border shadow-sm mb-3" style="height: 450px; overflow: hidden;">
                <div class="position-absolute top-0 end-0 m-3 z-3 d-flex gap-2">
                    <!-- Nút Share (Dropdown) -->
                    <div class="dropdown">
                        <button class="btn btn-light rounded-circle shadow-sm d-flex align-items-center justify-content-center" style="width: 45px; height: 45px; transition: all 0.2s;" type="button" data-bs-toggle="dropdown" aria-expanded="false" aria-label="Share">
                            <i class="bi bi-share fs-5 text-secondary"></i>
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end shadow border-0 rounded-4 p-2 text-center" style="min-width: 60px;">
                            <li class="mb-2"><a class="dropdown-item p-1 rounded-circle d-flex align-items-center justify-content-center mx-auto" href="javascript:void(0)" style="width:35px; height:35px;"><i class="bi bi-facebook fs-4 text-primary"></i></a></li>
                            <li class="mb-2"><a class="dropdown-item p-1 rounded-circle d-flex align-items-center justify-content-center mx-auto" href="javascript:void(0)" style="width:35px; height:35px;"><i class="bi bi-messenger fs-4 text-primary"></i></a></li>
                            <li><a class="dropdown-item p-1 rounded-circle d-flex align-items-center justify-content-center mx-auto" href="javascript:void(0)" style="width:35px; height:35px;"><i class="bi bi-link-45deg fs-4 text-secondary"></i></a></li>
                        </ul>
                    </div>

                    <!-- Nút Yêu Thích (Trái tim) -->
                    <button class="btn btn-light rounded-circle shadow-sm d-flex align-items-center justify-content-center" style="width: 45px; height: 45px; transition: all 0.2s;" onclick="toggleFavorite(this)" aria-label="Favorite">
                        <i class="bi bi-heart fs-5 text-secondary" style="transition: transform 0.2s cubic-bezier(0.175, 0.885, 0.32, 1.275);"></i>
                    </button>
                </div>

                @if (Model.ProductImages != null && Model.ProductImages.Any())
                {
                    <!-- Mũi tên Trái -->
                    <button class="btn btn-light position-absolute start-0 top-50 translate-middle-y ms-2 rounded-circle shadow-sm z-3" style="width: 40px; height: 40px;" onclick="prevImage()" aria-label="Previous image">
                        <i class="bi bi-chevron-left"></i>
                    </button>
                }

                <img id="mainProductImage" src="@(string.IsNullOrEmpty(Model.ImagePath) ? "/images/placeholder.jpg" : Model.ImagePath)" 
                     class="img-fluid object-fit-contain p-3 w-100 h-100" 
                     style="cursor: zoom-in;" onclick="openLightbox()"
                     alt="@Model.Name" />

                @if (Model.ProductImages != null && Model.ProductImages.Any())
                {
                    <!-- Mũi tên Phải -->
                    <button class="btn btn-light position-absolute end-0 top-50 translate-middle-y me-2 rounded-circle shadow-sm z-3" style="width: 40px; height: 40px;" onclick="nextImage()" aria-label="Next image">
                        <i class="bi bi-chevron-right"></i>
                    </button>
                }
            </div>

            @if (Model.ProductImages != null && Model.ProductImages.Any())
            {
                <div class="d-flex flex-wrap gap-2 justify-content-center justify-content-lg-start mt-3" id="galleryThumbs">
                    <!-- Ảnh đại diện -->
                    <div class="gallery-thumb" onclick="changeImageByIndex(0)" style="width: 80px; height: 80px; cursor: pointer; transition: all 0.2s;">
                        <img src="@Model.ImagePath" class="img-fluid rounded border w-100 h-100 object-fit-cover border-danger border-2 shadow-sm" alt="Thumbnail" />
                    </div>
                    <!-- Các ảnh phụ -->
                    @{ int imgIndex = 1; }
                    @foreach (var img in Model.ProductImages.OrderBy(p => p.SortOrder))
                    {
                        var currentIndex = imgIndex++;
                        <div class="gallery-thumb" onclick="changeImageByIndex(@currentIndex)" style="width: 80px; height: 80px; cursor: pointer; transition: all 0.2s;">
                            <img src="@img.ImageUrl" class="img-fluid rounded border w-100 h-100 object-fit-cover" style="opacity: 0.6;" alt="Gallery" />
                        </div>
                    }
                </div>
            }

            <!-- Banner Đặc Quyền (Modern Apple Style) -->
            <div class="mt-auto pt-4">
                <div class="p-4 rounded-4 shadow-sm position-relative overflow-hidden text-start" style="background: #ffffff; border: 1px solid rgba(0,0,0,0.08); transition: all 0.3s;" onmouseover="this.style.boxShadow='0 10px 30px rgba(0,0,0,0.08)'" onmouseout="this.style.boxShadow='0 .125rem .25rem rgba(0,0,0,.075)'">
                
                <!-- Hiệu ứng dải màu tinh tế trên cùng -->
                <div class="position-absolute top-0 start-0 w-100" style="height: 4px; background: linear-gradient(90deg, #00f2fe 0%, #4facfe 100%);"></div>

                <div class="d-flex align-items-center justify-content-between mb-4 pb-3 border-bottom border-light">
                    <div class="d-flex align-items-center">
                        <div class="d-flex align-items-center justify-content-center bg-primary bg-opacity-10 text-primary rounded-circle me-3 shadow-sm" style="width: 40px; height: 40px;">
                            <i class="bi bi-gem fs-5"></i>
                        </div>
                        <h6 class="fw-bold mb-0 text-dark" style="letter-spacing: 0.5px; font-size: 1.05rem;">Đặc quyền tại TechGear</h6>
                    </div>
                    <span class="badge rounded-pill bg-primary bg-opacity-10 text-primary border border-primary border-opacity-25 px-3 py-2 fw-medium shadow-sm">Độc quyền</span>
                </div>
                
                <ul class="list-unstyled mb-0 d-flex flex-column gap-3" style="font-size: 0.95rem; color: #495057;">
                    <li class="d-flex align-items-center" style="transition: transform 0.2s;" onmouseover="this.style.transform='translateX(6px)'" onmouseout="this.style.transform='translateX(0)'">
                        <div class="d-flex align-items-center justify-content-center bg-danger bg-opacity-10 text-danger rounded-circle me-3 flex-shrink-0" style="width: 35px; height: 35px;">
                            <i class="bi bi-arrow-repeat fs-5"></i>
                        </div>
                        <span>Bảo hành 1 đổi 1 trong <b>30 ngày</b> nếu có lỗi NSX.</span>
                    </li>
                    <li class="d-flex align-items-center" style="transition: transform 0.2s;" onmouseover="this.style.transform='translateX(6px)'" onmouseout="this.style.transform='translateX(0)'">
                        <div class="d-flex align-items-center justify-content-center bg-info bg-opacity-10 text-info rounded-circle me-3 flex-shrink-0" style="width: 35px; height: 35px;">
                            <i class="bi bi-tools fs-5"></i>
                        </div>
                        <span>Tặng gói bảo dưỡng, vệ sinh thiết bị <b>trọn đời</b>.</span>
                    </li>
                    <li class="d-flex align-items-center" style="transition: transform 0.2s;" onmouseover="this.style.transform='translateX(6px)'" onmouseout="this.style.transform='translateX(0)'">
                        <div class="d-flex align-items-center justify-content-center bg-warning bg-opacity-10 text-warning rounded-circle me-3 flex-shrink-0" style="width: 35px; height: 35px;">
                            <i class="bi bi-currency-dollar fs-5"></i>
                        </div>
                        <span>Trợ giá lên đến <b>30%</b> khi tham gia thu cũ đổi mới.</span>
                    </li>
                    <li class="d-flex align-items-center" style="transition: transform 0.2s;" onmouseover="this.style.transform='translateX(6px)'" onmouseout="this.style.transform='translateX(0)'">
                        <div class="d-flex align-items-center justify-content-center bg-success bg-opacity-10 text-success rounded-circle me-3 flex-shrink-0" style="width: 35px; height: 35px;">
                            <i class="bi bi-truck fs-5"></i>
                        </div>
                        <span>Miễn phí giao hàng toàn quốc cho đơn từ <b>1 triệu</b>.</span>
                    </li>
                </ul>
            </div>
            </div> <!-- Close mt-auto wrapper -->

        </div>

        <!-- Thông Tin Chi Tiết -->
        <div class="col-md-6 d-flex flex-column">
            <div>
                <span class="badge bg-light text-dark border px-3 py-2 mb-3 fw-bold">@Model.Brand</span>
            
            <h2 class="fw-bold mb-3">@Model.Name</h2>
            
            <!-- Trạng thái Kho & Thông số thực tế -->
            <div class="d-flex align-items-center gap-4 mb-3 text-muted small pb-3 border-bottom">
                <div>
                    @if(Model.Stock > 0) {
                        <span class="badge bg-success-subtle text-success py-1 px-2 border"><i class="bi bi-check2-circle"></i> Còn @Model.Stock máy</span>
                    } else {
                        <span class="badge bg-danger-subtle text-danger py-1 px-2 border"><i class="bi bi-x-circle"></i> Tạm hết hàng</span>
                    }
                </div>
                @if(Model.ReviewCount > 0) {
                    <div class="text-warning fw-bold" style="cursor: pointer;" onclick="document.getElementById('review-section').scrollIntoView({behavior: 'smooth'})">
                        <i class="bi bi-star-fill"></i> @Model.AverageRating.ToString("0.0") 
                        <span class="text-muted fw-normal ms-1 text-decoration-underline">(@Model.ReviewCount đánh giá)</span>
                    </div>
                }

                @if(Model.SoldCount > 0) {
                    <div><i class="bi bi-box-seam text-primary"></i> Đã bán @Model.SoldCount</div>
                } else {
                    <div><i class="bi bi-stars text-warning"></i> Sản phẩm mới</div>
                }
            </div>

            <!-- Box Giá Tiền -->
            <div class="p-4 rounded-4 mb-4 shadow-sm" style="background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%); border: 1px solid rgba(0,0,0,0.05);">
                @if (Model.PromotionalPrice.HasValue && Model.PromotionalPrice < Model.Price)
                {
                    <div class="d-flex align-items-center gap-2 mb-1">
                        <h2 class="text-danger fw-bold mb-0" style="letter-spacing: -0.5px; font-size: 2rem;">@Model.PromotionalPrice.Value.ToString("N0") ₫</h2>
                        <span class="badge bg-danger text-white rounded-pill px-2 py-1 small shadow-sm"><i class="bi bi-lightning-charge-fill text-warning me-1"></i>GIẢM @Math.Round((1 - (decimal)Model.PromotionalPrice.Value / Model.Price) * 100)%</span>
                    </div>
                    <div class="text-muted text-decoration-line-through" style="font-size: 0.95rem;">@Model.Price.ToString("N0") ₫</div>
                }
                else
                {
                    <h2 class="text-danger fw-bold mb-0" style="letter-spacing: -0.5px; font-size: 2rem;">@Model.Price.ToString("N0") ₫</h2>
                }
            </div>

            <!-- Chọn số lượng -->
            @if (Model.Stock > 0)
            {
                <div class="d-flex align-items-center justify-content-between justify-content-sm-start gap-sm-4 mb-4 bg-white p-3 rounded-4 shadow-sm border">
                    <label class="fw-bold text-secondary mb-0">Số lượng:</label>
                    <div class="input-group bg-light rounded-pill p-1 shadow-sm" style="width: 140px; border: 1px solid #dee2e6;">
                        <button class="btn btn-light rounded-circle text-secondary d-flex align-items-center justify-content-center" style="width: 35px; height: 35px;" type="button" onclick="decreaseQuantity()"><i class="bi bi-dash fs-5"></i></button>
                        <input type="number" id="productQuantity" class="form-control border-0 text-center fw-bold bg-transparent px-1" value="1" min="1" max="@Model.Stock" onchange="syncQuantity()" readonly>
                        <button class="btn btn-white rounded-circle text-dark shadow-sm d-flex align-items-center justify-content-center" style="width: 35px; height: 35px;" type="button" onclick="increaseQuantity()"><i class="bi bi-plus fs-5"></i></button>
                    </div>
                </div>
            }

            <!-- Hành động Mua hàng -->
            <div class="d-flex flex-column flex-sm-row gap-3 mb-4">
                @if (Model.Stock > 0)
                {
                    // Lên giỏ nhưng cho nhảy Ajax
                    <form asp-controller="Cart" asp-action="Add" asp-route-productId="@Model.Id" method="post" class="flex-grow-1 ajax-add-to-cart">
                        <input type="hidden" name="quantity" id="hiddenQtyAdd" value="1" />
                        <button type="submit" class="btn btn-outline-danger btn-lg w-100 fw-bold py-3 rounded-pill btn-hover-zoom shadow-sm border-2">
                            <i class="bi bi-cart-plus fs-5 me-2"></i> THÊM GIỎ HÀNG
                        </button>
                    </form>
                    // Nút mua ngay sang Checkout
                    <form asp-controller="Cart" asp-action="BuyNow" asp-route-productId="@Model.Id" method="post" class="flex-grow-1">
                        <input type="hidden" name="quantity" id="hiddenQtyBuy" value="1" />
                        <button type="submit" class="btn btn-danger btn-lg w-100 fw-bold py-3 rounded-pill shadow btn-hover-zoom border-0" style="background: linear-gradient(45deg, #ff416c, #ff4b2b);">
                            MUA NGAY <i class="bi bi-bag-check ms-2 fs-5"></i>
                        </button>
                    </form>
                }
                else
                {
                    <button type="button" class="btn notify-btn-modern w-100" onclick="openNotifyModal(@Model.Id)">
                        <div class="notify-btn-content">
                            <i class="bi bi-bell-fill bell-icon-animate"></i>
                            <span>Nhận thông báo khi có hàng</span>
                            <i class="bi bi-arrow-right ms-auto arrow-icon-slide"></i>
                        </div>
                    </button>
                }
            </div>
            </div> <!-- Close wrapper div -->

            <!-- Bình luận nhanh / Hỏi đáp -->
            <div class="mt-auto" style="padding-top: 2rem;">
                <div id="qa-section-block" class="bg-white rounded-4 p-3 border border-light-subtle shadow-sm hover-shadow" style="transition: all 0.3s;">
                    <div class="d-flex align-items-center justify-content-between mb-3">
                    <div class="d-flex align-items-center">
                        <div class="bg-primary bg-opacity-10 text-primary rounded-circle d-flex align-items-center justify-content-center me-2" style="width: 32px; height: 32px;">
                            <i class="bi bi-chat-dots-fill fs-6"></i>
                        </div>
                        <h6 class="fw-bold mb-0 text-dark" style="font-size: 0.95rem;">Hỏi đáp nhanh</h6>
                    </div>
                    <div class="d-flex align-items-center gap-2">
                        <!-- Nút Xem thêm (hiện khi có nhiều hơn 8 câu) -->
                        <div id="qa-load-more-wrap" style="display: none;">
                            <button type="button" id="qa-load-more-btn" class="btn btn-sm btn-outline-primary rounded-pill py-0 px-2 fw-semibold d-flex align-items-center" style="font-size: 0.7rem; height: 22px;" onclick="openQaModal()" title="Xem toàn bộ">
                                <i class="bi bi-arrows-angle-expand me-1" style="font-size: 0.6rem;"></i> Xem tất cả
                            </button>
                        </div>
                        <!-- Trạng thái kết nối -->
                        <span id="qa-connection-status" class="badge bg-success bg-opacity-10 text-success" style="font-size: 0.65rem; display: none;">
                            <i class="bi bi-circle-fill me-1" style="font-size: 0.4rem;"></i>Trực tuyến
                        </span>
                    </div>
                </div>

                <!-- Vùng chứa bình luận (Render bằng JS) -->
                <div id="mini-qa-list" class="mb-3 d-flex flex-column gap-2 overflow-y-auto custom-scrollbar pe-1" style="height: 185px; scroll-behavior: smooth;">
                    <!-- Loading spinner -->
                    <div id="qa-loading" class="d-flex align-items-center justify-content-center h-100">
                        <div class="spinner-border spinner-border-sm text-primary me-2" role="status"></div>
                        <small class="text-muted">Đang tải câu hỏi...</small>
                    </div>
                </div>

                <!-- Strip trích dẫn: hiện khi đang trả lời một câu hỏi cụ thể -->
                <div id="qa-reply-strip" class="align-items-center justify-content-between px-2 py-1 mb-1 rounded" style="background: #f0f9ff; border: 1px solid #bae6fd; font-size: 0.75rem; color: #0369a1; display: none;">
                    <div class="d-flex align-items-center gap-1 text-truncate">
                        <i class="bi bi-reply-fill"></i>
                        <span id="qa-reply-strip-text" class="text-truncate"></span>
                    </div>
                    <button type="button" class="btn btn-sm p-0 ms-2 text-secondary flex-shrink-0" onclick="cancelQaReply()" style="line-height: 1;" title="Hủy trả lời">
                        <i class="bi bi-x-lg" style="font-size: 0.75rem;"></i>
                    </button>
                </div>

                <!-- Form nhập câu hỏi -->
                <form id="mini-qa-form" class="d-flex gap-2 position-relative" onsubmit="handleMiniQaSubmit(event)">
                    <input type="text" id="mini-qa-input" class="form-control form-control-sm rounded-pill ps-3 pe-5 border-secondary border-opacity-25 bg-light focus-ring focus-ring-primary" placeholder="Viết câu hỏi..." style="font-size: 0.85rem; height: 36px;" autocomplete="off" maxlength="500">
                    <button type="submit" id="mini-qa-submit-btn" class="btn btn-primary rounded-circle position-absolute end-0 top-50 translate-middle-y me-1 d-flex align-items-center justify-content-center" style="width: 28px; height: 28px; padding: 0; background-color: #44b5fe; border: none;">
                        <i class="bi bi-send-fill text-white" style="font-size: 0.75rem;"></i>
                    </button>
                </form>
            </div>

        </div>
    </div>
</div>

<!-- Phần mô tả sản phẩm -->
<div class="mb-5">
    <div class="pt-4 pb-3">
        <h4 class="fw-bold m-0 text-dark border-start border-4 border-primary ps-3">Đặc điểm nổi bật</h4>
    </div>
    <div class="pt-2">
        <div class="lh-lg" style="font-size: 1.05rem;">
            @Html.Raw(Model.Description?.Replace("\n", "<br/>") ?? "<p class='text-muted'>Chưa có bài viết mô tả cho sản phẩm này.</p>")
        </div>
    </div>
</div>

<!-- Khách hàng đánh giá -->
<div class="card border-0 shadow-sm rounded-4 mb-5" id="review-section">
    <div class="card-header bg-white pt-4 pb-3 d-flex justify-content-between align-items-center">
        <h4 class="fw-bold m-0 text-dark border-start border-4 border-warning ps-3">Đánh giá sản phẩm</h4>
    </div>
    <div class="card-body p-4 p-md-5">
        <!-- Dashboard Tổng quan -->
        <div class="row align-items-center mb-5 pb-4 border-bottom">
            <div class="col-md-4 text-center border-end-md mb-4 mb-md-0">
                <h1 class="display-1 fw-bold text-warning mb-0" id="avg-rating-display">@Model.AverageRating.ToString("0.0")</h1>
                <div class="text-warning fs-4 mb-2" id="avg-stars-display">
                    <!-- JS sẽ render -->
                </div>
                <p class="text-muted mb-0"><span id="total-reviews-display">@Model.ReviewCount</span> đánh giá</p>
            </div>
            <div class="col-md-8 px-md-5" id="rating-bars-container">
                <!-- Progress bars sẽ được render bằng JS -->
                <div class="text-center text-muted small">Đang tải thống kê...</div>
            </div>
        </div>

        <!-- Form Đánh giá -->
        @if (User.Identity != null && User.Identity.IsAuthenticated)
        {
            <div class="bg-light p-4 rounded-4 mb-5">
                <h5 class="fw-bold mb-3" id="review-form-title">Gửi đánh giá của bạn</h5>
                <form id="frmReview" onsubmit="submitReview(event)">
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Bạn cảm thấy sản phẩm này thế nào?</label>
                        <div class="d-flex gap-2 text-warning fs-3 mb-1" id="star-selector" style="cursor: pointer;">
                            <i class="bi bi-star" data-val="1"></i>
                            <i class="bi bi-star" data-val="2"></i>
                            <i class="bi bi-star" data-val="3"></i>
                            <i class="bi bi-star" data-val="4"></i>
                            <i class="bi bi-star" data-val="5"></i>
                        </div>
                        <input type="hidden" id="reviewRating" name="rating" value="0" required />
                        <div class="small text-danger d-none" id="rating-error">Vui lòng chọn số sao.</div>
                    </div>
                    <div class="mb-3">
                        <textarea class="form-control" id="reviewContent" name="content" rows="3" placeholder="Xin mời chia sẻ một số cảm nhận về sản phẩm (tối đa 1000 ký tự)..." required maxlength="1000"></textarea>
                    </div>
                    <button type="submit" class="btn btn-warning fw-bold px-4 rounded-pill text-dark" id="btnSubmitReview">Gửi đánh giá</button>
                </form>
            </div>
        }
        else
        {
            <div class="alert alert-info rounded-4 text-center py-4 mb-5 border-0 bg-primary-subtle text-primary">
                <i class="bi bi-info-circle fs-4 d-block mb-2"></i>
                Vui lòng <a href="/Account/Login?returnUrl=/Product/Detail/@Model.Id" class="fw-bold text-decoration-underline text-primary">Đăng nhập</a> để chia sẻ cảm nhận của bạn.
            </div>
        }

        <!-- Danh sách Bình luận -->
        <div id="reviews-list-container">
            <div class="text-center py-5">
                <div class="spinner-border text-primary" role="status"></div>
                <p class="mt-2 text-muted">Đang tải bình luận...</p>
            </div>
        </div>
        
        <!-- Phân trang -->
