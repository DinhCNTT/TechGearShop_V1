@model TechGearShop_V1.Models.Entities.Product
@{
    ViewData["Title"] = Model.Name;
    Layout = "~/Views/Shared/_Layout.cshtml";
    var relatedProducts = ViewBag.RelatedProducts as List<TechGearShop_V1.Models.Entities.Product> ?? new List<TechGearShop_V1.Models.Entities.Product>();
}

<div class="bg-white rounded-4 shadow-sm p-4 p-md-5 mb-5 mt-3">
    <!-- Breadcrumb -->
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb mb-0">
            <li class="breadcrumb-item"><a href="/" class="text-decoration-none"><i class="bi bi-house-door"></i> Trang chủ</a></li>
            <li class="breadcrumb-item"><a href="/Product" class="text-decoration-none">Sản phẩm</a></li>
            <li class="breadcrumb-item"><a href="/Product?categoryId=@Model.CategoryId" class="text-decoration-none">@Model.Category?.Name</a></li>
            <li class="breadcrumb-item active" aria-current="page">@Model.Name</li>
        </ol>
    </nav>

    <div class="row gx-5">
        <!-- Ảnh Sản Phẩm -->
        <div class="col-md-6 mb-4 mb-md-0 position-relative text-center">
            @if (Model.PromotionalPrice.HasValue && Model.PromotionalPrice < Model.Price)
            {
                decimal discountPercent = ((Model.Price - Model.PromotionalPrice.Value) / Model.Price) * 100;
                <span class="position-absolute top-0 start-0 badge bg-danger fs-6 py-2 px-3 z-3 rounded-pill" style="margin: 15px;">
                    <i class="bi bi-lightning-charge-fill text-warning"></i> Giảm @discountPercent.ToString("N0")%
                </span>
            }

            <div class="main-image-container position-relative d-flex align-items-center justify-content-center bg-white rounded-4 border shadow-sm mb-3" style="height: 450px; overflow: hidden;">
                <!-- Mũi tên Trái -->
                <button class="btn btn-light position-absolute start-0 top-50 translate-middle-y ms-2 rounded-circle shadow-sm z-3" style="width: 40px; height: 40px;" onclick="prevImage()" aria-label="Previous image">
                    <i class="bi bi-chevron-left"></i>
                </button>

                <img id="mainProductImage" src="@(string.IsNullOrEmpty(Model.ImagePath) ? "/images/placeholder.jpg" : Model.ImagePath)" 
                     class="img-fluid object-fit-contain p-3 w-100 h-100" 
                     style="cursor: zoom-in;" onclick="openLightbox()"
                     alt="@Model.Name" />

                <!-- Mũi tên Phải -->
                <button class="btn btn-light position-absolute end-0 top-50 translate-middle-y me-2 rounded-circle shadow-sm z-3" style="width: 40px; height: 40px;" onclick="nextImage()" aria-label="Next image">
                    <i class="bi bi-chevron-right"></i>
                </button>
            </div>

            @if (Model.ProductImages != null && Model.ProductImages.Any())
            {
                <div class="d-flex flex-wrap gap-2 justify-content-center" id="galleryThumbs">
                    <!-- Ảnh đại diện -->
                    <div class="gallery-thumb" onclick="changeImageByIndex(0)" style="width: 80px; height: 80px; cursor: pointer; transition: all 0.2s;">
                        <img src="@Model.ImagePath" class="img-fluid rounded border w-100 h-100 object-fit-cover border-danger border-2 shadow-sm" alt="Thumbnail" />
                    </div>
                    <!-- Các ảnh phụ -->
                    @{ int imgIndex = 1; }
                    @foreach (var img in Model.ProductImages.OrderBy(p => p.SortOrder))
                    {
                        var currentIndex = imgIndex++;
                        <div class="gallery-thumb" onclick="changeImageByIndex(@currentIndex)" style="width: 80px; height: 80px; cursor: pointer; transition: all 0.2s;">
                            <img src="@img.ImageUrl" class="img-fluid rounded border w-100 h-100 object-fit-cover" style="opacity: 0.6;" alt="Gallery" />
                        </div>
                    }
                </div>
            }
        </div>

        <!-- Thông Tin Chi Tiết -->
        <div class="col-md-6">
            <span class="badge bg-light text-dark border px-3 py-2 mb-3 fw-bold">@Model.Brand</span>
            
            <h2 class="fw-bold mb-3">@Model.Name</h2>
            
            <!-- Trạng thái Kho & Đánh giá (Demo) -->
            <div class="d-flex align-items-center gap-4 mb-3 text-muted small pb-3 border-bottom">
                <div>
                    @if(Model.Stock > 0) {
                        <span class="badge bg-success-subtle text-success py-1 px-2 border"><i class="bi bi-check2-circle"></i> Còn @Model.Stock máy</span>
                    } else {
                        <span class="badge bg-danger-subtle text-danger py-1 px-2 border"><i class="bi bi-x-circle"></i> Tạm hết hàng</span>
                    }
                </div>
                <div><i class="bi bi-star-fill text-warning"></i> 4.9 (128 Đánh giá)</div>
                <div><i class="bi bi-box-seam text-primary"></i> Đã bán 350+</div>
            </div>

            <!-- Box Giá Tiền -->
            <div class="bg-light p-4 rounded-4 mb-4">
                @if (Model.PromotionalPrice.HasValue && Model.PromotionalPrice < Model.Price)
                {
                    <h1 class="text-danger fw-bold display-5 mb-1">@Model.PromotionalPrice.Value.ToString("N0") ₫</h1>
                    <div class="text-muted text-decoration-line-through fs-5">@Model.Price.ToString("N0") ₫</div>
                }
                else
                {
                    <h1 class="text-danger fw-bold display-5 mb-0">@Model.Price.ToString("N0") ₫</h1>
                }
            </div>

            <!-- Chọn số lượng -->
            @if (Model.Stock > 0)
            {
                <div class="d-flex align-items-center mb-4">
                    <label class="fw-bold me-3">Số lượng:</label>
                    <div class="input-group border rounded" style="width: 130px;">
                        <button class="btn btn-light border-0 text-secondary" type="button" onclick="decreaseQuantity()"><i class="bi bi-dash"></i></button>
                        <input type="number" id="productQuantity" class="form-control border-0 text-center fw-semibold bg-white" value="1" min="1" max="@Model.Stock" onchange="syncQuantity()" readonly>
                        <button class="btn btn-light border-0 text-secondary" type="button" onclick="increaseQuantity()"><i class="bi bi-plus"></i></button>
                    </div>
                    <span class="text-muted ms-3 small">(@Model.Stock sản phẩm có sẵn)</span>
                </div>
            }

            <!-- Hành động Mua hàng -->
            <div class="d-flex gap-3 mb-4">
                @if (Model.Stock > 0)
                {
                    // Lên giỏ nhưng cho nhảy Ajax
                    <form asp-controller="Cart" asp-action="Add" asp-route-productId="@Model.Id" method="post" class="flex-grow-1 ajax-add-to-cart">
                        <input type="hidden" name="quantity" id="hiddenQtyAdd" value="1" />
                        <button type="submit" class="btn btn-outline-danger btn-lg w-100 fw-bold py-3 rounded-pill btn-hover-zoom">
                            <i class="bi bi-cart-plus fs-5 me-2"></i> THÊM GIỎ HÀNG
                        </button>
                    </form>
                    // Nút mua ngay sang Checkout
                    <form asp-controller="Cart" asp-action="BuyNow" asp-route-productId="@Model.Id" method="post" class="flex-grow-1">
                        <input type="hidden" name="quantity" id="hiddenQtyBuy" value="1" />
                        <button type="submit" class="btn btn-danger btn-lg w-100 fw-bold py-3 rounded-pill shadow-sm btn-hover-zoom">
                            MUA NGAY <i class="bi bi-bag-check ms-2"></i>
                        </button>
                    </form>
                }
                else
                {
                    <button class="btn btn-secondary btn-lg w-100 fw-bold py-3 rounded-pill disabled"><i class="bi bi-bell-fill me-2"></i> NHẬN THÔNG BÁO KHI CÓ HÀNG</button>
                }
            </div>

            <!-- Thông tin bổ sung cam kết -->
            <ul class="list-unstyled mb-0 bg-light-subtle rounded-3 p-3 border">
                <li class="mb-2"><i class="bi bi-shield-check text-success fs-5 me-2 align-middle"></i>Bảo hành chính hãng 24 tháng.</li>
                <li class="mb-2"><i class="bi bi-arrow-repeat text-primary fs-5 me-2 align-middle"></i>Đổi mới trong 7 ngày nếu có lỗi NSX.</li>
                <li><i class="bi bi-truck text-dark fs-5 me-2 align-middle"></i>Miễn phí giao hàng toàn quốc.</li>
            </ul>
        </div>
    </div>
</div>

<!-- Phần mô tả sản phẩm -->
<div class="card border-0 shadow-sm rounded-4 mb-5">
    <div class="card-header bg-white pt-4 pb-3">
        <h4 class="fw-bold m-0 text-dark border-start border-4 border-primary ps-3">Đặc điểm nổi bật</h4>
    </div>
    <div class="card-body p-4 p-md-5">
        <div class="lh-lg" style="font-size: 1.05rem;">
            @Html.Raw(Model.Description?.Replace("\n", "<br/>") ?? "<p class='text-muted'>Chưa có bài viết mô tả cho sản phẩm này.</p>")
        </div>
    </div>
</div>

<!-- Sản phẩm liên quan -->
@if (relatedProducts.Any())
{
    <div class="mb-5">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h3 class="fw-bold m-0 border-start border-4 border-danger ps-3">Gợi ý cho bạn</h3>
        </div>
        <div class="row row-cols-1 row-cols-sm-2 row-cols-md-4 g-4">
            @foreach (var prod in relatedProducts)
            {
                <div class="col">
                    <partial name="_ProductCard" model="prod" />
                </div>
            }
        </div>
    </div>
}

<!-- Lightbox Modal (Fullscreen Dark Theme) -->
<div class="modal fade" id="imageLightboxModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-fullscreen">
        <div class="modal-content bg-dark border-0">
            <div class="modal-header border-0 pb-0 pe-4 pt-4 z-3 position-absolute end-0 top-0 w-100 d-flex justify-content-end">
                <button type="button" class="btn-close btn-close-white fs-4" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body d-flex justify-content-center align-items-center position-relative p-0 h-100">
                <!-- Nút Trái Modal -->
                <button class="btn btn-outline-light position-absolute start-0 top-50 translate-middle-y ms-3 ms-md-5 rounded-circle" style="width:50px;height:50px;" onclick="prevImage()" aria-label="Previous">
                    <i class="bi bi-chevron-left fs-4"></i>
                </button>
                
                <!-- Ảnh Modal -->
                <img id="lightboxImage" src="" class="img-fluid object-fit-contain" style="max-height: 90vh; max-width: 90vw;" alt="Zoomed Product" />
                
                <!-- Nút Phải Modal -->
                <button class="btn btn-outline-light position-absolute end-0 top-50 translate-middle-y me-3 me-md-5 rounded-circle" style="width:50px;height:50px;" onclick="nextImage()" aria-label="Next">
                    <i class="bi bi-chevron-right fs-4"></i>
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Data Array chứa danh sách các URL ảnh
        const galleryImages = [
            '@Html.Raw(Model.ImagePath)'
            @foreach(var img in Model.ProductImages.OrderBy(p => p.SortOrder)) {
                <text>,'@Html.Raw(img.ImageUrl)'</text>
            }
        ];
        
        let currentImageIndex = 0;

        function changeImageByIndex(index) {
            if (index < 0 || index >= galleryImages.length) return;
            currentImageIndex = index;
            
            // Cập nhật ảnh chính
            const mainImg = document.getElementById('mainProductImage');
            mainImg.style.opacity = '0.5';
            setTimeout(() => {
                mainImg.src = galleryImages[currentImageIndex];
                mainImg.style.opacity = '1';
            }, 150);
            
            // Cập nhật trạng thái Thumbnail
            const thumbs = document.querySelectorAll('.gallery-thumb img');
            thumbs.forEach((img, idx) => {
                if (idx === currentImageIndex) {
                    img.classList.add('border-danger', 'border-2', 'shadow-sm');
                    img.style.opacity = '1';
                } else {
                    img.classList.remove('border-danger', 'border-2', 'shadow-sm');
                    img.style.opacity = '0.6';
                }
            });

            // Nếu Lightbox đang mở, cập nhật luôn ảnh trong Lightbox
            const lightboxImg = document.getElementById('lightboxImage');
            if (lightboxImg) {
                lightboxImg.style.opacity = '0.5';
                setTimeout(() => {
                    lightboxImg.src = galleryImages[currentImageIndex];
                    lightboxImg.style.opacity = '1';
                }, 150);
            }
        }

        function openLightbox() {
            // Hiển thị Modal Bootstrap
            var myModal = new bootstrap.Modal(document.getElementById('imageLightboxModal'), {
                keyboard: true
            });
            // Set ảnh hiện tại trước khi show
            document.getElementById('lightboxImage').src = galleryImages[currentImageIndex];
            myModal.show();
        }

        function nextImage() {
            let nextIdx = currentImageIndex + 1;
            if (nextIdx >= galleryImages.length) nextIdx = 0; // Quay vòng
            changeImageByIndex(nextIdx);
        }

        function prevImage() {
            let prevIdx = currentImageIndex - 1;
            if (prevIdx < 0) prevIdx = galleryImages.length - 1; // Móc ngược
            changeImageByIndex(prevIdx);
        }


        function syncQuantity() {
            var qty = document.getElementById('productQuantity').value;
            // Update hidden inputs for both forms
            var hdAdd = document.getElementById('hiddenQtyAdd');
            var hdBuy = document.getElementById('hiddenQtyBuy');
            if (hdAdd) hdAdd.value = qty;
            if (hdBuy) hdBuy.value = qty;
        }

        function increaseQuantity() {
            var input = document.getElementById('productQuantity');
            var max = parseInt(input.getAttribute('max'));
            var current = parseInt(input.value);
            
            if (current >= max) {
                Swal.fire({
                    icon: 'warning',
                    title: 'Giới hạn tồn kho!',
                    text: 'Sản phẩm này trong kho chỉ còn tối đa ' + max + ' cái.',
                    confirmButtonColor: '#dc3545',
                    confirmButtonText: 'Đã hiểu'
                });
            } else {
                input.stepUp();
                syncQuantity();
            }
        }

        function decreaseQuantity() {
            var input = document.getElementById('productQuantity');
            input.stepDown();
            syncQuantity();
        }
    </script>
}
