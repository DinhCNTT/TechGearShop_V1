@model TechGearShop_V1.Models.DTOs.VNPayResponseDto

@{
    ViewData["Title"] = "Kết quả thanh toán VNPay";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-5 mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
                @if (Model.IsSuccess)
                {
                    <div class="bg-success text-white text-center py-4">
                        <i class="bi bi-check-circle-fill display-1"></i>
                        <h2 class="fw-bold mt-3 mb-0">Thanh toán thành công!</h2>
                    </div>
                    <div class="card-body p-4 p-md-5">
                        <p class="text-center text-muted mb-4">Cảm ơn bạn đã mua sắm tại TechGearShop. Đơn hàng của bạn đã được thanh toán và đang trong quá trình xử lý.</p>
                        
                        <div class="bg-light rounded-3 p-3 mb-4">
                            <div class="d-flex justify-content-between border-bottom pb-2 mb-2">
                                <span class="text-muted">Mã đơn hàng:</span>
                                <span class="fw-bold">#@Model.OrderId</span>
                            </div>
                            <div class="d-flex justify-content-between border-bottom pb-2 mb-2">
                                <span class="text-muted">Mã giao dịch VNPay:</span>
                                <span class="fw-semibold text-secondary">@Model.TransactionId</span>
                            </div>
                            <div class="d-flex justify-content-between border-bottom pb-2 mb-2">
                                <span class="text-muted">Ngân hàng:</span>
                                <span class="fw-semibold">@Model.BankCode</span>
                            </div>
                            <div class="d-flex justify-content-between">
                                <span class="text-muted">Số tiền thanh toán:</span>
                                <span class="fw-bold text-danger fs-5">@Model.Amount.ToString("N0") ₫</span>
                            </div>
                        </div>

                        <div class="d-grid gap-2 d-md-flex justify-content-md-center">
                            <a href="@Url.Action("Orders", "Account")" class="btn btn-primary px-4 fw-semibold rounded-pill">Quản lý đơn hàng</a>
                            <a href="@Url.Action("Index", "Home")" class="btn btn-outline-secondary px-4 fw-semibold rounded-pill">Tiếp tục mua sắm</a>
                        </div>
                    </div>
                }
                else
                {
                    <div class="bg-danger text-white text-center py-4">
                        <i class="bi bi-x-circle-fill display-1"></i>
                        <h2 class="fw-bold mt-3 mb-0">Thanh toán thất bại</h2>
                    </div>
                    <div class="card-body p-4 p-md-5">
                        <div class="alert alert-warning text-center fw-semibold mb-4">
                            Mã lỗi VNPay: @Model.ResponseCode
                        </div>
                        <p class="text-center text-muted mb-4">Rất tiếc, giao dịch thanh toán VNPay của bạn không thành công hoặc đã bị hủy. Đơn hàng đã tự động bị hủy để hoàn lại số lượng sản phẩm vào kho.</p>
                        
                        <div class="d-grid gap-2 d-md-flex justify-content-md-center">
                            <a href="@Url.Action("Index", "Cart")" class="btn btn-danger px-4 fw-semibold rounded-pill">Trở lại giỏ hàng</a>
                            <a href="@Url.Action("Index", "Home")" class="btn btn-outline-secondary px-4 fw-semibold rounded-pill">Trang chủ</a>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>
