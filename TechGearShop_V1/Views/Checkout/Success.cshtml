@model int

@{
    ViewData["Title"] = "Đặt hàng thành công";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="row justify-content-center my-5">
    <div class="col-md-7 text-center">
        <div class="mb-4">
            <i class="bi bi-check-circle-fill text-success" style="font-size: 6rem;"></i>
        </div>
        <h1 class="display-5 fw-bold text-dark mb-3">Đơn hàng đã được ghi nhận!</h1>
        <p class="fs-5 text-muted mb-4">Cảm ơn bạn đã tin tưởng mua sắm tại TechGear Shop. Chúng tôi đang xử lý đơn hàng của bạn và sẽ gửi email xác nhận trong ít phút ngắn ngủi nữa.</p>
        
        <div class="card bg-light border-0 rounded-4 p-4 mx-auto mb-5 shadow-sm" style="max-width: 500px;">
            <p class="mb-1 text-secondary fw-semibold">Mã Đơn Hàng Của Bạn</p>
            <h2 class="fw-bold m-0 text-primary">#TG-2026-@Model.ToString("D5")</h2>
        </div>

        <div>
            <a href="/" class="btn btn-primary btn-lg px-5 me-2 rounded-pill fw-bold shadow"><i class="bi bi-arrow-left-circle me-2"></i> Quay lại trang chủ</a>
            <a href="/Product" class="btn btn-outline-dark btn-lg px-4 rounded-pill fw-bold">Tiếp tục mua sắm</a>
        </div>
    </div>
</div>
