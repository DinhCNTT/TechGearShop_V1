@model TechGearShop_V1.Models.ViewModels.CheckoutViewModel

@{
    ViewData["Title"] = "Thanh toán an toàn";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="row gx-5">
    <!-- Form thông tin đặt hàng (Trái) -->
    <div class="col-lg-7 mb-5">
        <div class="card border-0 shadow-sm rounded-4 p-4">
            <h4 class="fw-bold mb-4"><i class="bi bi-shield-lock-fill text-success"></i> Thông tin thanh toán</h4>
            
            <form asp-controller="Checkout" asp-action="PlaceOrder" method="post" id="checkoutForm">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3 fw-semibold"></div>

                <div class="row g-3">
                    <!-- Họ Tên -->
                    <div class="col-md-6 mb-3">
                        <label asp-for="ReceiverName" class="form-label fw-semibold">Họ và tên <span class="text-danger">*</span></label>
                        <input asp-for="ReceiverName" class="form-control bg-light" placeholder="Nguyễn Văn A" />
                        <span asp-validation-for="ReceiverName" class="text-danger small"></span>
                    </div>

                    <!-- Số Điện Thoại -->
                    <div class="col-md-6 mb-3">
                        <label asp-for="ReceiverPhone" class="form-label fw-semibold">Số điện thoại <span class="text-danger">*</span></label>
                        <input asp-for="ReceiverPhone" class="form-control bg-light" placeholder="0987123456" />
                        <span asp-validation-for="ReceiverPhone" class="text-danger small"></span>
                    </div>

                    <!-- Tỉnh / Thành -->
                    <div class="col-md-5 mb-3">
                        <label asp-for="Province" class="form-label fw-semibold">Tỉnh / Thành phố <span class="text-danger">*</span></label>
                        <select asp-for="Province" class="form-select bg-light">
                            <option value="">-- Chọn Tỉnh/Thành --</option>
                            <option value="Hà Nội">Hà Nội</option>
                            <option value="Hồ Chí Minh">TP. Hồ Chí Minh</option>
                            <option value="Đà Nẵng">Đà Nẵng</option>
                            <option value="Tỉnh khác">Tỉnh Thành Khác (Demo)</option>
                        </select>
                        <span asp-validation-for="Province" class="text-danger small"></span>
                    </div>

                    <!-- Lọc Địa chỉ (Ngắn) -->
                    <div class="col-md-7 mb-3">
                        <label asp-for="ShippingAddress" class="form-label fw-semibold">Số nhà, Tên đường, Phường/Xã <span class="text-danger">*</span></label>
                        <input asp-for="ShippingAddress" class="form-control bg-light" placeholder="Số 1, Phố Y, Phường X..." />
                        <span asp-validation-for="ShippingAddress" class="text-danger small"></span>
                    </div>

                    <!-- Ghi Chú -->
                    <div class="col-12 mb-3">
                        <label asp-for="Note" class="form-label fw-semibold">Ghi chú giao hàng (Tùy chọn)</label>
                        <textarea asp-for="Note" class="form-control bg-light" rows="3" placeholder="Giao giờ hành chính..."></textarea>
                    </div>

                    <!-- Hình thức thanh toán -->
                    <div class="col-12 mb-4">
                        <label class="form-label fw-semibold d-block">Hình thức thanh toán <span class="text-danger">*</span></label>
                        <div class="form-check p-3 border rounded mb-2 bg-light">
                            <input class="form-check-input ms-1 me-2" type="radio" asp-for="PaymentMethod" value="@TechGearShop_V1.Models.Entities.PaymentMethod.COD" id="payCOD" checked>
                            <label class="form-check-label w-100" style="cursor:pointer;" for="payCOD">
                                <i class="bi bi-cash-stack text-success"></i> Thanh toán khi nhận hàng (COD)
                            </label>
                        </div>
                        <div class="form-check p-3 border rounded bg-light opacity-50">
                            <input class="form-check-input ms-1 me-2" type="radio" asp-for="PaymentMethod" value="@TechGearShop_V1.Models.Entities.PaymentMethod.VNPay" id="payVNPay" disabled>
                            <label class="form-check-label w-100" style="cursor:pointer;" for="payVNPay">
                                <i class="bi bi-credit-card-2-front text-primary"></i> Chuyển khoản VNPay (Sẽ mở ở Phase sau)
                            </label>
                        </div>
                    </div>
                </div>

                <!-- Hidden Input để đẩy Coupon Code nếu áp dụng thành công nộp chung cùng form -->
                <input type="hidden" asp-for="CouponCode" id="hiddenCouponCode">

                <button type="submit" class="btn btn-danger btn-lg w-100 fw-bold py-3 shadow-sm rounded-pill" id="btnPlaceOrder">
                    ĐẶT HÀNG NGAY <i class="bi bi-arrow-right-circle ms-2"></i>
                </button>
                <div class="text-center mt-3 small text-muted"><i class="bi bi-check-circle-fill text-success"></i> Thông tin của bạn được bảo mật an toàn 100%</div>
            </form>
        </div>
    </div>

    <!-- Tóm tắt Đơn hàng (Phải) -->
    <div class="col-lg-5">
        <div class="card border-0 shadow-sm rounded-4 bg-light p-4 sticky-top" style="top: 2rem;">
            <h5 class="fw-bold mb-4 border-bottom pb-2">Đơn hàng của bạn (@Model.CartItems.Sum(c => c.Quantity) món)</h5>
            
            <div class="mb-4" style="max-height: 300px; overflow-y: auto;">
                @foreach(var item in Model.CartItems)
                {
                    <div class="d-flex align-items-center mb-3">
                        <div class="position-relative me-3">
                            @if (!string.IsNullOrEmpty(item.ImagePath))
                            {
                                <img src="@item.ImagePath" class="rounded object-fit-cover border" width="60" height="60" />
                            }
                            <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-secondary text-white border border-white">
                                @item.Quantity
                            </span>
                        </div>
                        <div class="flex-grow-1">
                            <div class="fw-semibold text-truncate" style="max-width: 200px;" title="@item.ProductName">@item.ProductName</div>
                            <div class="text-muted small">@item.Price.ToString("N0")₫</div>
                        </div>
                        <div class="fw-bold ms-auto">
                            @((item.Price * item.Quantity).ToString("N0"))₫
                        </div>
                    </div>
                }
            </div>

            <!-- Mã giảm giá AJAX Form -->
            <div class="mb-4 pt-3 border-top">
                <label class="form-label fw-semibold">Mã giảm giá (Coupon)</label>
                <div class="input-group">
                    <input type="text" id="couponInput" class="form-control" placeholder="Nhập mã tại đây">
                    <button class="btn btn-dark fw-semibold px-4" type="button" id="btnApplyCoupon" onclick="applyCoupon()">Áp dụng</button>
                </div>
                <div id="couponMessage" class="mt-2 small fw-semibold" style="display:none;"></div>
            </div>

            <!-- Tính tiền tổng hợp -->
            <div class="border-top pt-3">
                <div class="d-flex justify-content-between mb-2">
                    <span class="text-muted">Tạm tính</span>
                    <span class="fw-semibold" id="rawSubTotal" data-value="@Model.SubTotal">@Model.SubTotal.ToString("N0") ₫</span>
                </div>
                <div class="d-flex justify-content-between mb-2">
                    <span class="text-muted">Phí Giao Hàng</span>
                    <span class="fw-semibold">@Model.ShippingFee.ToString("N0") ₫</span>
                </div>
                <div class="d-flex justify-content-between mb-3 text-success d-none" id="discountRow">
                    <span class="text-success"><i class="bi bi-tag-fill"></i> Giảm giá Coupon</span>
                    <span class="fw-semibold" id="discountValue">-0 ₫</span>
                </div>
                
                <hr>
                
                <div class="d-flex justify-content-between align-items-center">
                    <span class="fw-bold fs-5">Tổng cộng</span>
                    <span class="fw-bold fs-3 text-danger" id="finalTotal">@Model.FinalTotal.ToString("N0") ₫</span>
                </div>
                <p class="text-end text-muted small mb-0 mt-1">(Đã bao gồm VAT nếu có)</p>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        // Javascript cho Validate Coupon API (Sử dụng kiến trúc Fetch API hiện đại)
        async function applyCoupon() {
            var code = document.getElementById("couponInput").value.trim();
            var msgDiv = document.getElementById("couponMessage");
            var btn = document.getElementById("btnApplyCoupon");
            
            if (code === "") {
                msgDiv.style.display = "block";
                msgDiv.className = "mt-2 small fw-semibold text-danger";
                msgDiv.innerText = "Vui lòng nhập mã để áp dụng.";
                return;
            }

            // Giao diện pending
            btn.innerHTML = '<span class="spinner-border spinner-border-sm"></span>';
            btn.disabled = true;

            try {
                const response = await fetch(`/Checkout/ApplyCoupon?code=${code}`);
                const result = await response.json();

                msgDiv.style.display = "block";
                
                if (result.success) {
                    // Cập nhật giao diện tiền tệ
                    msgDiv.className = "mt-2 small fw-bold text-success";
                    msgDiv.innerHTML = `<i class="bi bi-check-circle-fill"></i> ${result.message}`;
                    
                    document.getElementById("hiddenCouponCode").value = code; // Bind to main Form
                    
                    // Hiện row coupon và trừ tiền
                    document.getElementById("discountRow").classList.remove("d-none");
                    document.getElementById("discountValue").innerText = `-${result.discount.toLocaleString('vi-VN')} ₫`;

                    let subTotal = parseFloat(document.getElementById("rawSubTotal").getAttribute("data-value"));
                    let fee = @Model.ShippingFee;
                    let finalAmount = subTotal + fee - result.discount;
                    if(finalAmount < 0) finalAmount = 0; // Edge case
                    
                    document.getElementById("finalTotal").innerText = `${finalAmount.toLocaleString('vi-VN')} ₫`;
                    
                    document.getElementById("couponInput").readOnly = true;
                    btn.innerText = "Đã áp dụng";
                } else {
                    // Mã sai
                    msgDiv.className = "mt-2 small text-danger";
                    msgDiv.innerText = result.message;
                    btn.innerHTML = "Áp dụng";
                    btn.disabled = false;
                    document.getElementById("hiddenCouponCode").value = "";
                }
            } catch(e) {
                msgDiv.style.display = "block";
                msgDiv.className = "mt-2 small text-danger";
                msgDiv.innerText = "Lỗi kết nối máy chủ!";
                btn.innerHTML = "Áp dụng";
                btn.disabled = false;
            }
        }
    </script>
}
