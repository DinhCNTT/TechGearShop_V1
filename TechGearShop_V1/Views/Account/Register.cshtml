@model TechGearShop_V1.Models.ViewModels.RegisterViewModel
@{
    ViewData["Title"] = "Tạo tài khoản mới";
}

<div class="row justify-content-center my-5">
    <div class="col-md-6 col-lg-5">
        <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
            <!-- Card Header with Gradient -->
            <div class="card-header py-4 text-white text-center" style="background: linear-gradient(135deg, #198754, #20c997);">
                <h3 class="fw-bold mb-1"><i class="bi bi-person-plus me-2"></i>Tạo Tài Khoản</h3>
                <p class="mb-0 opacity-75 small">Mua sắm dễ dàng hơn với tài khoản TechGear</p>
            </div>

            <div class="card-body p-4 p-md-5">
                <form asp-action="Register" method="post">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small" role="alert"></div>

                    <div class="mb-3">
                        <label asp-for="Username" class="form-label fw-semibold">Tên đăng nhập <span class="text-danger">*</span></label>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-end-0"><i class="bi bi-at text-muted"></i></span>
                            <input asp-for="Username" class="form-control border-start-0 bg-light" placeholder="techuser123" />
                        </div>
                        <span asp-validation-for="Username" class="text-danger small"></span>
                        <div class="form-text text-muted">Chỉ dùng chữ, số và dấu _ (không dấu cách)</div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Email" class="form-label fw-semibold">Email <span class="text-danger">*</span></label>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-end-0"><i class="bi bi-envelope text-muted"></i></span>
                            <input asp-for="Email" class="form-control border-start-0 bg-light" placeholder="tenban@email.com" />
                        </div>
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="PhoneNumber" class="form-label fw-semibold">Số điện thoại <span class="text-danger">*</span></label>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-end-0"><i class="bi bi-telephone text-muted"></i></span>
                            <input asp-for="PhoneNumber" class="form-control border-start-0 bg-light" placeholder="0987123456" />
                        </div>
                        <span asp-validation-for="PhoneNumber" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Password" class="form-label fw-semibold">Mật khẩu <span class="text-danger">*</span></label>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-end-0"><i class="bi bi-lock text-muted"></i></span>
                            <input asp-for="Password" class="form-control border-start-0 bg-light" placeholder="Tối thiểu 6 ký tự" id="pwdField" />
                            <button class="btn btn-outline-secondary border-start-0" type="button" onclick="togglePwd('pwdField', this)">
                                <i class="bi bi-eye"></i>
                            </button>
                        </div>
                        <span asp-validation-for="Password" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="ConfirmPassword" class="form-label fw-semibold">Xác nhận mật khẩu <span class="text-danger">*</span></label>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-end-0"><i class="bi bi-lock-fill text-muted"></i></span>
                            <input asp-for="ConfirmPassword" class="form-control border-start-0 bg-light" placeholder="Nhập lại mật khẩu" id="confirmPwdField" />
                            <button class="btn btn-outline-secondary border-start-0" type="button" onclick="togglePwd('confirmPwdField', this)">
                                <i class="bi bi-eye"></i>
                            </button>
                        </div>
                        <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                    </div>

                    <div class="d-grid">
                        <button type="submit" class="btn btn-success btn-lg rounded-pill fw-bold py-2">
                            TẠO TÀI KHOẢN <i class="bi bi-arrow-right-circle ms-1"></i>
                        </button>
                    </div>
                </form>
            </div>

            <div class="card-footer bg-white text-center py-4 border-top">
                <span class="text-muted">Đã có tài khoản?</span>
                <a asp-action="Login" class="fw-bold text-primary ms-1 text-decoration-none">Đăng nhập ngay</a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        function togglePwd(fieldId, btn) {
            const field = document.getElementById(fieldId);
            const icon = btn.querySelector('i');
            if (field.type === 'password') {
                field.type = 'text';
                icon.className = 'bi bi-eye-slash';
            } else {
                field.type = 'password';
                icon.className = 'bi bi-eye';
            }
        }
    </script>
}
