@model IEnumerable<TechGearShop_V1.Models.Entities.Order>
@using TechGearShop_V1.Models.Entities
@{
    ViewData["Title"] = "Đơn hàng của tôi";
    var all = Model.ToList();
    var filter = Context.Request.Query["status"].ToString();
    var displayed = filter switch {
        "pending"    => all.Where(o => o.Status == OrderStatus.Pending).ToList(),
        "processing" => all.Where(o => o.Status == OrderStatus.Processing).ToList(),
        "shipping"   => all.Where(o => o.Status == OrderStatus.Shipping).ToList(),
        "completed"  => all.Where(o => o.Status == OrderStatus.Completed).ToList(),
        "cancelled"  => all.Where(o => o.Status == OrderStatus.Cancelled).ToList(),
        _            => all
    };
}

@* Hiển thị thông báo thành công / lỗi toàn trang *@
@if (TempData["UserSuccess"] != null)
{
    <div class="alert alert-success alert-dismissible fade show m-0 rounded-0 border-0" role="alert">
        <i class="bi bi-check-circle-fill me-2"></i>@TempData["UserSuccess"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["UserError"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show m-0 rounded-0 border-0" role="alert">
        <i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["UserError"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="container py-5">
    <div class="row g-4">
        <!-- Sidebar Account -->
        <div class="col-lg-3">
            <div class="card border-0 shadow-sm rounded-4 overflow-hidden sticky-top" style="top: 80px;">
                <div class="card-body p-4 text-center" style="background: linear-gradient(135deg, #0d6efd 0%, #6610f2 100%);">
                    <div class="rounded-circle bg-white d-inline-flex align-items-center justify-content-center mb-3 shadow" style="width: 72px; height: 72px;">
                        <i class="bi bi-person-fill text-primary" style="font-size: 2rem;"></i>
                    </div>
                    <h6 class="fw-bold text-white mb-1">@User.Identity!.Name</h6>
                    <span class="badge bg-white bg-opacity-25 text-white small px-3 py-1 rounded-pill">⭐ Thành viên TechGear</span>
                </div>
                <div class="list-group list-group-flush">
                    <a href="#" class="list-group-item list-group-item-action border-0 py-3 px-4 text-muted d-flex align-items-center gap-3">
                        <i class="bi bi-person-circle fs-5 text-primary"></i>Hồ sơ của tôi
                    </a>
                    <a href="/Account/Orders" class="list-group-item list-group-item-action border-0 py-3 px-4 fw-semibold d-flex align-items-center gap-3" style="background: rgba(13,110,253,0.07); color: #0d6efd; border-left: 3px solid #0d6efd !important;">
                        <i class="bi bi-bag-check-fill fs-5"></i>Đơn hàng của tôi
                    </a>
                    <a href="/Account/Notifications" class="list-group-item list-group-item-action border-0 py-3 px-4 text-muted d-flex align-items-center gap-3">
                        <i class="bi bi-bell-fill fs-5 text-warning"></i>Thông báo
                    </a>
                </div>
            </div>
        </div>

        <!-- Main Content -->
        <div class="col-lg-9">
            <!-- Status Filter Tabs (như Shopee) -->
            <div class="card border-0 shadow-sm rounded-4 overflow-hidden mb-4">
                <div class="d-flex border-bottom overflow-auto" style="white-space: nowrap;">
                    @{
                        (string Key, string Label, int Count)[] tabs = {
                            ("",          "Tất cả",         all.Count),
                            ("pending",   "Chờ xác nhận",   all.Count(o => o.Status == OrderStatus.Pending)),
                            ("processing","Đang xử lý",     all.Count(o => o.Status == OrderStatus.Processing)),
                            ("shipping",  "Đang giao",      all.Count(o => o.Status == OrderStatus.Shipping)),
                            ("completed", "Hoàn thành",     all.Count(o => o.Status == OrderStatus.Completed)),
                            ("cancelled", "Đã hủy",         all.Count(o => o.Status == OrderStatus.Cancelled)),
                        };
                    }
                    @foreach (var tab in tabs)
                    {
                        bool isActive = filter == tab.Key;
                        <a href="/Account/Orders@(tab.Key != "" ? "?status=" + tab.Key : "")"
                           class="py-3 px-4 text-decoration-none flex-shrink-0 d-flex align-items-center gap-2 @(isActive ? "fw-bold border-bottom border-primary border-3 text-primary" : "text-muted")"
                           style="font-size: 0.9rem;">
                            @tab.Label
                            @if (tab.Count > 0)
                            {
                                <span class="badge rounded-pill @(isActive ? "bg-primary" : "bg-secondary bg-opacity-50 text-dark")">@tab.Count</span>
                            }
                        </a>
                    }
                </div>
            </div>

            @if (!displayed.Any())
            {
                <div class="card border-0 shadow-sm rounded-4 p-5 text-center">
                    <i class="bi bi-bag-x mb-4" style="font-size: 5rem; color: #dee2e6;"></i>
                    <h5 class="fw-bold text-dark mb-2">Không có đơn hàng nào</h5>
                    <p class="text-muted small mb-4">Có vẻ như bạn chưa có đơn hàng nào trong mục này.</p>
                    <a href="/Product" class="btn btn-primary rounded-pill px-5 fw-bold mx-auto" style="max-width:200px;">Mua sắm ngay</a>
                </div>
            }
            else
            {
                @foreach (var order in displayed)
                {
                    string payLabelText = "COD";
                    string payLabelColor = "text-success";
                    
                    if (order.PaymentMethod == TechGearShop_V1.Models.Entities.PaymentMethod.VNPay)
                    {
                        if (order.PaymentStatus == TechGearShop_V1.Models.Entities.PaymentStatus.Paid)
                        {
                            payLabelText = "VNPay (Đã thanh toán)";
                            payLabelColor = "text-success";
                        }
                        else if (order.PaymentStatus == TechGearShop_V1.Models.Entities.PaymentStatus.Failed)
                        {
                            payLabelText = "VNPay (Lỗi)";
                            payLabelColor = "text-danger";
                        }
                        else
                        {
                            payLabelText = "VNPay (Chưa thanh toán)";
                            payLabelColor = "text-warning";
                        }
                    }

                    <div class="card border-0 shadow-sm rounded-4 overflow-hidden mb-4 order-card">

                        <!-- Order Header -->
                        <div class="card-header bg-white border-bottom px-4 py-3 d-flex justify-content-between align-items-center flex-wrap gap-2">
                            <div class="d-flex align-items-center gap-3">
                                <span class="fw-bold text-dark">Đơn hàng #@order.Id</span>
                                
                                @* LOGIC HIỂN THỊ THỜI GIAN THỰC TẾ THEO TAB *@
                                @{
                                    string timeLabel = "Đặt lúc:";
                                    DateTime timeValue = order.OrderDate;

                                    if (order.Status == OrderStatus.Shipping && order.ShippingDate.HasValue)
                                    {
                                        timeLabel = "Giao lúc:";
                                        timeValue = order.ShippingDate.Value;
                                    }
                                    else if (order.Status == OrderStatus.Completed && order.CompletedDate.HasValue)
                                    {
                                        timeLabel = "Hoàn thành lúc:";
                                        timeValue = order.CompletedDate.Value;
                                    }
                                    else if (order.Status == OrderStatus.Cancelled && order.CancelledDate.HasValue)
                                    {
                                        timeLabel = "Hủy lúc:";
                                        timeValue = order.CancelledDate.Value;
                                    }
                                    
                                    // Chuyển UTC sang giờ Việt Nam (+7)
                                    var vnTime = timeValue.AddHours(7).ToString("HH:mm - dd/MM/yyyy");
                                }

                                <span class="text-muted small"><i class="bi bi-clock me-1"></i>@timeLabel @vnTime</span>
                                <span class="badge @(payLabelColor == "text-success" ? "bg-success" : (payLabelColor == "text-danger" ? "bg-danger" : "bg-warning")) bg-opacity-10 @(payLabelColor) border border-opacity-25 fw-normal px-2 py-1" style="font-size: 0.75rem;">
                                    <i class="bi bi-credit-card me-1"></i>@payLabelText
                                </span>
                            </div>
                            <div>
                                @switch (order.Status)
                                {
                                    case OrderStatus.PaymentPending:
                                        <span class="badge bg-warning text-dark px-3 py-2 rounded-pill">⏳ Đang chờ thanh toán VNPay</span>
                                        <a href="/VNPay/Pay?orderId=@order.Id" class="btn btn-sm btn-primary ms-2 rounded-pill">Thanh toán ngay</a>
                                        break;
                                    case OrderStatus.Pending:
                                        <span class="badge bg-warning text-dark px-3 py-2 rounded-pill">⏳ Chờ xác nhận</span>; break;
                                    case OrderStatus.Processing:
                                        <span class="badge bg-info px-3 py-2 rounded-pill">⚙️ Đang xử lý</span>; break;
                                    case OrderStatus.Shipping:
                                        <span class="badge bg-primary px-3 py-2 rounded-pill">🚚 Đang giao hàng</span>; break;
                                    case OrderStatus.Completed:
                                        <span class="badge bg-success px-3 py-2 rounded-pill">✅ Đã giao thành công</span>; break;
                                    default:
                                        <span class="badge bg-danger px-3 py-2 rounded-pill">❌ Đã hủy</span>; break;
                                }
                            </div>
                        </div>

                        <!-- Shipping Address -->
                        <div class="px-4 py-2 bg-light border-bottom d-flex align-items-center gap-2 small text-muted">
                            <i class="bi bi-geo-alt-fill text-danger"></i>
                            <span>Giao đến: <strong class="text-dark">@order.ReceiverName</strong> — @order.ShippingAddress</span>
                        </div>

                        <!-- Items List -->
                        <div class="card-body p-0">
                            @foreach (var detail in order.OrderDetails)
                            {
                                <div class="d-flex align-items-center px-4 py-3 border-bottom order-item-row" style="transition: background 0.2s;">
                                    <a href="/Account/OrderDetail/@order.Id" class="flex-shrink-0">
                                        <img src="@detail.Product?.ImagePath" alt="@detail.Product?.Name"
                                             class="rounded-3 object-fit-cover shadow-sm"
                                             style="width: 80px; height: 80px;" onerror="this.src='/images/no-image.png'" />
                                    </a>
                                    <div class="ms-3 flex-grow-1">
                                        <a href="/Account/OrderDetail/@order.Id" class="text-decoration-none text-dark">
                                            <h6 class="mb-1 fw-semibold line-clamp-2">@detail.Product?.Name</h6>
                                        </a>
                                        <div class="text-muted small">Phân loại: Chính hãng</div>
                                    </div>
                                    <div class="text-end ms-3 flex-shrink-0">
                                        <div class="text-muted small">x @detail.Quantity</div>
                                        <div class="fw-bold text-danger">@detail.UnitPrice.ToString("N0") ₫</div>
                                    </div>
                                </div>
                            }
                        </div>

                        <!-- Price Breakdown Footer -->
                        <div class="card-footer bg-white border-top px-4 py-3">
                            <div class="d-flex justify-content-between align-items-start flex-wrap gap-3">
                                <!-- Action Buttons -->
                                <div class="d-flex gap-2 flex-wrap align-items-center">
                                    @if (order.Status == OrderStatus.Pending)
                                    {
                                        <form asp-controller="Account" asp-action="CancelOrder" method="post"
                                              onsubmit="return confirm('Bạn chắc chắn muốn hủy đơn #@order.Id?')">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@order.Id" />
                                            <button type="submit" class="btn btn-outline-danger btn-sm rounded-pill px-3">
                                                <i class="bi bi-x-circle me-1"></i>Hủy đơn
                                            </button>
                                        </form>
                                    }
                                    @if (order.Status == OrderStatus.Completed)
                                    {
                                        <form asp-controller="Cart" asp-action="Reorder" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="orderId" value="@order.Id" />
                                            <button type="submit" class="btn btn-outline-primary btn-sm rounded-pill px-3" title="Mua lại toàn bộ sản phẩm trong đơn này">
                                                <i class="bi bi-bag-plus me-1"></i>Mua lại
                                            </button>
                                        </form>
                                        <a href="#" class="btn btn-outline-warning btn-sm rounded-pill px-3 btn-review-order"
                                           data-products='@System.Text.Json.JsonSerializer.Serialize(order.OrderDetails.Select(d => new { id = d.ProductId, name = d.Product?.Name, image = d.Product?.ImagePath }))'>
                                            <i class="bi bi-star me-1"></i>Đánh giá
                                        </a>
                                    }
                                    @if (order.Status == OrderStatus.Shipping)
                                    {
                                        <span class="small text-muted fst-italic"><i class="bi bi-truck me-1"></i>Đơn đang trên đường giao đến bạn...</span>
                                    }
                                </div>

                                <!-- Price Summary -->
                                <div class="text-end">
                                    <div class="small text-muted">Tạm tính: @order.TotalAmount.ToString("N0") ₫</div>
                                    @if (order.ShippingFee > 0)
                                    {
                                        <div class="small text-muted">Phí vận chuyển: +@order.ShippingFee.ToString("N0") ₫</div>
                                    }
                                    @if (order.DiscountAmount > 0)
                                    {
                                        <div class="small text-success"><i class="bi bi-tags-fill me-1"></i>Giảm giá: -@order.DiscountAmount.ToString("N0") ₫</div>
                                    }
                                    <div class="fs-6 fw-bold text-danger mt-1">
                                        Thành tiền: @order.FinalAmount.ToString("N0") ₫
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            }
            
            <div id="paginationContainer" class="mt-4"></div>
        </div>
    </div>
</div>

<!-- Review Modal -->
<div class="modal fade" id="reviewModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content border-0 shadow rounded-4 overflow-hidden">
            <div class="modal-header bg-warning bg-opacity-10 border-0">
                <h5 class="modal-title fw-bold text-dark"><i class="bi bi-star-fill text-warning me-2"></i>Đánh giá sản phẩm</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-4 bg-light" id="reviewModalBody" style="max-height: 70vh; overflow-y: auto;">
                <!-- Products will be injected here via JS -->
            </div>
        </div>
    </div>
</div>

<style>
    .order-item-row:hover { background-color: rgba(13, 110, 253, 0.03); }
</style>

@section Scripts {
<script>
    document.addEventListener("DOMContentLoaded", function () {
        const PAGE_SIZE = 5;
        let currentPage = 1;
        const items = Array.from(document.querySelectorAll('.order-card'));
        const totalItems = items.length;
        const totalPages = Math.max(1, Math.ceil(totalItems / PAGE_SIZE));
        
        function renderPage(page) {
            currentPage = page;
            const start = (page - 1) * PAGE_SIZE;
            const end = start + PAGE_SIZE;

            items.forEach((item, index) => {
                if (index >= start && index < end) {
                    item.style.display = '';
                } else {
                    item.style.display = 'none';
                }
            });

            renderPagination();
        }

        function renderPagination() {
            const container = document.getElementById('paginationContainer');
            if (totalPages <= 1) {
                container.innerHTML = '';
                return;
            }

            const startIdx = (currentPage - 1) * PAGE_SIZE + 1;
            const endIdx = Math.min(currentPage * PAGE_SIZE, totalItems);

            let pagesHtml = '';
            for (let i = 1; i <= totalPages; i++) {
                pagesHtml += `<li class="page-item ${i === currentPage ? 'active' : ''}">
                    <a class="page-link border-0 shadow-sm mx-1 rounded-3" href="#" data-page="${i}">${i}</a>
                </li>`;
            }

            container.innerHTML = `
                <div class="d-flex justify-content-between align-items-center bg-white p-3 rounded-4 shadow-sm border-0">
                    <small class="text-muted">Hiển thị <strong>${startIdx}–${endIdx}</strong> / ${totalItems} đơn hàng</small>
                    <nav>
                        <ul class="pagination pagination-sm mb-0 gap-1">
                            <li class="page-item ${currentPage === 1 ? 'disabled' : ''}">
                                <a class="page-link border-0 shadow-sm rounded-3" href="#" data-page="${currentPage - 1}">‹</a>
                            </li>
                            ${pagesHtml}
                            <li class="page-item ${currentPage === totalPages ? 'disabled' : ''}">
                                <a class="page-link border-0 shadow-sm rounded-3" href="#" data-page="${currentPage + 1}">›</a>
                            </li>
                        </ul>
                    </nav>
                </div>
            `;

            container.querySelectorAll('.page-link').forEach(link => {
                link.addEventListener('click', function(e) {
                    e.preventDefault();
                    if (this.parentElement.classList.contains('disabled')) return;
                    const page = parseInt(this.getAttribute('data-page'));
                    if (page >= 1 && page <= totalPages) {
                        renderPage(page);
                        window.scrollTo({ top: 0, behavior: 'smooth' });
                    }
                });
            });
        }

        if (totalItems > 0) {
            renderPage(1);
        }

        // Review Logic
        const reviewModalElement = document.getElementById('reviewModal');
        let reviewModal;
        if(reviewModalElement) {
            reviewModal = new bootstrap.Modal(reviewModalElement);
        }

        document.querySelectorAll('.btn-review-order').forEach(btn => {
            btn.addEventListener('click', function(e) {
                e.preventDefault();
                const productsJson = this.getAttribute('data-products');
                let products = [];
                try {
                    products = JSON.parse(productsJson);
                } catch(err) { console.error("Parse JSON error", err); }

                const modalBody = document.getElementById('reviewModalBody');
                modalBody.innerHTML = ''; // clear

                if(products.length === 0) {
                    modalBody.innerHTML = '<p class="text-center text-muted">Không có sản phẩm nào để đánh giá.</p>';
                    reviewModal.show();
                    return;
                }

                products.forEach(p => {
                    const pDiv = document.createElement('div');
                    pDiv.className = 'card border-0 shadow-sm rounded-4 mb-3';
                    pDiv.innerHTML = `
                        <div class="card-body p-3">
                            <div class="d-flex align-items-center mb-3">
                                <img src="${p.image || '/images/no-image.png'}" alt="${p.name}" class="rounded-3 object-fit-cover me-3 shadow-sm" style="width: 60px; height: 60px;">
                                <h6 class="mb-0 fw-semibold text-dark line-clamp-2">${p.name}</h6>
                            </div>
                            
                            <div class="d-flex align-items-center mb-2 star-rating-container" data-product-id="${p.id}">
                                <span class="me-2 text-muted small">Chất lượng:</span>
                                <div class="stars" style="cursor: pointer;">
                                    ${[1,2,3,4,5].map(i => `<i class="bi bi-star fs-4 text-warning star-item" data-value="${i}"></i>`).join('')}
                                </div>
                                <span class="ms-3 rating-text fw-bold text-warning" style="font-size: 0.9rem;"></span>
                            </div>
                            
                            <textarea class="form-control bg-light border-0 mb-2 review-content" rows="2" placeholder="Hãy chia sẻ nhận xét của bạn về sản phẩm này nhé..."></textarea>
                            
                            <div class="text-end d-flex align-items-center justify-content-end gap-2">
                                <span class="submit-msg text-success small d-none"><i class="bi bi-check-circle-fill"></i> Đã lưu</span>
                                <button class="btn btn-warning rounded-pill px-4 fw-bold btn-submit-review text-white" data-product-id="${p.id}">Gửi đánh giá</button>
                            </div>
                        </div>
                    `;
                    modalBody.appendChild(pDiv);

                    fetch(`/api/Review/my/${p.id}`)
                        .then(res => res.json())
                        .then(data => {
                            if(data.success && data.data) {
                                const rev = data.data;
                                setStars(pDiv, rev.rating);
                                pDiv.querySelector('.review-content').value = rev.content || '';
                                pDiv.querySelector('.btn-submit-review').textContent = 'Cập nhật đánh giá';
                            }
                        })
                        .catch(err => console.error(err));

                    let currentRating = 0;
                    const stars = pDiv.querySelectorAll('.star-item');
                    const textSpan = pDiv.querySelector('.rating-text');
                    const texts = ['Tệ', 'Không hài lòng', 'Bình thường', 'Hài lòng', 'Tuyệt vời'];

                    function setStars(container, rating) {
                        currentRating = rating;
                        const cStars = container.querySelectorAll('.star-item');
                        cStars.forEach(s => {
                            let val = parseInt(s.getAttribute('data-value'));
                            if(val <= rating) {
                                s.classList.remove('bi-star');
                                s.classList.add('bi-star-fill');
                            } else {
                                s.classList.remove('bi-star-fill');
                                s.classList.add('bi-star');
                            }
                        });
                        if(rating > 0) {
                            textSpan.textContent = texts[rating-1];
                        } else {
                            textSpan.textContent = '';
                        }
                    }

                    stars.forEach(s => {
                        s.addEventListener('mouseover', function() {
                            let val = parseInt(this.getAttribute('data-value'));
                            const cStars = pDiv.querySelectorAll('.star-item');
                            cStars.forEach(st => {
                                let stVal = parseInt(st.getAttribute('data-value'));
                                if(stVal <= val) {
                                    st.classList.remove('bi-star');
                                    st.classList.add('bi-star-fill');
                                } else {
                                    st.classList.remove('bi-star-fill');
                                    st.classList.add('bi-star');
                                }
                            });
                            textSpan.textContent = texts[val-1];
                        });
                        
                        s.parentElement.addEventListener('mouseleave', function() {
                            setStars(pDiv, currentRating);
                        });

                        s.addEventListener('click', function() {
                            currentRating = parseInt(this.getAttribute('data-value'));
                            setStars(pDiv, currentRating);
                        });
                    });

                    const submitBtn = pDiv.querySelector('.btn-submit-review');
                    submitBtn.addEventListener('click', function() {
                        if(currentRating === 0) {
                            alert('Vui lòng chọn số sao để đánh giá!');
                            return;
                        }
                        const content = pDiv.querySelector('.review-content').value;
                        const formData = new FormData();
                        formData.append('productId', p.id);
                        formData.append('rating', currentRating);
                        formData.append('content', content);

                        submitBtn.disabled = true;
                        const originalText = submitBtn.textContent;
                        submitBtn.innerHTML = '<span class="spinner-border spinner-border-sm"></span> Đang lưu...';

                        fetch('/api/Review/add', {
                            method: 'POST',
                            body: formData
                        })
                        .then(res => res.json())
                        .then(resData => {
                            submitBtn.disabled = false;
                            if(resData.success) {
                                submitBtn.textContent = 'Cập nhật đánh giá';
                                
                                // 1. Đóng Modal tự động
                                reviewModal.hide();
                                
                                // 2. Hiển thị Toast nhỏ gọn, tinh tế
                                if (typeof Swal !== 'undefined') {
                                    Swal.fire({
                                        toast: true,
                                        position: 'top-end',
                                        icon: 'success',
                                        title: resData.message || 'Cập nhật đánh giá thành công!',
                                        showConfirmButton: false,
                                        timer: 3000,
                                        width: 'auto',
                                        padding: '0.5em 1em',
                                        customClass: {
                                            popup: 'shadow-sm border-0'
                                        }
                                    });
                                } else {
                                    alert('Đánh giá thành công!');
                                }
                            } else {
                                if (typeof Swal !== 'undefined') {
                                    Swal.fire({
                                        toast: true,
                                        position: 'top-end',
                                        icon: 'error',
                                        title: resData.message || 'Đã có lỗi xảy ra',
                                        showConfirmButton: false,
                                        timer: 3000,
                                        width: 'auto',
                                        padding: '0.5em 1em',
                                        customClass: { popup: 'shadow-sm border-0' }
                                    });
                                } else {
                                    alert(resData.message || 'Có lỗi xảy ra');
                                }
                                submitBtn.textContent = originalText;
                            }
                        })
                        .catch(err => {
                            submitBtn.disabled = false;
                            submitBtn.textContent = originalText;
                            alert('Lỗi kết nối mạng');
                        });
                    });
                });

                reviewModal.show();
            });
        });
    });
</script>
}
