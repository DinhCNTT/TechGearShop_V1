<nav class="navbar navbar-expand-lg navbar-dark bg-primary shadow-sm">
    <div class="container">
        <a class="navbar-brand fw-bold fs-3" asp-area="" asp-controller="Home" asp-action="Index">
            <i class="bi bi-cpu"></i> TechGear
        </a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navbarNav">
            <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                <li class="nav-item">
                    <a class="nav-link text-white fw-semibold" asp-area="" asp-controller="Home" asp-action="Index">Trang Chủ</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link text-white fw-semibold" asp-controller="Product" asp-action="Index">Tất Cả Sản Phẩm</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link text-white fw-semibold" asp-controller="Product" asp-action="Index" asp-route-sortOrder="price_desc">Khuyến Mãi</a>
                </li>
            </ul>

            <form class="d-flex me-3" role="search" asp-controller="Home" asp-action="Index" method="get">
                <input class="form-control me-2 rounded-pill border-0 shadow-sm px-4" type="search" name="keyword" placeholder="Tìm kiếm linh kiện..." aria-label="Search">
                <button class="btn btn-warning rounded-pill px-3 shadow-sm text-dark fw-bold" type="submit"><i class="bi bi-search"></i></button>
            </form>

            @using TechGearShop_V1.Extensions
@using TechGearShop_V1.Models.ViewModels
@inject Microsoft.AspNetCore.Http.IHttpContextAccessor HttpContextAccessor

@{
    var cartItems = HttpContextAccessor.HttpContext?.Session.Get<List<CartItem>>("shopping_cart") ?? new List<CartItem>();
    int cartCount = cartItems.Count;
}
<ul class="navbar-nav d-flex align-items-center">
    <!-- Custom Language Switcher (hides the ugly Google widget off-screen) -->
    <li class="nav-item dropdown me-2" id="lang-switcher">
        <a class="nav-link dropdown-toggle text-white d-flex align-items-center gap-1" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
            <span id="active-lang-flag">🇻🇳</span>
            <span id="active-lang-text" class="fw-semibold small">VI</span>
        </a>
        <ul class="dropdown-menu dropdown-menu-end shadow border-0 rounded-3 py-2" style="min-width:130px;">
            <li>
                <button class="dropdown-item d-flex align-items-center gap-2 rounded-2 py-2" onclick="switchLang('vi','🇻🇳','VI')">
                    <span>🇻🇳</span> Tiếng Việt
                </button>
            </li>
            <li>
                <button class="dropdown-item d-flex align-items-center gap-2 rounded-2 py-2" onclick="switchLang('en','🇬🇧','EN')">
                    <span>🇬🇧</span> English
                </button>
            </li>
        </ul>
    </li>
    <!-- Hidden Google Translate mount point (off-screen) -->
    <div id="google_translate_element" style="position:absolute;top:-9999px;left:-9999px;"></div>

    <li class="nav-item me-2">
        <a class="nav-link text-white position-relative" asp-area="" asp-controller="Cart" asp-action="Index">
            <i class="bi bi-cart3 fs-5"></i>
            @if (cartCount > 0)
            {
                <span class="position-absolute top-10 start-100 translate-middle badge rounded-pill bg-danger">
                    @cartCount
                    <span class="visually-hidden">sản phẩm trong giỏ</span>
                </span>
            }
        </a>
    </li>
                <!-- Dynamic Auth Dropdown: Đọc từ Cookie Claims -->
                <li class="nav-item dropdown">
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <a class="nav-link dropdown-toggle text-white d-flex align-items-center gap-1" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                            <i class="bi bi-person-circle fs-5"></i>
                            <span class="d-none d-lg-inline small">@User.Identity.Name</span>
                        </a>
                        <ul class="dropdown-menu dropdown-menu-end shadow border-0 rounded-3">
                            <li><h6 class="dropdown-header text-muted">Xin chào, @User.Identity.Name!</h6></li>
                            @if (User.IsInRole("Admin"))
                            {
                                <li><a class="dropdown-item" asp-area="Admin" asp-controller="Dashboard" asp-action="Index"><i class="bi bi-speedometer2 me-2 text-primary"></i>Trang Quản Trị</a></li>
                                <li><hr class="dropdown-divider"></li>
                            }
                            <li><a class="dropdown-item" href="/Account/Profile"><i class="bi bi-person me-2"></i>Hồ sơ của tôi</a></li>
                            <li><a class="dropdown-item" href="/Account/Orders"><i class="bi bi-box-seam me-2"></i>Đơn hàng của tôi</a></li>
                            <li><hr class="dropdown-divider"></li>
                            <li>
                                <form asp-controller="Account" asp-action="Logout" method="post">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="dropdown-item text-danger">
                                        <i class="bi bi-box-arrow-right me-2"></i>Đăng xuất
                                    </button>
                                </form>
                            </li>
                        </ul>
                    }
                    else
                    {
                        <a class="nav-link dropdown-toggle text-white" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                            <i class="bi bi-person-circle fs-5"></i>
                        </a>
                        <ul class="dropdown-menu dropdown-menu-end shadow border-0 rounded-3">
                            <li><a class="dropdown-item fw-semibold" asp-controller="Account" asp-action="Login"><i class="bi bi-box-arrow-in-right me-2 text-primary"></i>Đăng nhập</a></li>
                            <li><a class="dropdown-item" asp-controller="Account" asp-action="Register"><i class="bi bi-person-plus me-2 text-success"></i>Đăng ký tài khoản</a></li>
                        </ul>
                    }
                </li>
            </ul>
        </div>
    </div>
</nav>
