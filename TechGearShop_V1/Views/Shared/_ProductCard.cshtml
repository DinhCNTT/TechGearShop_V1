@model TechGearShop_V1.Models.Entities.Product

<div class="card product-card h-100 position-relative">
    @if (Model.PromotionalPrice.HasValue)
    {
        <span class="badge bg-danger position-absolute top-0 start-0 m-2 z-1">Giảm giá</span>
    }
    
    <a href="/Product/Detail/@Model.Id">
        @if (!string.IsNullOrEmpty(Model.ImagePath))
        {
            <img src="@Model.ImagePath" class="card-img-top p-2" alt="@Model.Name">
        }
        else
        {
            <div class="bg-secondary text-white d-flex align-items-center justify-content-center card-img-top p-2" style="height: 200px;">
                <i class="bi bi-image" style="font-size: 3rem;"></i>
            </div>
        }
    </a>
    
    <div class="card-body d-flex flex-column">
        <div class="mb-2">
            <span class="badge bg-light text-dark border">@Model.Brand</span>
        </div>
        <h5 class="card-title line-clamp-2 fs-6">
            <a href="/Product/Detail/@Model.Id" class="text-decoration-none text-dark">@Model.Name</a>
        </h5>
        
        <div class="mt-auto pt-3">
            @if (Model.PromotionalPrice.HasValue)
            {
                <div class="price-text">@Model.PromotionalPrice.Value.ToString("N0") đ</div>
                <div class="text-muted text-decoration-line-through small">@Model.Price.ToString("N0") đ</div>
            }
            else
            {
                <div class="price-text">@Model.Price.ToString("N0") đ</div>
            }
        </div>
        
        <div class="mt-3">
            @if (Model.Stock > 0)
            {
                <!-- Form Add to Cart -->
                <form asp-controller="Cart" asp-action="Add" asp-route-productId="@Model.Id" method="post" class="d-grid gap-2 ajax-add-to-cart">
                    <button type="submit" class="btn btn-outline-primary btn-hover-zoom">
                        <i class="bi bi-cart-plus"></i> Thêm giỏ hàng
                    </button>
                </form>
            }
            else
            {
                <button class="btn btn-secondary w-100 disabled" disabled>Tạm hết hàng</button>
            }
        </div>
    </div>
</div>
