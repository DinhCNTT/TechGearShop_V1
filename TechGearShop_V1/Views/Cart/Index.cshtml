@model List<TechGearShop_V1.Models.ViewModels.CartItem>

@{
    ViewData["Title"] = "Giỏ hàng của bạn";
    // Tạm tính ban đầu = 0 vì chưa có item nào được check
    decimal totalCartPrice = 0;
}

<div class="row">
    <div class="col-md-8 mb-4">
        <div class="card shadow-sm">
            <div class="card-header bg-white py-3">
                <h5 class="mb-0 fw-bold"><i class="bi bi-cart3"></i> Giỏ hàng (@Model.Count sản phẩm)</h5>
            </div>
            <div class="card-body">
                @if (!Model.Any())
                {
                    <div class="text-center py-5">
                        <i class="bi bi-cart-x text-muted" style="font-size: 4rem;"></i>
                        <h4 class="mt-3 text-secondary">Giỏ hàng trống</h4>
                        <p>Tiếp tục mua sắm ngay thôi!</p>
                        <a href="/" class="btn btn-primary mt-2">Về trang chủ</a>
                    </div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table align-middle" id="cartTable">
                            <thead class="table-light">
                                <tr>
                                    <th style="width: 40px;">
                                        <input class="form-check-input" type="checkbox" id="selectAll" checked>
                                    </th>
                                    <th>Sản phẩm</th>
                                    <th>Đơn giá</th>
                                    <th style="width: 150px;">Số lượng</th>
                                    <th>Thành tiền</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model)
                                {
                                    decimal totalItemPrice = item.Price * item.Quantity;
                                    <tr>
                                        <td>
                                            <input class="form-check-input item-check" type="checkbox" name="selectedItems" value="@item.ProductId" data-price="@item.Price" data-quantity="@item.Quantity" checked form="checkoutForm">
                                        </td>
                                        <td>
                                            <a href="@Url.Action("Detail", "Product", new { id = item.ProductId })" class="d-flex align-items-center text-dark text-decoration-none">
                                                @if (!string.IsNullOrEmpty(item.ImagePath))
                                                {
                                                    <img src="@item.ImagePath" class="rounded me-3 object-fit-cover" width="60" height="60" alt="@item.ProductName" />
                                                }
                                                <span class="fw-semibold">@item.ProductName</span>
                                            </a>
                                        </td>
                                        <td class="text-danger fw-bold">@item.Price.ToString("N0")₫</td>
                                        <td>
                                            <form asp-controller="Cart" asp-action="UpdateQuantity" method="post">
                                                <input type="hidden" name="productId" value="@item.ProductId" />
                                                <div class="input-group border rounded" style="width: 120px; margin: 0 auto;">
                                                    <button class="btn btn-light border-0 px-2 text-secondary" type="button" onclick="this.parentNode.querySelector('input[type=number]').stepDown(); this.form.submit();"><i class="bi bi-dash"></i></button>
                                                    <input type="number" name="quantity" class="form-control border-0 text-center px-0 bg-white fw-bold" value="@item.Quantity" min="1" max="99" readonly>
                                                    <button class="btn btn-light border-0 px-2 text-secondary" type="button" onclick="this.parentNode.querySelector('input[type=number]').stepUp(); this.form.submit();"><i class="bi bi-plus"></i></button>
                                                </div>
                                            </form>
                                        </td>
                                        <td class="fw-bold item-total-price">@totalItemPrice.ToString("N0")₫</td>
                                        <td class="text-end">
                                            <form asp-controller="Cart" asp-action="Remove" method="post">
                                                <input type="hidden" name="productId" value="@item.ProductId" />
                                                <button type="submit" class="btn btn-sm btn-outline-danger" title="Xóa">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            </form>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                    <div class="d-flex justify-content-between align-items-center mt-3 pt-3 border-top">
                        <form asp-controller="Cart" asp-action="Clear" method="post" onsubmit="return confirm('Bạn có chắc muốn xóa toàn bộ giỏ hàng?');">
                            <button type="submit" class="btn btn-outline-secondary btn-sm"><i class="bi bi-trash3"></i> Xóa tất cả</button>
                        </form>
                        <a href="/" class="btn btn-outline-primary"><i class="bi bi-arrow-left"></i> Tiếp tục mua hàng</a>
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- Tóm tắt đơn hàng -->
    <div class="col-md-4">
        <div class="card shadow-sm border-0 bg-light">
            <div class="card-body">
                <h5 class="fw-bold mb-4">Tóm tắt đơn hàng</h5>
                <div class="d-flex justify-content-between mb-3">
                    <span class="text-muted">Tạm tính:</span>
                    <span class="fw-bold" id="subtotalDisplay">0 đ</span>
                </div>
                <div class="d-flex justify-content-between mb-3">
                    <span class="text-muted">Phí Giao Hàng:</span>
                    <span class="fw-bold text-success">Miễn phí</span>
                </div>
                <hr>
                <div class="d-flex justify-content-between mb-4">
                    <span class="fw-bold fs-5">Tổng tiền:</span>
                    <span class="fw-bold fs-4 text-danger" id="cartTotalDisplay">@totalCartPrice.ToString("N0") đ</span>
                </div>
                
                @if (Model.Any())
                {
                    <form id="checkoutForm" asp-controller="Cart" asp-action="Checkout" method="post">
                        @Html.AntiForgeryToken()
                        <!-- Hidden inputs được tạo bằng JS khi submit -->
                        <div id="selectedInputsContainer"></div>
                        <button type="submit" id="btnCheckout" class="btn btn-danger btn-lg w-100 fw-bold shadow-sm">
                            TIẾN HÀNH THANH TOÁN <i class="bi bi-arrow-right-circle ms-2"></i>
                        </button>
                    </form>
                }
                else
                {
                    <button class="btn btn-secondary btn-lg w-100 fw-bold disabled" disabled>GIỎ HÀNG TRỐNG</button>
                }
                
                <div class="mt-4 payment-methods text-center">
                    <p class="text-muted small mb-2">Chấp nhận thanh toán</p>
                    <div class="d-flex justify-content-center gap-2 text-primary fs-3">
                        <i class="bi bi-credit-card-fill"></i>
                        <i class="bi bi-cash"></i>
                        <i class="bi bi-paypal"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function() {
            // Hiển thị cảnh báo từ Server nếu UpdateQuantity vượt quá giới hạn Stock
            @if (TempData["StockWarning"] != null)
            {
                <text>
                Swal.fire({
                    icon: 'warning',
                    title: 'Gián đoạn thao tác',
                    text: '@Html.Raw(TempData["StockWarning"])',
                    confirmButtonColor: '#dc3545',
                    confirmButtonText: 'Đã hiểu'
                });
                </text>
            }

            // Logic tính tổng tiền giỏ hàng theo Select
            const selectAll = document.getElementById('selectAll');
            const itemCheckboxes = document.querySelectorAll('.item-check');
            const totalDisplay = document.getElementById('cartTotalDisplay');
            const subtotalDisplay = document.querySelector('.card-body .fw-bold:nth-child(2)'); // Tạm tính element
            const btnCheckout = document.getElementById('btnCheckout');

            function calculateTotal() {
                let total = 0;
                let checkedCount = 0;
                
                itemCheckboxes.forEach(cb => {
                    if (cb.checked) {
                        const price = parseFloat(cb.getAttribute('data-price'));
                        const quantity = parseInt(cb.getAttribute('data-quantity'));
                        total += price * quantity;
                        checkedCount++;
                    }
                });

                // Cập nhật Tạm tính & Tổng tiền
                const formattedTotal = new Intl.NumberFormat('vi-VN').format(total) + ' đ';
                if (totalDisplay) totalDisplay.textContent = formattedTotal;
                const subtotalEl = document.getElementById('subtotalDisplay');
                if (subtotalEl) subtotalEl.textContent = formattedTotal;

                // Đồng bộ SelectAll
                if (selectAll) {
                    selectAll.checked = (checkedCount === itemCheckboxes.length && itemCheckboxes.length > 0);
                }

                // Vô hiệu hóa nút Thanh toán nếu không chọn sp nào (<a> tag dùng CSS)
                if (btnCheckout) {
                    if (checkedCount === 0) {
                        btnCheckout.classList.add('disabled');
                        btnCheckout.setAttribute('aria-disabled', 'true');
                    } else {
                        btnCheckout.classList.remove('disabled');
                        btnCheckout.removeAttribute('aria-disabled');
                    }
                }
            }

            // Gắn event
            if (selectAll) {
                selectAll.addEventListener('change', function() {
                    itemCheckboxes.forEach(cb => cb.checked = selectAll.checked);
                    calculateTotal();
                });
            }

            itemCheckboxes.forEach(cb => {
                cb.addEventListener('change', calculateTotal);
            });

            // Tính toán lần đầu (mặc định checked hết khi tải trang)
            calculateTotal();

            // Trước khi submit form Checkout: Build hidden inputs từ checkboxes được tick
            const checkoutForm = document.getElementById('checkoutForm');
            if (checkoutForm) {
                checkoutForm.addEventListener('submit', function(e) {
                    const selectedIds = Array.from(itemCheckboxes)
                        .filter(cb => cb.checked)
                        .map(cb => cb.value);

                    if (selectedIds.length === 0) {
                        e.preventDefault();
                        alert('Vui lòng chọn ít nhất 1 sản phẩm!');
                        return;
                    }

                    // Build dynamic hidden inputs
                    const container = document.getElementById('selectedInputsContainer');
                    container.innerHTML = '';
                    selectedIds.forEach(id => {
                        const input = document.createElement('input');
                        input.type = 'hidden';
                        input.name = 'selectedItems';
                        input.value = id;
                        container.appendChild(input);
                    });
                });
            }
        });
    </script>
}
