@model TechGearShop_V1.Models.ViewModels.OrderListViewModel
@{
    ViewData["Title"] = "Quản lý Đơn hàng";
}

<div class="page-header mb-4">
    <h1><i class="bi bi-box-seam me-2 text-primary"></i>Quản lý Đơn hàng</h1>
</div>

<!-- Toolbar: Tabs & Search -->
<div class="card border-0 shadow-sm rounded-4 mb-4">
    <div class="card-body p-3">
        <form method="get" action="/Admin/Order" class="row g-3 align-items-center">
            <div class="col-md-7">
                <div class="d-flex flex-wrap gap-2 pb-1">
                    <a href="/Admin/Order" class="btn btn-sm rounded-pill px-3 @(Model.Status == null ? "btn-primary" : "btn-outline-secondary")">Tất cả</a>
                    <a href="/Admin/Order?status=PaymentPending" class="btn btn-sm rounded-pill px-3 @(Model.Status == TechGearShop_V1.Models.Entities.OrderStatus.PaymentPending ? "btn-warning text-dark" : "btn-outline-secondary")">Chờ thanh toán VNPay</a>
                    <a href="/Admin/Order?status=Pending" class="btn btn-sm rounded-pill px-3 @(Model.Status == TechGearShop_V1.Models.Entities.OrderStatus.Pending ? "btn-warning" : "btn-outline-secondary")">Chờ xử lý</a>
                    <a href="/Admin/Order?status=Processing" class="btn btn-sm rounded-pill px-3 @(Model.Status == TechGearShop_V1.Models.Entities.OrderStatus.Processing ? "btn-info" : "btn-outline-secondary")">Đang chuẩn bị</a>
                    <a href="/Admin/Order?status=Shipping" class="btn btn-sm rounded-pill px-3 @(Model.Status == TechGearShop_V1.Models.Entities.OrderStatus.Shipping ? "btn-primary" : "btn-outline-secondary")">Đang giao</a>
                    <a href="/Admin/Order?status=Completed" class="btn btn-sm rounded-pill px-3 @(Model.Status == TechGearShop_V1.Models.Entities.OrderStatus.Completed ? "btn-success" : "btn-outline-secondary")">Hoàn thành</a>
                    <a href="/Admin/Order?status=Cancelled" class="btn btn-sm rounded-pill px-3 @(Model.Status == TechGearShop_V1.Models.Entities.OrderStatus.Cancelled ? "btn-danger" : "btn-outline-secondary")">Đã hủy</a>
                </div>
            </div>
            <div class="col-md-5">
                <div class="input-group">
                    <input type="hidden" name="status" value="@Model.Status" />
                    <input type="text" name="searchKeyword" value="@Model.SearchKeyword" class="form-control bg-light border-0" placeholder="Nhập mã đơn, tên hoặc email khách hàng..." />
                    <button type="submit" class="btn btn-primary"><i class="bi bi-search"></i> Tìm</button>
                </div>
            </div>
        </form>
    </div>
</div>

<div class="admin-table-wrap">
    <table class="table admin-table mb-0">
        <thead>
            <tr>
                <th style="width:80px">Mã Đơn</th>
                <th style="width:150px">Ngày Đặt</th>
                <th>Khách Hàng</th>
                <th style="width:150px">Tổng Tiền</th>
                <th style="width:150px">Thanh Toán</th>
                <th style="width:130px">Trạng Thái</th>
                <th style="width:100px" class="text-end pe-3">Hành Động</th>
            </tr>
        </thead>
                <tbody>
                    @foreach (var o in Model.Orders)
                    {
                        <tr>
                            <td>
                                <span class="fw-semibold text-dark">#@o.Id</span>
                            </td>
                            <td>@o.OrderDate.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</td>
                            <td>
                                <div class="fw-semibold text-dark">@o.User?.Username</div>
                                <div class="text-muted" style="font-size:0.75rem;">@o.User?.Email</div>
                            </td>
                            <td><span class="text-danger fw-bold">@o.FinalAmount.ToString("N0") ₫</span></td>
                            <td>
                                @if (o.PaymentMethod == TechGearShop_V1.Models.Entities.PaymentMethod.VNPay)
                                {
                                    if (o.PaymentStatus == TechGearShop_V1.Models.Entities.PaymentStatus.Paid)
                                    {
                                        <span class="badge bg-success bg-opacity-10 text-success border border-success"><i class="bi bi-credit-card me-1"></i> VNPay (Đã TT)</span>
                                    }
                                    else if (o.PaymentStatus == TechGearShop_V1.Models.Entities.PaymentStatus.Failed)
                                    {
                                        <span class="badge bg-danger bg-opacity-10 text-danger border border-danger"><i class="bi bi-x-circle me-1"></i> VNPay (Lỗi)</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-warning bg-opacity-10 text-warning border border-warning"><i class="bi bi-clock me-1"></i> VNPay (Chưa TT)</span>
                                    }
                                }
                                else
                                {
                                    <span class="badge bg-secondary bg-opacity-10 text-secondary border border-secondary"><i class="bi bi-cash me-1"></i> COD</span>
                                }
                            </td>
                            <td>
                                @switch (o.Status)
                                {
                                    case TechGearShop_V1.Models.Entities.OrderStatus.PaymentPending:
                                        <span class="badge bg-warning text-dark"><i class="bi bi-hourglass-split me-1"></i> Chờ TT VNPay</span>
                                        break;
                                    case TechGearShop_V1.Models.Entities.OrderStatus.Pending:
                                        <span class="badge bg-warning text-dark"><i class="bi bi-clock me-1"></i> Chờ xử lý</span>
                                        break;
                                    case TechGearShop_V1.Models.Entities.OrderStatus.Processing:
                                        <span class="badge bg-info text-dark"><i class="bi bi-arrow-repeat me-1"></i> Đang chuẩn bị</span>
                                        break;
                                    case TechGearShop_V1.Models.Entities.OrderStatus.Shipping:
                                        <span class="badge bg-primary"><i class="bi bi-truck me-1"></i> Đang giao</span>
                                        break;
                                    case TechGearShop_V1.Models.Entities.OrderStatus.Completed:
                                        <span class="badge bg-success"><i class="bi bi-check-circle me-1"></i> Hoàn thành</span>
                                        break;
                                    case TechGearShop_V1.Models.Entities.OrderStatus.Cancelled:
                                        <span class="badge bg-danger"><i class="bi bi-x-circle me-1"></i> Đã hủy</span>
                                        break;
                                }
                            </td>
                            <td class="text-end pe-3">
                                <a asp-action="Detail" asp-route-id="@o.Id" class="btn-icon btn-icon-view" title="Chi tiết đơn hàng">
                                    <i class="bi bi-eye-fill"></i>
                                </a>
                            </td>
                        </tr>
                    }
                    @if (!Model.Orders.Any())
                    {
                        <tr>
                            <td colspan="6" class="text-center text-muted py-5">
                                <i class="bi bi-inbox fs-1 opacity-30 d-block mb-2"></i>
                                Không tìm thấy đơn hàng nào.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        
        <!-- Pagination -->
        @if (Model.TotalPages > 1)
        {
            <div class="p-3 border-top d-flex justify-content-between align-items-center">
                <small class="text-muted">Hiển thị @Model.Orders.Count() / @Model.TotalItems đơn hàng</small>
                <nav aria-label="Page navigation">
                    <ul class="pagination pagination-sm m-0">
                        @for (int i = 1; i <= Model.TotalPages; i++)
                        {
                            <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                                <a class="page-link" href="/Admin/Order?page=@i&searchKeyword=@Model.SearchKeyword&status=@Model.Status">@i</a>
                            </li>
                        }
                    </ul>
                </nav>
            </div>
        }
    </div>
</div>
