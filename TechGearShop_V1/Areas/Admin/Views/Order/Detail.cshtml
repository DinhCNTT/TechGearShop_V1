@model TechGearShop_V1.Models.Entities.Order
@{
    ViewData["Title"] = $"Chi tiết đơn #{Model.Id}";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold m-0"><i class="bi bi-receipt me-2 text-primary"></i>Chi tiết Đơn hàng #@Model.Id</h2>
    <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4"><i class="bi bi-arrow-left me-2"></i>Quay lại</a>
</div>

<div class="row gx-4">
    <div class="col-md-8">
        <!-- Danh sách sản phẩm -->
        <div class="card border-0 shadow-sm rounded-4 mb-4">
            <div class="card-header bg-white pt-4 pb-2 border-bottom-0">
                <h5 class="fw-bold">Danh sách mặt hàng</h5>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th class="ps-4">Sản Phẩm</th>
                                <th>Đơn Giá</th>
                                <th>SL</th>
                                <th class="text-end pe-4">Thành Tiền</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach(var item in Model.OrderDetails)
                            {
                                <tr>
                                    <td class="ps-4">
                                        <div class="d-flex align-items-center gap-3">
                                            <img src="@(string.IsNullOrEmpty(item.Product?.ImagePath) ? "/images/placeholder.jpg" : item.Product.ImagePath)" width="50" height="50" class="rounded object-fit-cover shadow-sm border" />
                                            <span class="fw-semibold">@item.Product?.Name</span>
                                        </div>
                                    </td>
                                    <td>@item.UnitPrice.ToString("N0") ₫</td>
                                    <td>x @item.Quantity</td>
                                    <td class="text-end pe-4 fw-bold text-danger">@((item.UnitPrice * item.Quantity).ToString("N0")) ₫</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <!-- Thông tin Khách hàng -->
        <div class="card border-0 shadow-sm rounded-4 mb-4">
            <div class="card-body">
                <h5 class="fw-bold mb-3"><i class="bi bi-person-fill text-muted me-2"></i>Thông tin Khách Hàng</h5>
                <hr />
                <p class="mb-1"><strong>Tài khoản:</strong> @Model.User?.Username</p>
                <p class="mb-1"><strong>Email:</strong> @Model.User?.Email</p>
                <p class="mb-0"><strong>Ngày đặt:</strong> @Model.OrderDate.ToString("dd/MM/yyyy HH:mm")</p>
            </div>
        </div>

        <!-- Trạng thái & Action -->
        <div class="card border-0 shadow-sm rounded-4 mb-4">
            <div class="card-body">
                <h5 class="fw-bold mb-3"><i class="bi bi-activity text-primary me-2"></i>Cập nhật Trạng thái</h5>
                <hr />
                <form asp-action="UpdateStatus" method="post">
                    <input type="hidden" name="orderId" value="@Model.Id" />
                    <div class="mb-3">
                        <select name="status" class="form-select bg-light border-0 fw-semibold">
                            <option value="Pending" selected="@(Model.Status == TechGearShop_V1.Models.Entities.OrderStatus.Pending)">Chờ xử lý</option>
                            <option value="Processing" selected="@(Model.Status == TechGearShop_V1.Models.Entities.OrderStatus.Processing)">Đang chuẩn bị hàng</option>
                            <option value="Shipping" selected="@(Model.Status == TechGearShop_V1.Models.Entities.OrderStatus.Shipping)">Đang giao hàng</option>
                            <option value="Completed" selected="@(Model.Status == TechGearShop_V1.Models.Entities.OrderStatus.Completed)">Đã giao thành công</option>
                            <option value="Cancelled" selected="@(Model.Status == TechGearShop_V1.Models.Entities.OrderStatus.Cancelled)">Hủy đơn</option>
                        </select>
                    </div>
                    <button type="submit" class="btn btn-primary w-100 rounded-pill fw-bold">Cập Nhật & Lưu</button>
                </form>
            </div>
        </div>

        <!-- Thanh toán -->
        <div class="card border-0 shadow-sm rounded-4 bg-light">
            <div class="card-body">
                <div class="d-flex justify-content-between mb-2">
                    <span class="text-muted">Tổng tiền hàng:</span>
                    <span class="fw-semibold">@Model.TotalAmount.ToString("N0") ₫</span>
                </div>
                <div class="d-flex justify-content-between mb-2">
                    <span class="text-muted">Phí vận chuyển:</span>
                    <span class="fw-semibold">@Model.ShippingFee.ToString("N0") ₫</span>
                </div>
                <hr />
                <div class="d-flex justify-content-between align-items-center">
                    <span class="fw-bold fs-5">Khách phải trả:</span>
                    <span class="fw-bold fs-3 text-danger">@((Model.TotalAmount + Model.ShippingFee).ToString("N0")) ₫</span>
                </div>
            </div>
        </div>
    </div>
</div>
