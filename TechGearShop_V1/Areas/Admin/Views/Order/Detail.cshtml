@model TechGearShop_V1.Models.Entities.Order
@using TechGearShop_V1.Models.Entities
@{
    ViewData["Title"] = $"Chi tiết đơn #{Model.Id}";

    // Helper Functions for UI Colors
    string GetStatusColor(OrderStatus status) => status switch {
        OrderStatus.Pending => "warning",
        OrderStatus.Processing => "info",
        OrderStatus.Shipping => "primary",
        OrderStatus.Completed => "success",
        OrderStatus.Cancelled => "danger",
        _ => "secondary"
    };

    string GetStatusText(OrderStatus status) => status switch {
        OrderStatus.Pending => "Chờ Xử Lý",
        OrderStatus.Processing => "Đang Chuẩn Bị Hàng",
        OrderStatus.Shipping => "Đang Giao Hàng",
        OrderStatus.Completed => "Hoàn Thành",
        OrderStatus.Cancelled => "Đã Hủy",
        _ => "Không Xác Định"
    };
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="fw-bold m-0 d-flex align-items-center gap-3">
            <span>Chi tiết Đơn hàng #@Model.Id</span>
            <span class="badge bg-@GetStatusColor(Model.Status) bg-opacity-10 text-@GetStatusColor(Model.Status) fs-6 px-3 py-2 rounded-pill border border-@GetStatusColor(Model.Status)">
                <i class="bi bi-circle-fill small me-2"></i>@GetStatusText(Model.Status)
            </span>
        </h2>
        <p class="text-muted mt-2 mb-0"><i class="bi bi-clock me-1"></i> Ngày đặt: @Model.OrderDate.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</p>
    </div>
    <a asp-action="Index" class="btn btn-light border shadow-sm rounded-pill px-4 fw-semibold"><i class="bi bi-arrow-left me-2"></i>Quay lại</a>
</div>

<div class="row gx-4">
    <div class="col-xl-8 col-lg-7">
        <!-- Order Items Info -->
        <div class="card border-0 shadow-sm rounded-4 mb-4 overflow-hidden">
            <div class="card-header bg-white py-3 border-bottom d-flex align-items-center">
                <i class="bi bi-box-seam text-primary fs-5 me-2"></i>
                <h5 class="fw-bold m-0">Sản phẩm đặt mua (@Model.OrderDetails.Count)</h5>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table align-middle mb-0 table-hover">
                        <thead class="table-light text-muted small">
                            <tr>
                                <th class="ps-4 py-3 fw-semibold">SẢN PHẨM</th>
                                <th class="py-3 fw-semibold text-center">ĐƠN GIÁ</th>
                                <th class="py-3 fw-semibold text-center">SỐ LƯỢNG</th>
                                <th class="text-end pe-4 py-3 fw-semibold">THÀNH TIỀN</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach(var item in Model.OrderDetails)
                            {
                                <tr>
                                    <td class="ps-4 py-3">
                                        <div class="d-flex align-items-center gap-3">
                                            <div class="bg-light p-1 rounded border">
                                                <img src="@(string.IsNullOrEmpty(item.Product?.ImagePath) ? "/images/placeholder.jpg" : item.Product.ImagePath)" width="55" height="55" class="rounded object-fit-cover bg-white" />
                                            </div>
                                            <div>
                                                <div class="fw-bold text-dark fs-6">@item.Product?.Name</div>
                                                <small class="text-muted">Mã SP: #@item.ProductId</small>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="text-center">@item.UnitPrice.ToString("N0")₫</td>
                                    <td class="text-center fw-bold text-primary">x @item.Quantity</td>
                                    <td class="text-end pe-4 fw-bold text-dark">@((item.UnitPrice * item.Quantity).ToString("N0"))₫</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- Note section -->
        <div class="card border-0 shadow-sm rounded-4 mb-4">
            <div class="card-body p-4">
                <h6 class="fw-bold mb-3"><i class="bi bi-chat-left-text text-muted me-2"></i>Ghi chú của khách hàng</h6>
                @if (!string.IsNullOrWhiteSpace(Model.Note))
                {
                    <div class="p-3 bg-warning bg-opacity-10 text-dark rounded fw-medium">
                        @Model.Note
                    </div>
                }
                else
                {
                    <div class="p-3 bg-light rounded text-muted fst-italic">
                        Không có ghi chú.
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- Right Column Sidebar -->
    <div class="col-xl-4 col-lg-5">
        
        <!-- Status Action -->
        <div class="card border-0 shadow-sm rounded-4 mb-4 border-top border-primary border-4">
            <div class="card-body p-4">
                <h6 class="fw-bold mb-3"><i class="bi bi-lightning-charge text-warning me-2"></i>Triển khai đơn hàng</h6>
                <form asp-action="UpdateStatus" method="post">
                    <input type="hidden" name="orderId" value="@Model.Id" />
                    <div class="input-group mb-3 shadow-sm rounded-3">
                        <select name="status" class="form-select border-0 bg-light fw-bold text-dark py-2">
                            <option value="Pending" selected="@(Model.Status == OrderStatus.Pending)">Chờ xử lý</option>
                            <option value="Processing" selected="@(Model.Status == OrderStatus.Processing)">Đang chuẩn bị</option>
                            <option value="Shipping" selected="@(Model.Status == OrderStatus.Shipping)">Đang giao hàng</option>
                            <option value="Completed" selected="@(Model.Status == OrderStatus.Completed)">Đã giao thành công</option>
                            <option value="Cancelled" selected="@(Model.Status == OrderStatus.Cancelled)">Hủy đơn</option>
                        </select>
                        <button type="submit" class="btn btn-primary fw-bold px-3">CẬP NHẬT</button>
                    </div>
                </form>
            </div>
        </div>

        <!-- Customer & Shipping Detail -->
        <div class="card border-0 shadow-sm rounded-4 mb-4">
            <div class="card-header bg-white py-3 border-bottom d-flex align-items-center">
                <i class="bi bi-person-badge text-success fs-5 me-2"></i>
                <h6 class="fw-bold m-0">Thông tin Vận Chuyển</h6>
            </div>
            <div class="card-body p-4">
                <div class="d-flex align-items-start mb-3">
                    <div class="bg-primary bg-opacity-10 p-2 rounded-circle text-primary me-3">
                        <i class="bi bi-person-fill fs-5"></i>
                    </div>
                    <div>
                        <small class="text-muted d-block">Tên người nhận</small>
                        <span class="fw-bold text-dark">@Model.ReceiverName</span>
                        <div class="text-muted small mt-1">@Model.User?.Email (@Model.User?.Username)</div>
                    </div>
                </div>
                
                <div class="d-flex align-items-start mb-3">
                    <div class="bg-success bg-opacity-10 p-2 rounded-circle text-success me-3">
                        <i class="bi bi-telephone-fill fs-5"></i>
                    </div>
                    <div>
                        <small class="text-muted d-block">Số điện thoại</small>
                        <span class="fw-bold text-dark">@Model.ReceiverPhone</span>
                    </div>
                </div>

                <div class="d-flex align-items-start">
                    <div class="bg-danger bg-opacity-10 p-2 rounded-circle text-danger me-3">
                        <i class="bi bi-geo-alt-fill fs-5"></i>
                    </div>
                    <div>
                        <small class="text-muted d-block">Địa chỉ giao hàng</small>
                        <span class="fw-semibold text-dark">@Model.ShippingAddress</span>
                        @if (!string.IsNullOrEmpty(Model.Province))
                        {
                            <div class="text-muted small mt-1">@Model.Province</div>
                        }
                    </div>
                </div>
            </div>
        </div>

        <!-- Payment Setup -->
        <div class="card border-0 shadow-sm rounded-4 mb-4">
            <div class="card-header bg-white py-3 border-bottom d-flex align-items-center justify-content-between">
                <div class="d-flex align-items-center">
                    <i class="bi bi-wallet2 text-info fs-5 me-2"></i>
                    <h6 class="fw-bold m-0">Thanh toán</h6>
                </div>
                <span class="badge bg-secondary">@(Model.PaymentMethod == PaymentMethod.COD ? "COD" : "Online")</span>
            </div>
            <div class="card-body p-4 bg-light rounded-bottom-4">
                <ul class="list-unstyled mb-0">
                    <li class="d-flex justify-content-between align-items-center mb-2 pb-2">
                        <span class="text-muted">Tổng tiền hàng:</span>
                        <span class="fw-semibold text-dark">@Model.TotalAmount.ToString("N0") ₫</span>
                    </li>
                    <li class="d-flex justify-content-between align-items-center mb-2 pb-2">
                        <span class="text-muted">Phí giao hàng:</span>
                        <span class="fw-semibold text-dark">@Model.ShippingFee.ToString("N0") ₫</span>
                    </li>
                    @if (Model.DiscountAmount > 0)
                    {
                        <li class="d-flex justify-content-between align-items-center mb-2 pb-2">
                            <span class="text-muted">Mã giảm giá <span class="badge bg-danger ms-1">@Model.CouponCode</span>:</span>
                            <span class="fw-semibold text-success">-@Model.DiscountAmount.ToString("N0") ₫</span>
                        </li>
                    }
                    <li class="d-flex justify-content-between align-items-center mt-3 pt-3 border-top border-dark-subtle">
                        <span class="fw-bold text-dark fs-5">Tổng thu:</span>
                        <span class="fw-bold text-danger fs-3">@Model.FinalAmount.ToString("N0") ₫</span>
                    </li>
                </ul>
            </div>
        </div>

    </div>
</div>
