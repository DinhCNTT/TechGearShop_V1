@model TechGearShop_V1.Models.ViewModels.DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
    // Serialize sang JSON an toàn cho Javascript
    var revenueJson    = System.Text.Json.JsonSerializer.Serialize(Model.RevenueData);
    var orderJson      = System.Text.Json.JsonSerializer.Serialize(Model.OrderCountData);
    var labelsJson     = System.Text.Json.JsonSerializer.Serialize(Model.RevenueLabels);
    var topNamesJson   = System.Text.Json.JsonSerializer.Serialize(Model.TopProducts.Select(p => p.Name));
    var topQtyJson     = System.Text.Json.JsonSerializer.Serialize(Model.TopProducts.Select(p => p.SoldQty));
}

<div class="page-header">
    <div>
        <h1><i class="bi bi-grid-1x2-fill me-2 text-primary"></i>Dashboard</h1>
        <p class="text-muted small mb-0">Chào mừng trở lại! Đây là tổng quan hệ thống.</p>
    </div>
    <span class="badge rounded-pill px-3 py-2 fw-semibold"
          style="background:#f0fdf4;color:#16a34a;border:1px solid #86efac;">
        <i class="bi bi-circle-fill me-1" style="font-size:0.45rem;"></i>
        Live · @DateTime.Now.ToString("HH:mm — dd/MM/yyyy")
    </span>
</div>

<style>
    .kpi-link {
        text-decoration: none;
        display: block;
        transition: transform 0.25s cubic-bezier(0.2, 0.8, 0.2, 1), box-shadow 0.25s ease;
    }
    .kpi-link:hover {
        transform: translateY(-5px);
        box-shadow: 0 10px 20px rgba(0, 0, 0, 0.15) !important;
    }
</style>

<!-- ── KPI Cards ── -->
<div class="row g-4 mb-5">
    <div class="col-sm-6 col-xl-3">
        <a href="/Admin/Order" class="kpi-link rounded-4">
            <div class="stat-card stat-blue shadow h-100">
                <div class="deco"></div>
                <div class="icon-badge"><i class="bi bi-bag-check-fill"></i></div>
                <div class="stat-value">@Model.TodayNewOrders</div>
                <div class="stat-label">Đơn hàng mới hôm nay</div>
                <div class="text-white small mt-3 d-flex align-items-center" style="opacity:0.8;">
                    Xem danh sách <i class="bi bi-arrow-right ms-1"></i>
                </div>
            </div>
        </a>
    </div>
    <div class="col-sm-6 col-xl-3">
        <a href="/Admin/Order" class="kpi-link rounded-4">
            <div class="stat-card stat-green shadow h-100">
                <div class="deco"></div>
                <div class="icon-badge"><i class="bi bi-cash-coin"></i></div>
                <div class="stat-value" style="font-size:1.5rem;">@Model.MonthlyRevenue.ToString("N0")đ</div>
                <div class="stat-label">Doanh thu tháng (Hoàn thành)</div>
                <div class="text-white small mt-3 d-flex align-items-center" style="opacity:0.8;">
                    Kế toán đơn hàng <i class="bi bi-arrow-right ms-1"></i>
                </div>
            </div>
        </a>
    </div>
    <div class="col-sm-6 col-xl-3">
        <a href="/Admin/Product" class="kpi-link rounded-4">
            <div class="stat-card stat-amber shadow h-100">
                <div class="deco"></div>
                <div class="icon-badge"><i class="bi bi-exclamation-triangle-fill"></i></div>
                <div class="stat-value">@Model.LowStockProductCount</div>
                <div class="stat-label">Sản phẩm sắp hết hàng (≤5)</div>
                <div class="text-white small mt-3 d-flex align-items-center" style="opacity:0.8;">
                    Nhập kho ngay <i class="bi bi-arrow-right ms-1"></i>
                </div>
            </div>
        </a>
    </div>
    <div class="col-sm-6 col-xl-3">
        <a href="/Admin/Order" class="kpi-link rounded-4">
            <div class="stat-card stat-rose shadow h-100">
                <div class="deco"></div>
                <div class="icon-badge"><i class="bi bi-hourglass-split"></i></div>
                <div class="stat-value">@Model.PendingOrders</div>
                <div class="stat-label">Đơn hàng chờ xử lý</div>
                <div class="text-white small mt-3 d-flex align-items-center" style="opacity:0.8;">
                    Duyệt đơn <i class="bi bi-arrow-right ms-1"></i>
                </div>
            </div>
        </a>
    </div>
</div>

<!-- ── Charts Row ── -->
<div class="row g-4 mb-4">
    <div class="col-lg-8">
        <div class="admin-table-wrap p-4" style="background:#fff;">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h6 class="fw-bold m-0 text-dark">📈 Doanh thu & Đơn hàng (6 tháng)</h6>
                <span class="badge bg-light text-muted">Đơn vị: VNĐ</span>
            </div>
            <canvas id="revenueChart" height="100"></canvas>
        </div>
    </div>
    <div class="col-lg-4">
        <div class="admin-table-wrap p-4" style="background:#fff;">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h6 class="fw-bold m-0 text-dark">🏆 Top sản phẩm bán chạy</h6>
            </div>
            @if (Model.TopProducts.Any())
            {
                <canvas id="topProductChart" height="220"></canvas>
            }
            else
            {
                <div class="text-center text-muted py-5">
                    <i class="bi bi-bar-chart-line fs-1 opacity-25 d-block mb-2"></i>
                    Chưa có dữ liệu doanh số.
                </div>
            }
        </div>
    </div>
</div>

<!-- ── Recent Orders Table ── -->
<div class="admin-table-wrap mb-5">
    <div class="d-flex justify-content-between align-items-center px-4 py-3 border-bottom">
        <h6 class="fw-bold m-0 text-dark">🕒 Đơn hàng gần nhất</h6>
        <a href="/Admin/Order" class="btn-admin-primary py-1 px-3" style="font-size:0.78rem;">
            Xem tất cả <i class="bi bi-arrow-right ms-1"></i>
        </a>
    </div>
    <table class="table admin-table mb-0">
        <thead>
            <tr>
                <th>Mã đơn</th>
                <th>Khách hàng</th>
                <th>Tổng tiền</th>
                <th>Trạng thái</th>
                <th>Thời gian</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var o in Model.RecentOrders)
            {
                <tr>
                    <td><a href="/Admin/Order/Detail/@o.Id" class="fw-bold text-primary text-decoration-none">#@o.Id</a></td>
                    <td>@o.CustomerName</td>
                    <td class="fw-semibold text-danger">@o.FinalAmount.ToString("N0")đ</td>
                    <td>
                        @{
                            var (bg, color) = o.Status switch
                            {
                                "Pending"    => ("#fefce8", "#ca8a04"),
                                "Processing" => ("#eff6ff", "#2563eb"),
                                "Shipping"   => ("#f0f9ff", "#0284c7"),
                                "Completed"  => ("#f0fdf4", "#16a34a"),
                                "Cancelled"  => ("#fff1f2", "#e11d48"),
                                _            => ("#f1f5f9", "#64748b")
                            };
                        }
                        <span class="badge-status" style="background:@bg;color:@color;">@o.Status</span>
                    </td>
                    <td class="text-muted small">@o.OrderDate.ToLocalTime().ToString("HH:mm dd/MM")</td>
                </tr>
            }
            @if (!Model.RecentOrders.Any())
            {
                <tr>
                    <td colspan="5" class="text-center text-muted py-5">
                        <i class="bi bi-inbox fs-1 opacity-25 d-block mb-2"></i>Chưa có đơn hàng nào.
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.2/dist/chart.umd.min.js"></script>
    <script>
        // ── Revenue + Order Count dual-axis chart ──
        const revenueCtx = document.getElementById('revenueChart');
        new Chart(revenueCtx, {
            data: {
                labels: @Html.Raw(labelsJson),
                datasets: [
                    {
                        type: 'line',
                        label: 'Doanh thu (VNĐ)',
                        data: @Html.Raw(revenueJson),
                        borderColor: '#3b82f6',
                        backgroundColor: 'rgba(59,130,246,0.08)',
                        fill: true,
                        tension: 0.4,
                        pointRadius: 5,
                        pointBackgroundColor: '#3b82f6',
                        yAxisID: 'yRevenue'
                    },
                    {
                        type: 'bar',
                        label: 'Số đơn hàng',
                        data: @Html.Raw(orderJson),
                        backgroundColor: 'rgba(16,185,129,0.18)',
                        borderColor: '#10b981',
                        borderWidth: 2,
                        borderRadius: 6,
                        yAxisID: 'yOrders'
                    }
                ]
            },
            options: {
                responsive: true,
                interaction: { mode: 'index', intersect: false },
                plugins: {
                    legend: { position: 'top' },
                    tooltip: {
                        callbacks: {
                            label: ctx => ctx.datasetIndex === 0
                                ? ` ${Number(ctx.raw).toLocaleString('vi-VN')}đ`
                                : ` ${ctx.raw} đơn`
                        }
                    }
                },
                scales: {
                    yRevenue: { position: 'left', ticks: { callback: v => (v/1e6).toFixed(1) + 'M' }, grid: { color: '#f1f5f9' } },
                    yOrders:  { position: 'right', grid: { drawOnChartArea: false } }
                }
            }
        });

        // ── Top Products doughnut ──
        @if (Model.TopProducts.Any())
        {
            <text>
            const topCtx = document.getElementById('topProductChart');
            new Chart(topCtx, {
                type: 'doughnut',
                data: {
                    labels: @Html.Raw(topNamesJson),
                    datasets: [{
                        data: @Html.Raw(topQtyJson),
                        backgroundColor: ['#3b82f6','#10b981','#f59e0b','#f43f5e','#8b5cf6'],
                        borderWidth: 2,
                        borderColor: '#fff'
                    }]
                },
                options: {
                    responsive: true,
                    cutout: '65%',
                    plugins: {
                        legend: { position: 'bottom', labels: { font: { size: 11 }, padding: 12 } }
                    }
                }
            });
            </text>
        }
    </script>
}
