@model TechGearShop_V1.Models.ViewModels.DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";

    var revenueJson  = System.Text.Json.JsonSerializer.Serialize(Model.RevenueData);
    var orderJson    = System.Text.Json.JsonSerializer.Serialize(Model.OrderCountData);
    var labelsJson   = System.Text.Json.JsonSerializer.Serialize(Model.RevenueLabels);
    var topNamesJson = System.Text.Json.JsonSerializer.Serialize(Model.TopProducts.Select(p => p.Name));
    var topQtyJson   = System.Text.Json.JsonSerializer.Serialize(Model.TopProducts.Select(p => p.SoldQty));

    var currentYear = DateTime.Now.Year;
    var yearRange   = Enumerable.Range(2024, currentYear - 2024 + 1).Reverse();

    // Growth badge helpers
    string GClass(double p) => p > 0 ? "g-up" : p < 0 ? "g-down" : "g-flat";
    string GIcon(double p)  => p > 0 ? "bi-arrow-up-right" : p < 0 ? "bi-arrow-down-right" : "bi-minus";
    string GText(double p)  => p == 0 ? "Không đổi vs kỳ trước" : $"{(p > 0 ? "+" : "")}{p:0.#}% vs kỳ trước";
}

<style>
/* ── Dashboard Page Styles ── */
.db-header {
    display: flex; align-items: flex-start; justify-content: space-between;
    flex-wrap: wrap; gap: 16px; margin-bottom: 32px;
    position: relative; z-index: 100;
}
.db-header-left h1 {
    font-size: 1.6rem; font-weight: 800; color: #0f172a;
    margin: 0 0 4px; letter-spacing: -0.02em;
}
.db-header-left p { color: #64748b; font-size: 0.875rem; margin: 0; }

/* Period filter pill */
.period-filter {
    display: flex; align-items: center; gap: 8px;
    background: #fff; border: 1.5px solid #e2e8f0;
    border-radius: 14px; padding: 8px 14px;
    box-shadow: 0 2px 8px rgba(0,0,0,0.06);
    transition: box-shadow 0.2s;
}
.period-filter:focus-within { box-shadow: 0 4px 16px rgba(59,130,246,0.18); border-color: #93c5fd; }
.period-filter .pf-icon { color: #3b82f6; font-size: 1rem; }
.period-filter select {
    border: none; outline: none; background: transparent;
    font-size: 0.82rem; font-weight: 600; color: #334155;
    cursor: pointer; padding: 0 2px;
}
.period-filter .pf-divider { color: #cbd5e1; font-size: 0.8rem; }
.pf-btn {
    background: #3b82f6; color: #fff; border: none; border-radius: 8px;
    padding: 5px 12px; font-size: 0.78rem; font-weight: 600; cursor: pointer;
    transition: background 0.2s, transform 0.15s;
}
.pf-btn:hover { background: #2563eb; transform: translateY(-1px); }

/* Live badge */
.live-dot {
    display: inline-flex; align-items: center; gap: 6px;
    font-size: 0.75rem; font-weight: 600; color: #16a34a;
    background: #f0fdf4; border: 1px solid #bbf7d0;
    border-radius: 20px; padding: 4px 12px;
}
.live-dot::before {
    content: ''; width: 7px; height: 7px; border-radius: 50%;
    background: #22c55e; animation: pulse 1.5s infinite;
}
@@keyframes pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50%       { opacity: 0.5; transform: scale(1.3); }
}

/* ── KPI Cards ── */
.kpi-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; margin-bottom: 28px; }
@@media (max-width: 1100px) { .kpi-grid { grid-template-columns: repeat(2, 1fr); } }

.kpi-card {
    position: relative; border-radius: 20px; padding: 24px;
    overflow: hidden; text-decoration: none; display: block;
    transition: transform 0.3s cubic-bezier(0.34,1.56,0.64,1), box-shadow 0.3s ease;
}
.kpi-card:hover { transform: translateY(-6px) scale(1.01); }
.kpi-card .kc-orb {
    position: absolute; right: -24px; top: -24px;
    width: 110px; height: 110px; border-radius: 50%;
    background: rgba(255,255,255,0.1);
}
.kpi-card .kc-orb2 {
    position: absolute; right: 30px; bottom: -30px;
    width: 70px; height: 70px; border-radius: 50%;
    background: rgba(255,255,255,0.06);
}
.kc-icon {
    width: 46px; height: 46px; border-radius: 14px;
    display: flex; align-items: center; justify-content: center;
    background: rgba(255,255,255,0.22); font-size: 1.3rem;
    color: #fff; margin-bottom: 18px;
    backdrop-filter: blur(4px);
}
.kc-value {
    font-size: 1.85rem; font-weight: 800; color: #fff;
    line-height: 1; letter-spacing: -0.03em; margin-bottom: 4px;
}
.kc-label { font-size: 0.78rem; font-weight: 500; color: rgba(255,255,255,0.75); margin-bottom: 14px; }
.kc-footer {
    display: flex; align-items: center; justify-content: space-between;
    border-top: 1px solid rgba(255,255,255,0.15); padding-top: 12px; margin-top: 4px;
}
.kc-link { font-size: 0.75rem; color: rgba(255,255,255,0.7); text-decoration: none; display: flex; align-items: center; gap: 4px; }
.kc-link:hover { color: #fff; }

/* Growth badges */
.g-badge {
    font-size: 0.7rem; font-weight: 700; padding: 3px 8px;
    border-radius: 20px; display: inline-flex; align-items: center; gap: 3px; white-space: nowrap;
}
.g-up   { background: rgba(255,255,255,0.25); color: #d1fae5; }
.g-down { background: rgba(0,0,0,0.15); color: #fecaca; }
.g-flat { background: rgba(255,255,255,0.12); color: rgba(255,255,255,0.6); }

/* Card color themes */
.kpi-blue  { background: linear-gradient(140deg, #3b82f6 0%, #1d4ed8 100%); box-shadow: 0 8px 28px rgba(59,130,246,0.4); }
.kpi-emerald { background: linear-gradient(140deg, #10b981 0%, #047857 100%); box-shadow: 0 8px 28px rgba(16,185,129,0.4); }
.kpi-amber { background: linear-gradient(140deg, #f59e0b 0%, #b45309 100%); box-shadow: 0 8px 28px rgba(245,158,11,0.4); }
.kpi-rose  { background: linear-gradient(140deg, #f43f5e 0%, #9f1239 100%); box-shadow: 0 8px 28px rgba(244,63,94,0.4); }

/* ── Chart & Widget panels ── */
.panel {
    background: #fff; border-radius: 20px;
    box-shadow: 0 2px 16px rgba(0,0,0,0.06);
    overflow: hidden;
}
.panel-header {
    display: flex; align-items: center; justify-content: space-between;
    padding: 20px 24px 0; margin-bottom: 20px;
}
.panel-title { font-size: 0.95rem; font-weight: 700; color: #0f172a; display: flex; align-items: center; gap: 8px; }
.panel-title .pt-icon {
    width: 32px; height: 32px; border-radius: 10px;
    display: flex; align-items: center; justify-content: center;
    font-size: 0.9rem;
}
.panel-badge { font-size: 0.7rem; padding: 3px 10px; border-radius: 20px; font-weight: 600; }

/* ── Orders Table in panel ── */
.dt-table { width: 100%; border-collapse: collapse; }
.dt-table thead th {
    padding: 10px 20px; font-size: 0.68rem; font-weight: 700;
    text-transform: uppercase; letter-spacing: 0.08em;
    color: #94a3b8; background: #f8fafc; border-bottom: 1px solid #f1f5f9;
}
.dt-table tbody td { padding: 13px 20px; font-size: 0.85rem; border-bottom: 1px solid #f8fafc; vertical-align: middle; }
.dt-table tbody tr:last-child td { border-bottom: none; }
.dt-table tbody tr { transition: background 0.15s; }
.dt-table tbody tr:hover { background: #f8faff; }

.order-id { font-weight: 700; color: #3b82f6; font-size: 0.85rem; }
.status-pill {
    display: inline-flex; align-items: center; gap: 5px;
    font-size: 0.68rem; font-weight: 700; padding: 4px 10px;
    border-radius: 20px; text-transform: uppercase; letter-spacing: 0.04em;
}

/* ── Counter animation ── */
.counter { display: inline-block; }

/* ── Stagger animations ── */
.stagger { opacity: 0; transform: translateY(20px); animation: fadeUp 0.5s ease forwards; }
.s1 { animation-delay: 0.05s; } .s2 { animation-delay: 0.12s; }
.s3 { animation-delay: 0.19s; } .s4 { animation-delay: 0.26s; }
.s5 { animation-delay: 0.33s; } .s6 { animation-delay: 0.40s; }
@@keyframes fadeUp { to { opacity: 1; transform: translateY(0); } }
</style>

<!-- ── Header ── -->
<div class="db-header stagger s1">
    <div class="db-header-left">
        <h1>Dashboard</h1>
        <p>
            <span class="live-dot" id="live-clock">Live · @DateTime.Now.ToString("HH:mm:ss, dd/MM/yyyy")</span>
            &nbsp;·&nbsp; Kỳ xem: <strong>Tháng @Model.SelectedMonth / @Model.SelectedYear</strong>
        </p>
    </div>

    <!-- Period Filter -->
    <form method="get" action="/Admin/Dashboard">
        <div class="period-filter">
            <i class="bi bi-calendar3 pf-icon"></i>
            <select name="month">
                @for (int m = 1; m <= 12; m++)
                {
                    if (m == Model.SelectedMonth) { <option value="@m" selected>Tháng @m</option> }
                    else                          { <option value="@m">Tháng @m</option> }
                }
            </select>
            <span class="pf-divider">/</span>
            <select name="year">
                @foreach (var y in yearRange)
                {
                    if (y == Model.SelectedYear) { <option value="@y" selected>@y</option> }
                    else                         { <option value="@y">@y</option> }
                }
            </select>
            <button type="submit" class="pf-btn ms-1"><i class="bi bi-arrow-right-short"></i> Xem</button>
        </div>
    </form>
</div>

<!-- ── KPI Cards ── -->
<div class="kpi-grid">
    <!-- Card 1: Đơn hôm nay -->
    <a href="/Admin/Order" class="kpi-card kpi-blue stagger s1">
        <div class="kc-orb"></div><div class="kc-orb2"></div>
        <div class="kc-icon"><i class="bi bi-bag-check"></i></div>
        <div class="kc-value counter" data-target="@Model.TodayNewOrders">0</div>
        <div class="kc-label">Đơn hàng mới hôm nay</div>
        <div class="kc-footer">
            <span class="kc-link">Xem danh sách <i class="bi bi-arrow-right"></i></span>
            @if (Model.TodayNewOrders > 0)
            {
                <span class="g-badge g-up"><i class="bi bi-fire"></i> Hôm nay có đơn</span>
            }
            else
            {
                <span class="g-badge g-flat"><i class="bi bi-moon"></i> Chưa có đơn</span>
            }
        </div>
    </a>

    <!-- Card 2: Doanh thu tháng -->
    <a href="/Admin/Order" class="kpi-card kpi-emerald stagger s2">
        <div class="kc-orb"></div><div class="kc-orb2"></div>
        <div class="kc-icon"><i class="bi bi-coin"></i></div>
        <div class="kc-value" style="font-size:1.45rem;">@Model.MonthlyRevenue.ToString("N0")đ</div>
        <div class="kc-label">Doanh thu kỳ chọn (Hoàn thành)</div>
        <div class="kc-footer">
            <span class="kc-link">Chi tiết <i class="bi bi-arrow-right"></i></span>
            <span class="g-badge @GClass(Model.RevenueGrowthPercent)">
                <i class="bi @GIcon(Model.RevenueGrowthPercent)"></i> @GText(Model.RevenueGrowthPercent)
            </span>
        </div>
    </a>

    <!-- Card 3: Tồn kho thấp -->
    <a href="/Admin/Product" class="kpi-card kpi-amber stagger s3">
        <div class="kc-orb"></div><div class="kc-orb2"></div>
        <div class="kc-icon"><i class="bi bi-exclamation-diamond"></i></div>
        <div class="kc-value counter" data-target="@Model.LowStockProductCount">0</div>
        <div class="kc-label">Sản phẩm sắp hết hàng (≤5)</div>
        <div class="kc-footer">
            <span class="kc-link">Nhập kho <i class="bi bi-arrow-right"></i></span>
            @if (Model.LowStockProductCount > 0)
            {
                <span class="g-badge g-down"><i class="bi bi-bell"></i> Cần xử lý</span>
            }
            else
            {
                <span class="g-badge g-up"><i class="bi bi-check2"></i> Ổn định</span>
            }
        </div>
    </a>

    <!-- Card 4: Chờ duyệt -->
    <a href="/Admin/Order" class="kpi-card kpi-rose stagger s4">
        <div class="kc-orb"></div><div class="kc-orb2"></div>
        <div class="kc-icon"><i class="bi bi-hourglass-split"></i></div>
        <div class="kc-value counter" data-target="@Model.PendingOrders">0</div>
        <div class="kc-label">Đơn hàng chờ xử lý</div>
        <div class="kc-footer">
            <span class="kc-link">Duyệt ngay <i class="bi bi-arrow-right"></i></span>
            @if (Model.PendingOrders > 0)
            {
                <span class="g-badge g-down"><i class="bi bi-clock"></i> Cần duyệt</span>
            }
            else
            {
                <span class="g-badge g-up"><i class="bi bi-check2-all"></i> Hết hàng chờ</span>
            }
        </div>
    </a>
</div>

<!-- ── Chart Row ── -->
<div class="row g-4 mb-4">
    <!-- Revenue Chart -->
    <div class="col-lg-8 stagger s5">
        <div class="panel" style="padding-bottom: 24px;">
            <div class="panel-header">
                <div class="panel-title">
                    <div class="pt-icon" style="background:#eff6ff; color:#3b82f6;">
                        <i class="bi bi-graph-up-arrow"></i>
                    </div>
                    Doanh thu &amp; Đơn hàng (6 kỳ gần nhất)
                </div>
                <span class="panel-badge" style="background:#f0fdf4; color:#16a34a;">Đơn vị: VNĐ</span>
            </div>
            <div style="padding: 0 24px;">
                <canvas id="revenueChart" height="90"></canvas>
            </div>
        </div>
    </div>

    <!-- Top Products Donut -->
    <div class="col-lg-4 stagger s6">
        <div class="panel" style="padding-bottom: 24px;">
            <div class="panel-header">
                <div class="panel-title">
                    <div class="pt-icon" style="background:#fef3c7; color:#d97706;">
                        <i class="bi bi-trophy"></i>
                    </div>
                    Top sản phẩm bán chạy
                </div>
            </div>
            <div style="padding: 0 24px;">
                @if (Model.TopProducts.Any())
                {
                    <canvas id="topProductChart" height="210"></canvas>
                }
                else
                {
                    <div class="text-center py-5 text-muted">
                        <i class="bi bi-bar-chart-line fs-1 d-block mb-2 opacity-25"></i>
                        <small>Chưa có dữ liệu doanh số.</small>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<!-- ── Recent Orders ── -->
<div class="panel stagger s6" style="margin-bottom: 40px;">
    <div class="panel-header" style="padding-bottom: 16px; border-bottom: 1px solid #f1f5f9;">
        <div class="panel-title">
            <div class="pt-icon" style="background:#f5f3ff; color:#7c3aed;">
                <i class="bi bi-receipt-cutoff"></i>
            </div>
            Đơn hàng gần nhất
        </div>
        <a href="/Admin/Order" class="btn-admin-primary py-1 px-3" style="font-size:0.78rem; border-radius: 10px;">
            Xem tất cả <i class="bi bi-arrow-right ms-1"></i>
        </a>
    </div>
    <table class="dt-table">
        <thead>
            <tr>
                <th>Mã đơn</th>
                <th>Khách hàng</th>
                <th>Tổng tiền</th>
                <th>Trạng thái</th>
                <th>Thời gian</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var o in Model.RecentOrders)
            {
                var (pillBg, pillColor, pillIcon) = o.Status switch {
                    "Pending"    => ("#fef9c3","#a16207","bi-clock"),
                    "Processing" => ("#dbeafe","#1d4ed8","bi-arrow-repeat"),
                    "Shipping"   => ("#e0f2fe","#0369a1","bi-truck"),
                    "Completed"  => ("#dcfce7","#15803d","bi-check2-circle"),
                    "Cancelled"  => ("#fee2e2","#b91c1c","bi-x-circle"),
                    _            => ("#f1f5f9","#475569","bi-dot")
                };
                <tr>
                    <td><span class="order-id">#@o.Id</span></td>
                    <td>
                        <div style="display:flex;align-items:center;gap:8px;">
                            <div style="width:30px;height:30px;border-radius:50%;background:linear-gradient(135deg,#3b82f6,#7c3aed);display:flex;align-items:center;justify-content:center;color:#fff;font-size:0.72rem;font-weight:700;flex-shrink:0;">
                                @o.CustomerName.Substring(0, Math.Min(1, o.CustomerName.Length)).ToUpper()
                            </div>
                            <span style="font-weight:500;color:#334155;">@o.CustomerName</span>
                        </div>
                    </td>
                    <td style="font-weight:700;color:#0f172a;">@o.FinalAmount.ToString("N0")đ</td>
                    <td>
                        <span class="status-pill" style="background:@pillBg;color:@pillColor;">
                            <i class="bi @pillIcon"></i> @o.Status
                        </span>
                    </td>
                    <td style="color:#94a3b8;font-size:0.8rem;">@o.OrderDate.ToLocalTime().ToString("HH:mm · dd/MM")</td>
                </tr>
            }
            @if (!Model.RecentOrders.Any())
            {
                <tr>
                    <td colspan="5" class="text-center py-5 text-muted">
                        <i class="bi bi-inbox fs-1 d-block mb-2 opacity-25"></i>
                        Chưa có đơn hàng nào.
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.2/dist/chart.umd.min.js"></script>
    <script>
    // ── Counter animation ──
    document.querySelectorAll('.counter[data-target]').forEach(el => {
        const target = +el.dataset.target;
        if (target === 0) { el.textContent = '0'; return; }
        let start = 0;
        const step = Math.ceil(target / 40);
        const timer = setInterval(() => {
            start = Math.min(start + step, target);
            el.textContent = start.toLocaleString('vi-VN');
            if (start >= target) clearInterval(timer);
        }, 25);
    });

    // ── Real-time clock ──
    (function tickClock() {
        const el = document.getElementById('live-clock');
        if (!el) return;
        const now = new Date();
        const hh = String(now.getHours()).padStart(2, '0');
        const mm = String(now.getMinutes()).padStart(2, '0');
        const ss = String(now.getSeconds()).padStart(2, '0');
        const dd = String(now.getDate()).padStart(2, '0');
        const mo = String(now.getMonth() + 1).padStart(2, '0');
        const yy = now.getFullYear();
        el.textContent = `Live · ${hh}:${mm}:${ss}, ${dd}/${mo}/${yy}`;
        setTimeout(tickClock, 1000);
    })();

    // ── Chart defaults ──
    Chart.defaults.font.family = "'Inter', sans-serif";
    Chart.defaults.color = '#94a3b8';

    // ── Revenue + Orders dual-axis ──
    new Chart(document.getElementById('revenueChart'), {
        data: {
            labels: @Html.Raw(labelsJson),
            datasets: [
                {
                    type: 'line',
                    label: 'Doanh thu (VNĐ)',
                    data: @Html.Raw(revenueJson),
                    borderColor: '#3b82f6',
                    backgroundColor: 'rgba(59,130,246,0.07)',
                    fill: true, tension: 0.45,
                    pointRadius: 5, pointHoverRadius: 8,
                    pointBackgroundColor: '#fff',
                    pointBorderColor: '#3b82f6',
                    pointBorderWidth: 2.5,
                    yAxisID: 'yR'
                },
                {
                    type: 'bar',
                    label: 'Số đơn',
                    data: @Html.Raw(orderJson),
                    backgroundColor: 'rgba(16,185,129,0.15)',
                    borderColor: '#10b981',
                    borderWidth: 2,
                    borderRadius: 8,
                    borderSkipped: false,
                    yAxisID: 'yO'
                }
            ]
        },
        options: {
            responsive: true,
            animation: { duration: 900, easing: 'easeOutQuart' },
            interaction: { mode: 'index', intersect: false },
            plugins: {
                legend: { position: 'top', labels: { usePointStyle: true, padding: 20, font: { size: 12 } } },
                tooltip: {
                    backgroundColor: '#0f172a', titleColor: '#94a3b8', bodyColor: '#f1f5f9',
                    padding: 12, cornerRadius: 12, borderColor: '#1e293b', borderWidth: 1,
                    callbacks: {
                        label: ctx => ctx.datasetIndex === 0
                            ? ` ${Number(ctx.raw).toLocaleString('vi-VN')}đ`
                            : ` ${ctx.raw} đơn`
                    }
                }
            },
            scales: {
                yR: { position: 'left', grid: { color: '#f1f5f9' }, ticks: { callback: v => (v/1e6).toFixed(0) + 'M' } },
                yO: { position: 'right', grid: { drawOnChartArea: false }, ticks: { precision: 0 } },
                x:  { grid: { display: false } }
            }
        }
    });

    @if (Model.TopProducts.Any())
    {
        <text>
        new Chart(document.getElementById('topProductChart'), {
            type: 'doughnut',
            data: {
                labels: @Html.Raw(topNamesJson),
                datasets: [{ data: @Html.Raw(topQtyJson),
                    backgroundColor: ['#3b82f6','#10b981','#f59e0b','#f43f5e','#8b5cf6'],
                    borderWidth: 3, borderColor: '#fff', hoverOffset: 6
                }]
            },
            options: {
                responsive: true, cutout: '68%',
                animation: { animateRotate: true, duration: 1000 },
                plugins: {
                    legend: { position: 'bottom', labels: { usePointStyle: true, padding: 14, font: { size: 11 } } },
                    tooltip: {
                        backgroundColor: '#0f172a', cornerRadius: 10, padding: 10,
                        callbacks: { label: ctx => ` ${ctx.label}: ${ctx.raw} sản phẩm` }
                    }
                }
            }
        });
        </text>
    }
    </script>
}
