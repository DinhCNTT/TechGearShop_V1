@{
    ViewData["Title"] = "Dashboard";
}

<div class="page-header">
    <div>
        <h1><i class="bi bi-grid-1x2-fill me-2 text-primary"></i>Dashboard</h1>
        <p class="text-muted small mb-0">Chào mừng trở lại! Đây là tổng quan hệ thống hôm nay.</p>
    </div>
    <span class="badge bg-primary-subtle text-primary px-3 py-2 rounded-pill fw-semibold">
        <i class="bi bi-circle-fill text-success me-1" style="font-size:0.5rem"></i>
        Live · @DateTime.Now.ToString("HH:mm dd/MM/yyyy")
    </span>
</div>

<!-- Stat Cards -->
<div class="row g-4 mb-4">
    <div class="col-sm-6 col-xl-3">
        <div class="stat-card stat-blue shadow">
            <div class="deco"></div>
            <div class="icon-badge"><i class="bi bi-bag-check-fill"></i></div>
            <div class="stat-value">0</div>
            <div class="stat-label">Đơn hàng mới hôm nay</div>
            <a href="/Admin/Order" class="text-white small mt-3 d-block opacity-75">Xem chi tiết <i class="bi bi-arrow-right"></i></a>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="stat-card stat-green shadow">
            <div class="deco"></div>
            <div class="icon-badge"><i class="bi bi-cash-coin"></i></div>
            <div class="stat-value">0đ</div>
            <div class="stat-label">Doanh thu tháng này</div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="stat-card stat-amber shadow">
            <div class="deco"></div>
            <div class="icon-badge"><i class="bi bi-exclamation-triangle-fill"></i></div>
            <div class="stat-value">0</div>
            <div class="stat-label">Sản phẩm sắp hết hàng</div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="stat-card stat-rose shadow">
            <div class="deco"></div>
            <div class="icon-badge"><i class="bi bi-people-fill"></i></div>
            <div class="stat-value">0</div>
            <div class="stat-label">Người dùng mới</div>
        </div>
    </div>
</div>

<!-- Info placeholder -->
<div class="p-4 rounded-4 border border-dashed text-center" style="background:#f8fafc; border-color:#cbd5e1 !important;">
    <i class="bi bi-bar-chart-line fs-1 text-muted opacity-50"></i>
    <p class="text-muted mt-2 mb-0">Biểu đồ doanh thu sẽ được tích hợp ở Ngày 11 (Chart.js).</p>
</div>
