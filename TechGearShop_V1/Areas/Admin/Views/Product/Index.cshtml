@model TechGearShop_V1.Models.ViewModels.ProductListViewModel

@{
    ViewData["Title"] = "Quản lý Sản phẩm";
}

<div class="page-header mb-4" style="position: relative;">
    <h1><i class="bi bi-box-seam-fill me-2 text-primary"></i>Quản lý Sản phẩm</h1>
    <a asp-action="Create" class="btn-admin-primary" style="position: absolute; left: 50%; transform: translateX(-50%);">
        <i class="bi bi-plus-lg me-1"></i> Thêm Sản phẩm
    </a>
</div>

<!-- Filter Toolbar -->
<div class="card border-0 shadow-sm rounded-4 mb-4">
    <div class="card-body p-3">
        <form method="get" action="/Admin/Product" class="row g-3 align-items-center">
            <div class="col-md-4">
                <select name="categoryId" class="form-select bg-light border-0">
                    <option value="">-- Tất cả danh mục --</option>
                    @foreach (var cat in Model.Categories)
                    {
                        if (Model.CurrentCategoryId == cat.Id)
                        {
                            <option value="@cat.Id" selected>@cat.Name</option>
                        }
                        else
                        {
                            <option value="@cat.Id">@cat.Name</option>
                        }
                    }
                </select>
            </div>
            <div class="col-md-8">
                <div class="input-group">
                    <input type="text" name="searchKeyword" value="@Model.CurrentKeyword" class="form-control bg-light border-0" placeholder="Nhập tên sản phẩm, thương hiệu..." />
                    <button type="submit" class="btn btn-primary px-4"><i class="bi bi-search me-1"></i> Tìm</button>
                    @if(!string.IsNullOrEmpty(Model.CurrentKeyword) || Model.CurrentCategoryId > 0)
                    {
                        <a href="/Admin/Product" class="btn btn-outline-secondary px-3"><i class="bi bi-x-circle me-1"></i> Xóa lọc</a>
                    }
                </div>
            </div>
        </form>
    </div>
</div>

<div class="admin-table-wrap">
    <table class="table admin-table mb-0">
        <thead>
            <tr>
                <th>Sản phẩm</th>
                <th>Danh mục</th>
                <th>Giá bán</th>
                <th>Tồn kho</th>
                <th>Trạng thái</th>
                <th class="text-end pe-3">Thao tác</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.Products)
            {
                <tr>
                    <td>
                        <div class="d-flex align-items-center gap-3">
                            @if (!string.IsNullOrEmpty(item.ImagePath))
                            {
                                <img src="@item.ImagePath" alt="@item.Name" width="44" height="44"
                                     class="rounded-3 object-fit-cover shadow-sm border" />
                            }
                            else
                            {
                                <div class="rounded-3 bg-light border d-flex align-items-center justify-content-center text-muted"
                                     style="width:44px;height:44px;">
                                    <i class="bi bi-image"></i>
                                </div>
                            }
                            <div>
                                <span class="fw-semibold text-dark">@item.Name</span>
                                @if (item.IsFeatured)
                                {
                                    <span class="badge bg-warning text-dark ms-2 align-text-top" style="font-size:0.65rem;"><i class="bi bi-star-fill"></i> Nổi bật</span>
                                }
                                <div class="text-muted mt-1" style="font-size:0.75rem;">
                                    <i class="bi bi-cart-check me-1"></i> Đã bán: <span class="fw-bold">@item.SoldCount</span>
                                </div>
                            </div>
                        </div>
                    </td>
                    <td>
                        <span class="badge-status" style="background:#f0f9ff;color:#0369a1;">@item.Category?.Name</span>
                    </td>
                    <td>
                        <div class="fw-bold text-danger">@item.Price.ToString("N0")đ</div>
                        @if (item.PromotionalPrice.HasValue)
                        {
                            <small class="text-muted text-decoration-line-through">@item.PromotionalPrice.Value.ToString("N0")đ</small>
                        }
                    </td>
                    <td>
                        @if (item.Stock <= 5)
                        {
                            <span class="fw-bold text-danger"><i class="bi bi-exclamation-circle me-1"></i>@item.Stock</span>
                        }
                        else
                        {
                            <span class="fw-semibold text-dark">@item.Stock</span>
                        }
                    </td>
                    <td>
                        @if (item.IsActive)
                        {
                            <span class="badge-status" style="background:#f0fdf4;color:#16a34a;"><i class="bi bi-circle-fill me-1" style="font-size:0.45rem;vertical-align:middle;"></i>Hiển thị</span>
                        }
                        else
                        {
                            <span class="badge-status" style="background:#fff1f2;color:#e11d48;"><i class="bi bi-circle-fill me-1" style="font-size:0.45rem;vertical-align:middle;"></i>Đã ẩn</span>
                        }
                    </td>
                    <td class="text-end pe-3">
                        <div class="d-flex gap-1 justify-content-end">
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn-icon btn-icon-edit" title="Chỉnh sửa">
                                <i class="bi bi-pencil-fill"></i>
                            </a>
                            <form asp-action="Delete" asp-route-id="@item.Id" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn-icon btn-icon-delete" title="Ẩn sản phẩm"
                                        onclick="return confirm('Ẩn sản phẩm @item.Name?')">
                                    <i class="bi bi-trash-fill"></i>
                                </button>
                            </form>
                        </div>
                    </td>
                </tr>
            }
            @if (!Model.Products.Any())
            {
                <tr>
                    <td colspan="6" class="text-center text-muted py-5">
                        <i class="bi bi-inbox fs-1 opacity-30 d-block mb-2"></i>
                        Chưa có sản phẩm nào.
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@if (Model.TotalPages > 1)
{
    <nav class="mt-4 d-flex justify-content-between align-items-center">
        <small class="text-muted ms-2">Hiển thị @Model.Products.Count() / @Model.TotalItems sản phẩm</small>
        <ul class="pagination justify-content-end m-0">
            <li class="page-item @(Model.CurrentPage == 1 ? "disabled" : "")">
                <a class="page-link" href="/Admin/Product?page=@(Model.CurrentPage - 1)&categoryId=@Model.CurrentCategoryId&searchKeyword=@Model.CurrentKeyword">
                    <i class="bi bi-chevron-left"></i>
                </a>
            </li>
            @for (int i = 1; i <= Model.TotalPages; i++)
            {
                <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                    <a class="page-link" href="/Admin/Product?page=@i&categoryId=@Model.CurrentCategoryId&searchKeyword=@Model.CurrentKeyword">@i</a>
                </li>
            }
            <li class="page-item @(Model.CurrentPage == Model.TotalPages ? "disabled" : "")">
                <a class="page-link" href="/Admin/Product?page=@(Model.CurrentPage + 1)&categoryId=@Model.CurrentCategoryId&searchKeyword=@Model.CurrentKeyword">
                    <i class="bi bi-chevron-right"></i>
                </a>
            </li>
        </ul>
    </nav>
}
