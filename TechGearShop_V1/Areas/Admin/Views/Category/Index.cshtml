@model IEnumerable<TechGearShop_V1.Models.Entities.Category>

@{
    ViewData["Title"] = "Quản lý Danh mục";
}

<div class="page-header" style="position: relative;">
    <h1><i class="bi bi-tags-fill me-2 text-primary"></i>Quản lý Danh mục</h1>
    <a asp-action="Create" class="btn-admin-primary" style="position: absolute; left: 50%; transform: translateX(-50%);">
        <i class="bi bi-plus-lg me-1"></i> Thêm Danh mục
    </a>
</div>

<div class="admin-table-wrap p-3">
    <table class="table admin-table mb-0" id="categoryTable">
        <thead>
            <tr>
                <th style="width:50px">ID</th>
                <th style="width:200px">Tên danh mục</th>
                <th>Mô tả</th>
                <th style="width:120px">Trạng thái</th>
                <th style="width:80px" class="text-end pe-3">Thao tác</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td><span class="text-muted small fw-semibold">#@item.Id</span></td>
                    <td>
                        <span class="fw-semibold text-dark">@item.Name</span>
                    </td>
                    <td><span class="text-muted small">@(item.Description ?? "—")</span></td>
                    <td>
                        @if (item.IsActive)
                        {
                            <span class="badge-status" style="background:#f0fdf4;color:#16a34a; white-space:nowrap;"><i class="bi bi-circle-fill me-1" style="font-size:0.45rem;vertical-align:middle;"></i>Hoạt động</span>
                        }
                        else
                        {
                            <span class="badge-status" style="background:#fff1f2;color:#e11d48; white-space:nowrap;"><i class="bi bi-circle-fill me-1" style="font-size:0.45rem;vertical-align:middle;"></i>Đã ẩn</span>
                        }
                    </td>
                    <td class="text-end pe-3">
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn-icon btn-icon-edit" title="Chỉnh sửa">
                            <i class="bi bi-pencil-fill"></i>
                        </a>
                    </td>
                </tr>
            }
            @if (!Model.Any())
            {
                <tr>
                    <td colspan="5" class="text-center text-muted py-5">
                        <i class="bi bi-inbox fs-1 opacity-30 d-block mb-2"></i>
                        Chưa có danh mục nào.
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@section Scripts {
    <!-- Thư viện DataTables -->
    <link href="https://cdn.datatables.net/v/bs5/dt-2.0.7/datatables.min.css" rel="stylesheet">
    <style>
        /* Tùy chỉnh DataTables cho mượt mà, chuyên nghiệp */
        div.dt-container .dt-search input {
            border: 1px solid #e2e8f0;
            border-radius: 8px;
            padding: 6px 12px;
            font-size: 0.875rem;
            box-shadow: none;
            outline: none;
            transition: all 0.2s;
        }
        div.dt-container .dt-search input:focus {
            border-color: #3b82f6;
            box-shadow: 0 0 0 3px rgba(59,130,246,0.1);
        }
        div.dt-container .dt-length select {
            border: 1px solid #e2e8f0;
            border-radius: 8px;
            padding: 4px 30px 4px 10px;
            font-size: 0.875rem;
        }
        div.dt-container .dt-info {
            font-size: 0.85rem;
            color: #64748b;
        }
        .admin-table tbody td {
            vertical-align: middle;
        }
    </style>
    <script src="https://cdn.datatables.net/v/bs5/dt-2.0.7/datatables.min.js"></script>
    <script>
        $(document).ready(function() {
            $('#categoryTable').DataTable({
                "language": {
                    "sProcessing":   "Đang xử lý...",
                    "sLengthMenu":   "Xem _MENU_ mục",
                    "sZeroRecords":  "Không tìm thấy dòng nào phù hợp",
                    "sInfo":         "Đang xem _START_ đến _END_ trong tổng số _TOTAL_ mục",
                    "sInfoEmpty":    "Đang xem 0 đến 0 trong tổng số 0 mục",
                    "sInfoFiltered": "(được lọc từ _MAX_ mục)",
                    "sSearch":       "Tìm kiếm nhanh:",
                    "oPaginate": {
                        "sFirst":    "Đầu",
                        "sPrevious": "Trước",
                        "sNext":     "Tiếp",
                        "sLast":     "Cuối"
                    }
                },
                "pageLength": 10,
                "ordering": true,
                "columnDefs": [
                    { "orderable": false, "targets": 4 } // Không sort cột thao tác
                ]
            });
        });
    </script>
}
