@model IEnumerable<TechGearShop_V1.Models.Entities.Category>

@{
    ViewData["Title"] = "Quản lý Danh mục";
}

<div class="page-header">
    <h1><i class="bi bi-tags-fill me-2 text-primary"></i>Quản lý Danh mục</h1>
    <a asp-action="Create" class="btn-admin-primary">
        <i class="bi bi-plus-lg me-1"></i> Thêm Danh mục
    </a>
</div>

<div class="admin-table-wrap">
    <table class="table admin-table mb-0">
        <thead>
            <tr>
                <th style="width:60px">ID</th>
                <th>Tên danh mục</th>
                <th>Mô tả</th>
                <th>Trạng thái</th>
                <th class="text-end pe-3">Thao tác</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td><span class="text-muted small fw-semibold">#@item.Id</span></td>
                    <td>
                        <span class="fw-semibold text-dark">@item.Name</span>
                    </td>
                    <td><span class="text-muted small">@(item.Description ?? "—")</span></td>
                    <td>
                        @if (item.IsActive)
                        {
                            <span class="badge-status" style="background:#f0fdf4;color:#16a34a; white-space:nowrap;"><i class="bi bi-circle-fill me-1" style="font-size:0.45rem;vertical-align:middle;"></i>Hoạt động</span>
                        }
                        else
                        {
                            <span class="badge-status" style="background:#fff1f2;color:#e11d48; white-space:nowrap;"><i class="bi bi-circle-fill me-1" style="font-size:0.45rem;vertical-align:middle;"></i>Đã ẩn</span>
                        }
                    </td>
                    <td class="text-end pe-3">
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn-icon btn-icon-edit" title="Chỉnh sửa">
                            <i class="bi bi-pencil-fill"></i>
                        </a>
                    </td>
                </tr>
            }
            @if (!Model.Any())
            {
                <tr>
                    <td colspan="5" class="text-center text-muted py-5">
                        <i class="bi bi-inbox fs-1 opacity-30 d-block mb-2"></i>
                        Chưa có danh mục nào.
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
